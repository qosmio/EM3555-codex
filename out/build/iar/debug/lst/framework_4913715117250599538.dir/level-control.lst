    960          void emberAfLevelControlClusterServerInitCallback(uint8_t endpoint)
    961          {
    962          #ifdef ZCL_USING_LEVEL_CONTROL_CLUSTER_START_UP_CURRENT_LEVEL_ATTRIBUTE
    963            // StartUp behavior relies StartUpCurrentLevel attributes being tokenized.
    964            if (areStartUpLevelControlServerAttributesTokenized(endpoint)) {
    965              // Read the StartUpOnOff attribute and set the OnOff attribute as per
    966              // following from zcl 7 14-0127-20i-zcl-ch-3-general.doc.
    967              // 3.10.2.2.14	StartUpCurrentLevel Attribute
    968              // The StartUpCurrentLevel attribute SHALL define the desired startup level
    969              // for a device when it is supplied with power and this level SHALL be
    970              // reflected in the CurrentLevel attribute. The values of the StartUpCurrentLevel
    971              // attribute are listed below:
    972              // Table 3 58. Values of the StartUpCurrentLevel Attribute
    973              // Value      Action on power up
    974              // 0x00       Set the CurrentLevel attribute to the minimum value permitted on the device.
    975              // 0x01-0xfe  Set the CurrentLevel attribute to this value.
    976              // 0xff       Set the CurrentLevel attribute to its previous value.
    977          
    978              // Initialize startUpCurrentLevel to assume previous value for currentLevel.
    979              uint8_t startUpCurrentLevel = STARTUP_CURRENT_LEVEL_USE_PREVIOUS_LEVEL;
    980              EmberAfStatus status = emberAfReadAttribute(endpoint,
    981                                                          ZCL_LEVEL_CONTROL_CLUSTER_ID,
    982                                                          ZCL_START_UP_CURRENT_LEVEL_ATTRIBUTE_ID,
    983                                                          CLUSTER_MASK_SERVER,
    984                                                          (uint8_t *)&startUpCurrentLevel,
    985                                                          sizeof(startUpCurrentLevel),
    986                                                          NULL);
    987              if (status == EMBER_ZCL_STATUS_SUCCESS) {
    988                uint8_t currentLevel = 0;
    989                status = emberAfReadAttribute(endpoint,
    990                                              ZCL_LEVEL_CONTROL_CLUSTER_ID,
    991                                              ZCL_CURRENT_LEVEL_ATTRIBUTE_ID,
    992                                              CLUSTER_MASK_SERVER,
    993                                              (uint8_t *)&currentLevel,
    994                                              sizeof(currentLevel),
    995                                              NULL);
    996                if (status == EMBER_ZCL_STATUS_SUCCESS) {
    997                  switch (startUpCurrentLevel) {
    998                    case STARTUP_CURRENT_LEVEL_USE_DEVICE_MINIMUM:
    999                      currentLevel = MIN_LEVEL;
   1000                      break;
   1001                    case STARTUP_CURRENT_LEVEL_USE_PREVIOUS_LEVEL:
   1002                      // Just fetched it.
   1003                      break;
   1004                    default:
   1005                      // Otherwise set to specified value 0x01-0xFE.
   1006                      // But, need to enforce currentLevel's min/max, right?
   1007                      // Spec doesn't mention this.
   1008                      if (startUpCurrentLevel < MIN_LEVEL) {
   1009                        currentLevel = MIN_LEVEL;
   1010                      } else if (startUpCurrentLevel > MAX_LEVEL) {
   1011                        currentLevel = MAX_LEVEL;
   1012                      } else {
   1013                        currentLevel = startUpCurrentLevel;
   1014                      }
   1015                      break;
   1016                  }
   1017                  status = emberAfWriteAttribute(endpoint,
   1018                                                 ZCL_LEVEL_CONTROL_CLUSTER_ID,
   1019                                                 ZCL_CURRENT_LEVEL_ATTRIBUTE_ID,
   1020                                                 CLUSTER_MASK_SERVER,
   1021                                                 (uint8_t *)&currentLevel,
   1022                                                 ZCL_INT8U_ATTRIBUTE_TYPE);
   1023                }
   1024              }
   1025            }
