    359          static void eventsCb(COEX_Events_t events)
    360          {
    361            if ((events & COEX_EVENT_HOLDOFF_CHANGED) != 0U) {
    362              emRadioHoldOffIsr((COEX_GetOptions() & COEX_OPTION_HOLDOFF_ACTIVE) != 0U);
    363            }
    364           #if     SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    365            if ((events & COEX_EVENT_PHY_SELECT_CHANGED) != 0U) {
    366              phySelectIsr();
    367            }
    368           #endif//SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    369            coexEventsCb(events);
    370          }
