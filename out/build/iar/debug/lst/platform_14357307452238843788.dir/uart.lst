   1630          void halInternalUartFlowControl(uint8_t port)
   1631          {
   1632            if (EM_SER1_PORT_EN(port)) {
   1633              uint16_t used = emSerialRxQueues[1]->used;
   1634              uint8_t time = halCommonGetInt16uQuarterSecondTick();
   1635          
   1636              if (used) {
   1637                xonTimer = time;
   1638              }
   1639              // Send an XON if the rx queue is below the XON threshold
   1640              // and an XOFF had been sent that needs to be reversed
   1641              {
   1642                DECLARE_INTERRUPT_STATE;
   1643                DISABLE_INTERRUPTS();
   1644                if ((xcmdCount == -1) && (used <= XON_LIMIT)) {
   1645                  halInternalUart1ForceXon();
   1646                } else if ((used == 0)
   1647                           && ((uint8_t)(time - xonTimer) >= XON_REFRESH_TIME)
   1648                           && (xcmdCount < XON_REFRESH_COUNT)) {
   1649                  halInternalUart1ForceXon();
   1650                } else {
   1651                }
   1652                RESTORE_INTERRUPTS();
   1653              }
   1654            }
   1655          }
   1656          
   1657          #endif
