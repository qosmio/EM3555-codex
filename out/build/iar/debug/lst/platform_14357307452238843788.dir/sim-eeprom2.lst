     93          #define TOKEN_MFG(name, creator, iscnt, isidx, type, arraysize, ...)
     94          
     95          //Fundamental limitations of the Simulated EEPROM design:
     96          //These limitations are forcefully enforced via compile-time errors
     97          //in the declarations that follow because exceeding any of them will
     98          //cause fatal operation and data corruption.
     99          //(1) The maximum number of tokens that can be stored is 254.
    100          //    (Tokens are identified by one-byte values, with 0xFF as invalid.)
    101          //(2a)The maximum size, in bytes, of a token (element) is 254.
    102          //    (One byte, with 0xFF as invalid)
    103          //(2b)Counter tokens must be exactly 4 bytes as determined by sizeof().
    104          //(3) The maximum number of elements in an indexed token is 126.
    105          //    (One byte, with MSB used as counter flag and 0x7F as non-indexed size.)
    106          //(4) The maximum total storage for tokens plus management is SIMEE_BTS_SIZE_B/2.
    107          //    (This limit is due to a Virtual Page only being a limited size and for
    108          //     the Simulated EEPROM to operate with any kind of efficiency, the
    109          //     Base Storage must be small enough to leave room for token copies.)
    110          
    111          //If the arraysize is exactly 1, we need only a single entry in the ptrCache
    112          //to hold this entry.  If the arraysize is not 1, we need +1 to hold
    113          //the redirection entry in the Primary Table and then arraysize entries in
    114          //the indexed table.  This works for all values of arraysize.
    115          #define TOKEN_DEF(name, creator, iscnt, isidx, type, arraysize, ...) \
    116            + (((arraysize) < 127 /*fundamental limit (3)*/)                   \
    117               ? ((arraysize) + (((arraysize) == 1) ? 0 : 1))                  \
    118               : -10000 /*force negative array length compile-time error*/)
    119          //value of all index counts added together

