   \                                 In section .text, align 2, keep-with-next
     27          void halStackSeedRandom(uint32_t seed)
     28          {
     29            seed0 = (uint16_t) seed;
   \                     halStackSeedRandom: (+1)
   \        0x0   0x....             LDR.N    R2,??DataTable1
   \        0x2   0x8010             STRH     R0,[R2, #+0]
     30            if (seed0 == 0) {
   \        0x4   0x8811             LDRH     R1,[R2, #+0]
   \        0x6   0x2900             CMP      R1,#+0
   \        0x8   0xD102             BNE.N    ??halStackSeedRandom_0
     31              seed0 = 0xbeef;
   \        0xA   0xF64B 0x61EF      MOVW     R1,#+48879
   \        0xE   0x8011             STRH     R1,[R2, #+0]
     32            }
     33            seed1 = (uint16_t) (seed >> 16);
   \                     ??halStackSeedRandom_0: (+1)
   \       0x10   0x....             LDR.N    R1,??DataTable1_1
   \       0x12   0x0C00             LSRS     R0,R0,#+16
   \       0x14   0x8008             STRH     R0,[R1, #+0]
     34            if (seed1 == 0) {
   \       0x16   0xD102             BNE.N    ??halStackSeedRandom_1
     35              seed1 = 0xface;
   \       0x18   0xF64F 0x20CE      MOVW     R0,#+64206
   \       0x1C   0x8008             STRH     R0,[R1, #+0]
     36            }
     37          }
   \                     ??halStackSeedRandom_1: (+1)
   \       0x1E   0x4770             BX       LR
     38          
     39          /*
     40           *    the stdlib rand() takes about 2.25ms @3.68MHz on the AVR
     41           *    hell- you can run an software implimentation AES cipher block in 1.5ms!
     42           *    obviously an LFSR method is much faster (12us on a 4MHz 128AVR actually).
     43           *    in the FPGA we did the first poly you see here but on a 32bit seed,
     44           *    taking only the msb word, but we quickly noticed a sequential nature
     45           *    in the output. so at each random number generation we actually ran the
     46           *    LFSR 16 times. we can avoid that but still remove the sequential nature
     47           *    and get a good looking spread by running two LFSRs and XORing them.
     48           */
     49          
     50          // ** NOTE: we might consider replacing the pseudo rng generation by
     51          // LFSR with something like SCG, LCG, or ACG - if the time trade off
     52          // is acceptable.
     53          

   \                                 In section .text, align 2, keep-with-next
     54          static uint16_t shift(uint16_t *val, uint16_t taps)
     55          {
   \                     shift: (+1)
   \        0x0   0x4602             MOV      R2,R0
     56            uint16_t newVal = *val;
   \        0x2   0x8810             LDRH     R0,[R2, #+0]
     57          
     58            if ((newVal & 0x8000) != 0U) {
   \        0x4   0x0403             LSLS     R3,R0,#+16
   \        0x6   0xD501             BPL.N    ??shift_0
     59              newVal ^= taps;
   \        0x8   0x4041             EORS     R1,R1,R0
   \        0xA   0x4608             MOV      R0,R1
     60            }
     61            *val = newVal << 1;
   \                     ??shift_0: (+1)
   \        0xC   0x0041             LSLS     R1,R0,#+1
   \        0xE   0x8011             STRH     R1,[R2, #+0]
     62            return newVal;
   \       0x10   0x4770             BX       LR
     63          }
     64          

   \                                 In section .text, align 2, keep-with-next
     65          uint16_t halCommonGetRandom(void)
     66          {
   \                     halCommonGetRandom: (+1)
   \        0x0   0xB510             PUSH     {R4,LR}
     67            uint16_t val;
     68            val = (shift(&seed0, 0x0062) ^ shift(&seed1, 0x100B));
   \        0x2   0x2162             MOVS     R1,#+98
   \        0x4   0x....             LDR.N    R0,??DataTable1
   \        0x6   0x.... 0x....      BL       shift
   \        0xA   0x4604             MOV      R4,R0
   \        0xC   0xF241 0x010B      MOVW     R1,#+4107
   \       0x10   0x....             LDR.N    R0,??DataTable1_1
   \       0x12   0x.... 0x....      BL       shift
   \       0x16   0x4044             EORS     R4,R0,R4
     69          
     70            // See Task EFM32ESS-869
     71            #ifdef RNG_SELF_TEST
     72            while (lastval == val) {
     73              val = (shift(&seed0, 0x0062) ^ shift(&seed1, 0x100B));
     74            }
     75            lastval = val;
     76            #endif
     77          
     78            return val;
   \       0x18   0x4620             MOV      R0,R4
   \       0x1A   0xBD10             POP      {R4,PC}
     79          }

