    591          // PTA MAC/PHY Event Handling
    592          
    593          #define PTA_RX_TIMEOUT_US 10000u
    594          #define PTA_RX_RETRY_US (1000u * halPtaGetOptionMask(PTA_OPT_RX_RETRY_TIMEOUT_MS, \
    595                                                               PTA_OPT_SHIFT_RX_RETRY_TIMEOUT_MS))
    596          
    597          #if     USE_MULTITIMER
    598          
    599          static void setTimer(RAIL_MultiTimer_t * timer,
    600                               uint32_t time,
    601                               RAIL_MultiTimerCallback_t cb)
    602          {
    603            if (!RAIL_IsMultiTimerRunning(timer)) {
    604              RAIL_SetMultiTimer(timer,
    605                                 time,
    606                                 RAIL_TIME_DELAY,
    607                                 cb,
    608                                 NULL);
    609            }
    610          }
    611          
    612          static void cancelTimer(RAIL_MultiTimer_t * timer)
    613          {
    614            (void) RAIL_CancelMultiTimer(timer);
    615          }
    616          
    617          static RAIL_MultiTimer_t ptaRxTimer;
    618          static RAIL_MultiTimer_t ptaRxRetryTimer;
    619          
    620          #if SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    621          static RAIL_MultiTimer_t ptaPhySelectTimer;
    622          static void ptaPhySelectTimerCb(RAIL_MultiTimer_t * tmr,
    623                                          RAIL_Time_t expectedTimeOfEvent,
    624                                          void *cbArg)
    625          {
    626            UNUSED_VAR(tmr);
    627            UNUSED_VAR(expectedTimeOfEvent);
    628            UNUSED_VAR(cbArg);
    629            phySelectTick();
    630          }
    631          
    632          static void phySelectTick(void)
    633          {
    634            if (phySelectTimeoutMs != 0U && !RAIL_IsMultiTimerRunning(&ptaPhySelectTimer)) {
    635              halCoexNewPhySelectedCoex = false;
    636              COEX_EnablePhySelectIsr(true);
    637            }
    638          }
    639          
    640          #define MICROSECONDS_PER_MILLISECOND (1000U)
    641          static void phySelectIsr(void)
    642          {
    643            halCoexNewPhySelectedCoex = true;
    644            if (phySelectInitialized) {
    645              setTimer(&ptaPhySelectTimer, phySelectTimeoutMs * MICROSECONDS_PER_MILLISECOND, &ptaPhySelectTimerCb);
    646            }
    647          }
    648          #endif //SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    649          
    650          static void ptaRxTimerCb(RAIL_MultiTimer_t * tmr,
    651                                   RAIL_Time_t expectedTimeOfEvent,
    652                                   void *cbArg)
    653          {
    654            UNUSED_VAR(tmr);
    655            UNUSED_VAR(expectedTimeOfEvent);
    656            UNUSED_VAR(cbArg);
    657            cancelTimer(&ptaRxTimer);
    658            cancelTimer(&ptaRxRetryTimer);
    659            (void) halPtaSetRxRequest(PTA_REQ_OFF, NULL);
    660          }
    661          
    662          // Both timers do the same thing, and cancel each other
    663          #define ptaRxRetryTimerCb ptaRxTimerCb
    664          
    665          #define checkTimers() /*no-op*/
    666          
    667          #else//!USE_MULTITIMER
    668          
    669          static void setTimer(int32_t * timer, uint32_t time, uint16_t * timeout)
    670          {
    671            *timer = -1;
    672            *timeout = (uint16_t) (time / 1000u);   // Micro to milliseconds
    673            *timer = (int32_t) halCommonGetInt16uMillisecondTick();
    674          }
    675          
    676          static void cancelTimer(int32_t * timer)
    677          {
    678            *timer = -1;
    679          }
    680          
    681          static int32_t ptaRxTimer = -1;
    682          static uint16_t ptaRxTimerCb = 0;
    683          static int32_t ptaRxRetryTimer = -1;
    684          static uint16_t ptaRxRetryTimerCb = 0;
    685          
    686          static bool isPtaTimerExpired(int32_t timerMs, uint16_t timeoutMs)
    687          {
    688            return (timerMs >= 0)
    689                   && (elapsedTimeInt16u((uint16_t)timerMs,
    690                                         halCommonGetInt16uMillisecondTick()) > timeoutMs);
    691          }
    692          
    693          static void checkTimers(void)
    694          {
    695            if (isPtaTimerExpired(ptaRxTimer, ptaRxTimerCb)
    696                || isPtaTimerExpired(ptaRxRetryTimer, ptaRxRetryTimerCb)) {
    697              // Both timers do the same thing, and cancel each other
    698              cancelTimer(&ptaRxTimer);
    699              cancelTimer(&ptaRxRetryTimer);
    700              (void) halPtaSetRxRequest(PTA_REQ_OFF, NULL);
    701            }
    702          }
    703          
    704          #endif//USE_MULTITIMER
    705          
    706          #if USE_MULTITIMER && SL_RAIL_UTIL_COEX_PWM_DEFAULT_ENABLED
    707          static bool pwmRequestInitialized = false;
    708          static void initPwmRequest(void)
    709          {
    710            extern RAIL_Handle_t emPhyRailHandle;
    711            if (!pwmRequestInitialized && emPhyRailHandle != NULL) {
    712              halPtaSetRequestPwm(COEX_REQ_PWM
    713                                  | (SL_RAIL_UTIL_COEX_PWM_PRIORITY << COEX_REQ_HIPRI_SHIFT),
    714                                  NULL,
    715                                  SL_RAIL_UTIL_COEX_PWM_REQ_DUTYCYCLE,
    716                                  SL_RAIL_UTIL_COEX_PWM_REQ_PERIOD);
    717              pwmRequestInitialized = true;
    718            }
    719          }
    720          #else //!(USE_MULTITIMER && SL_RAIL_UTIL_COEX_PWM_DEFAULT_ENABLED)
    721          #define initPwmRequest() //no-op
    722          #endif // USE_MULTITIMER && SL_RAIL_UTIL_COEX_PWM_DEFAULT_ENABLED
    723          
    724          halPtaStackStatus_t halPtaStackEvent(halPtaStackEvent_t ptaStackEvent,
    725                                               uint32_t supplement)
    726          {
    727            halPtaStackStatus_t status = PTA_STACK_STATUS_SUCCESS;
    728            bool isReceivingFrame = false;
    729          
    730            switch (ptaStackEvent) {
    731              case PTA_STACK_EVENT_TICK:
    732                if (halPtaIsEnabled()) {
    733                  initPwmRequest();
    734                  checkTimers();
    735                }
    736                (void) checkPhySwitch();
    737                break;
    738          
    739              // RX events:
    740              case PTA_STACK_EVENT_RX_STARTED:
    741                if (halPtaIsEnabled()) {
    742                  isReceivingFrame = (bool) supplement;
    743                  if (isReceivingFrame) {
    744                    (void) halPtaSetRxRequest(halPtaFrameDetectReq(), NULL);
    745                    cancelTimer(&ptaRxRetryTimer);
    746                    setTimer(&ptaRxTimer, PTA_RX_TIMEOUT_US, &ptaRxTimerCb);
    747                  }
    748                }
    749                setBlockPhySwitch(BLOCK_SWITCH_RX, true);
    750                break;
    751          
    752              case PTA_STACK_EVENT_RX_ACCEPTED:
    753                if (halPtaIsEnabled()) {
    754                  isReceivingFrame = (bool) supplement;
    755                  if (isReceivingFrame) {
    756                    halPtaReq_t filterPass = halPtaFilterPassReq();
    757                    if (filterPass != halPtaFrameDetectReq()) {
    758                      (void) halPtaSetRxRequest(filterPass, NULL);
    759                    }
    760                  }
    761                }
    762                setBlockPhySwitch(BLOCK_SWITCH_RX, true);
    763                break;
    764          
    765              case PTA_STACK_EVENT_RX_ACKING:
    766                // Defer Rx PTA cancellation to RX_ACK_* events
    767                setBlockPhySwitch(BLOCK_SWITCH_RX, true);
    768                break;
    769          
    770              case PTA_STACK_EVENT_RX_CORRUPTED:
    771              case PTA_STACK_EVENT_RX_ACK_BLOCKED:
    772              case PTA_STACK_EVENT_RX_ACK_ABORTED:
    773                if (halPtaIsEnabled()) {
    774                  if ((halPtaGetOptions() & PTA_OPT_RX_RETRY_REQ) != 0U) {
    775                    cancelTimer(&ptaRxTimer);
    776                    // Assert request and start rx retry timer.
    777                    (void) halPtaSetRxRequest(PTA_REQ_ON | PTA_RX_RETRY_PRI, NULL);
    778                    setTimer(&ptaRxRetryTimer, PTA_RX_RETRY_US, &ptaRxRetryTimerCb);
    779                    break;
    780                  }
    781                }
    782              // FALLTHROUGH
    783          
    784              case PTA_STACK_EVENT_RX_FILTERED:
    785              case PTA_STACK_EVENT_RX_ENDED:
    786              case PTA_STACK_EVENT_RX_ACK_SENT:
    787                isReceivingFrame = (bool) supplement;
    788              // FALLTHROUGH
    789          
    790              case PTA_STACK_EVENT_RX_IDLED:
    791                if (halPtaIsEnabled()) {
    792                  cancelTimer(&ptaRxTimer);
    793                  cancelTimer(&ptaRxRetryTimer);
    794                  if (!isReceivingFrame) {
    795                    (void) halPtaSetRxRequest(PTA_REQ_OFF, NULL);
    796                  }
    797                }
    798                setBlockPhySwitch(BLOCK_SWITCH_RX, isReceivingFrame);
    799                break;
    800          
    801              // TX events:
    802              case PTA_STACK_EVENT_TX_PENDED_MAC:
    803                if (halPtaIsEnabled()) {
    804                  halPtaCb_t cb = (halPtaCb_t) supplement;
    805                  HalPtaOptions ptaOptions = halPtaGetOptions();
    806                  if ((ptaOptions & PTA_OPT_MAC_AND_FORCE_HOLDOFFS) == PTA_OPT_MAC_AND_FORCE_HOLDOFFS) {
    807                    // Tell caller NOT to transmit
    808                    status = PTA_STACK_STATUS_HOLDOFF;
    809                  } else if (((ptaOptions & PTA_OPT_MAC_AND_FORCE_HOLDOFFS) == PTA_OPT_MAC_HOLDOFF)
    810                             && (cb != NULL)) {
    811                    // Assert Tx REQUEST  and wait for GRANT
    812                    halPtaSetTxRequest(PTA_REQ_ON | PTA_TX_PRI | PTA_REQCB_GRANTED, cb);
    813                    status = PTA_STACK_STATUS_CB_PENDING;
    814                  } else {
    815                    // No callback - proceed with a normal transmit
    816                  }
    817                }
    818                break;
    819          
    820              case PTA_STACK_EVENT_TX_PENDED_PHY:
    821                if (halPtaIsEnabled()) {
    822                  bool isCcaTransmit = (bool) supplement;
    823                  if (isCcaTransmit && ((halPtaGetOptions() & PTA_OPT_LONG_REQ) == 0U)) {
    824                    // Defer Tx req to CCA_SOON event
    825                  } else {
    826                    halPtaSetTxRequest(PTA_REQ_ON | PTA_TX_PRI, NULL);
    827                  }
    828                }
    829                setBlockPhySwitch(BLOCK_SWITCH_TX, true);
    830                break;
    831          
    832              case PTA_STACK_EVENT_TX_CCA_SOON:
    833                if (halPtaIsEnabled()) {
    834                  (void) halPtaSetTxRequest(PTA_REQ_ON | PTA_TX_PRI, NULL);
    835                }
    836                break;
    837          
    838              case PTA_STACK_EVENT_TX_CCA_BUSY:
    839                if (halPtaIsEnabled()) {
    840                  bool isNextCcaImminent = (bool) supplement;
    841                  if (!isNextCcaImminent) {
    842                    (void) halPtaSetTxRequest(PTA_REQ_OFF, NULL);
    843                  }
    844                }
    845                break;
    846          
    847              case PTA_STACK_EVENT_TX_STARTED:
    848              case PTA_STACK_EVENT_TX_ACK_WAITING:
    849                // Currently these events are advisory and leave TX REQ asserted
    850                break;
    851          
    852              case PTA_STACK_EVENT_TX_ACK_RECEIVED:
    853                if (halPtaIsEnabled()) {
    854                  bool hasFramePending = (bool) supplement;
    855                  (void) hasFramePending;
    856                  (void) halPtaSetTxRequest(PTA_REQ_OFF, NULL);
    857                  deescalatePriority();
    858                }
    859                setBlockPhySwitch(BLOCK_SWITCH_TX, false);
    860                break;
    861          
    862              case PTA_STACK_EVENT_TX_ACK_TIMEDOUT:
    863                if (halPtaIsEnabled()) {
    864                  uint8_t macRetries = (uint8_t) supplement;
    865                  if ((macRetries == 0) || halPtaGetTxReqRelease()) {
    866                    (void) halPtaSetTxRequest(PTA_REQ_OFF, NULL);
    867                    if (macRetries == 0) {
    868                      escalatePriority(&ptaMacFailEscalate,
    869                                       halPtaGetMacFailCounterThreshold());
    870                    }
    871                  } else {
    872                    // Hold Tx REQ for a MAC retransmit
    873                  }
    874                }
    875                setBlockPhySwitch(BLOCK_SWITCH_TX, false);
    876                break;
    877          
    878              case PTA_STACK_EVENT_TX_BLOCKED:
    879              case PTA_STACK_EVENT_TX_ABORTED:
    880                if (halPtaIsEnabled()) {
    881                  (void) halPtaSetTxRequest(PTA_REQ_OFF, NULL);
    882                  bool pktRequestedAck = (bool) supplement;
    883                  if (pktRequestedAck) {
    884                    if (ptaStackEvent == PTA_STACK_EVENT_TX_BLOCKED) {
    885                      escalatePriority(&ptaCcaFailEscalate,
    886                                       halPtaGetCcaCounterThreshold());
    887                    }
    888                    escalatePriority(&ptaMacFailEscalate,
    889                                     halPtaGetMacFailCounterThreshold());
    890                  }
    891                }
    892                setBlockPhySwitch(BLOCK_SWITCH_TX, false);
    893                break;
    894          
    895              case PTA_STACK_EVENT_TX_ENDED:
    896              case PTA_STACK_EVENT_TX_IDLED:
    897                if (halPtaIsEnabled()) {
    898                  (void) halPtaSetTxRequest(PTA_REQ_OFF, NULL);
    899                }
    900                setBlockPhySwitch(BLOCK_SWITCH_TX, false);
    901                break;
    902          
    903              default:
    904                break;
    905            }
    906            #if EMBER_AF_PLUGIN_COULOMB_COUNTER
    907            // Set the state w.r.t Coulomb Counter
    908            halCoulombCounterEvent(ptaStackEvent);
    909            #endif
    910            return status;
    911          }
