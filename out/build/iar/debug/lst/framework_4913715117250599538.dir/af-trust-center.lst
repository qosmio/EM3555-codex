    227          };
    228          
    229          void ezspTrustCenterJoinHandler(EmberNodeId newNodeId,
    230                                          EmberEUI64 newNodeEui64,
    231                                          EmberDeviceUpdate status,
    232                                          EmberJoinDecision policyDecision,
    233                                          EmberNodeId parentOfNewNode)
    234          {
    235            emberAfPushCallbackNetworkIndex();
    236          #if defined(EMBER_AF_PLUGIN_DELAYED_JOIN)
    237            policyDecision = (status == EMBER_STANDARD_SECURITY_SECURED_REJOIN
    238                              || status == EMBER_STANDARD_SECURITY_UNSECURED_REJOIN)
    239                             ? EMBER_USE_PRECONFIGURED_KEY
    240                             : EMBER_NO_ACTION;
    241          #endif
    242            //this would be the callback
    243            securityJoinNotify(newNodeId,
    244                               newNodeEui64,
    245                               parentOfNewNode,
    246                               status,
    247                               policyDecision);
    248            emberAfPopNetworkIndex();
    249          }
    250          
    251          static EmberStatus setJoinPolicy(EmberJoinDecision decision)
    252          {
    253            EzspDecisionBitmask policy = EZSP_DECISION_BITMASK_DEFAULT_CONFIGURATION;
    254            uint8_t textId = 0;
    255          
    256            if (decision == EMBER_USE_PRECONFIGURED_KEY) {
    257              policy = (EZSP_DECISION_ALLOW_JOINS | EZSP_DECISION_ALLOW_UNSECURED_REJOINS);
    258              textId = 1;
    259            } else if (decision == EMBER_SEND_KEY_IN_THE_CLEAR) {
    260              policy = (EZSP_DECISION_ALLOW_JOINS | EZSP_DECISION_ALLOW_UNSECURED_REJOINS | EZSP_DECISION_SEND_KEY_IN_CLEAR);
    261              textId = 2;
    262            }
    263            return emberAfSetEzspPolicy(EZSP_TRUST_CENTER_POLICY,
    264                                        policy,
    265                                        "Trust Center Policy",
    266                                        ezspJoinPolicyText[textId]);
    267          }
    268          
    269          static EmberStatus permitRequestingTrustCenterLinkKey(void)
    270          {
    271            const EmberAfSecurityProfileData *data = emAfGetCurrentSecurityProfileData();
    272            if (data == NULL) {
    273              return EMBER_ERR_FATAL;
    274            }
    275          
    276            return emberAfSetEzspPolicy(EZSP_TC_KEY_REQUEST_POLICY,
    277                                        data->tcLinkKeyRequestPolicy,
    278                                        "TC Key Request",
    279                                        (data->tcLinkKeyRequestPolicy
    280                                         !=  EMBER_AF_DENY_TC_KEY_REQUESTS
    281                                         ? "Allow"
    282                                         : "Deny"));
    283          }
    284          
    285          static EmberStatus permitRequestingApplicationLinkKey(void)
    286          {
    287            const EmberAfSecurityProfileData *data = emAfGetCurrentSecurityProfileData();
    288            if (data == NULL) {
    289              return EMBER_ERR_FATAL;
    290            }
    291            return emberAfSetEzspPolicy(EZSP_APP_KEY_REQUEST_POLICY,
    292                                        data->appLinkKeyRequestPolicy,
    293                                        "App. Key Request",
    294                                        (data->appLinkKeyRequestPolicy
    295                                         != EMBER_AF_DENY_APP_KEY_REQUESTS
    296                                         ? "Allow"
    297                                         : "Deny"));
    298          }
