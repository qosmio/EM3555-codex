    239          static EmberStatus sendOutput(uint8_t *data, uint8_t length)
    240          {
    241            uint8_t blockSize;
    242            uint16_t startTime = halCommonGetInt16uMillisecondTick();
    243            if (debugChannel[RAM_OUT_STATUS_INDEX] != RAM_OUT_STATUS_GO
    244                || debugChannel[RAM_OUT_LENGTH_INDEX] != 0
    245                || length < OUT_DATA_INDEX) {
    246              return EMBER_ERR_FATAL;
    247            }
    248            debugChannel[RAM_OUT_LENGTH_INDEX] = length;
    249            *ramOutBlockPointer = (uint32_t)data;
    250            blockSize = MIN(length, MAX_BLOCK_SIZE);
    251            debugChannel[RAM_OUT_BLOCK_SIZE_INDEX] = blockSize;
    252            while (length > 0) {
    253              uint16_t now = halCommonGetInt16uMillisecondTick();
    254              if (elapsedTimeInt16u(startTime, now) > TIMEOUT_MS) {
    255                break;
    256              }
    257              if (debugChannel[RAM_OUT_BLOCK_SIZE_INDEX] == 0) {
    258                length -= blockSize;
    259                if (length > 0) {
    260                  *ramOutBlockPointer += blockSize;
    261                  blockSize = MIN(length, MAX_BLOCK_SIZE);
    262                  debugChannel[RAM_OUT_BLOCK_SIZE_INDEX] = blockSize;
    263                }
    264              }
    265            }
    266            debugChannel[RAM_OUT_LENGTH_INDEX] = 0;
    267            debugChannel[RAM_OUT_BLOCK_SIZE_INDEX] = 0;
    268            if (length == 0) {
    269              return EMBER_SUCCESS;
    270            } else {
    271              debugChannel[RAM_OUT_STATUS_INDEX] = RAM_OUT_STATUS_STOP;
    272              return EMBER_ERR_FATAL;
    273            }
    274          }
    275          
