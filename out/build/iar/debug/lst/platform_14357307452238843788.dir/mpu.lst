   \                                 In section .text, align 2, keep-with-next
     91          void halInternalSetMPUGuardRegionStart(uint32_t baseAddress)
     92          {
   \                     halInternalSetMPUGuardRegionStart: (+1)
   \        0x0   0xB538             PUSH     {R3-R5,LR}
   \        0x2   0x4604             MOV      R4,R0
     93            uint32_t attr = GUARD_REGION_ATTR_EN;
   \        0x4   0x....             LDR.N    R5,??DataTable3_2
     94          
     95            // Clear the lower 5 bits of the base address to be sure that it's
     96            // properly aligned
     97            baseAddress &= 0xFFFFFFE0U;
   \        0x6   0x0964             LSRS     R4,R4,#+5
   \        0x8   0x0164             LSLS     R4,R4,#+5
     98          
     99            // If the base address is below the reset info then something weird is
    100            // going on so just turn off the guard region
    101            if (baseAddress < (uint32_t)(uint8_t *)_RESETINFO_SEGMENT_END) {
   \        0xA   0x....             LDR.N    R0,??DataTable3_3
   \        0xC   0x4284             CMP      R4,R0
   \        0xE   0xD200             BCS.N    ??halInternalSetMPUGuardRegionStart_0
    102              attr = GUARD_REGION_ATTR_DIS;
   \       0x10   0x....             LDR.N    R5,??DataTable3_4
    103            }
    104          
    105            // Add in the guard region number so the MPU knows which region to configure
    106            baseAddress |= GUARD_REGION & 0x0000001F;
    107          
    108            // Set the base address for the MPU guard region
    109            {
    110              DECLARE_INTERRUPT_STATE;
    111              DISABLE_INTERRUPTS();
   \                     ??halInternalSetMPUGuardRegionStart_0: (+1)
   \       0x12   0x.... 0x....      BL       _disableBasePri
    112              mpuConfig[GUARD_REGION & 0xF].base = baseAddress;
   \       0x16   0x....             LDR.N    R1,??DataTable3
   \       0x18   0xF044 0x0414      ORR      R4,R4,#0x14
   \       0x1C   0x620C             STR      R4,[R1, #+32]
    113              mpuConfig[GUARD_REGION & 0xF].attr = attr;
   \       0x1E   0x624D             STR      R5,[R1, #+36]
    114              RESTORE_INTERRUPTS();
   \       0x20   0xE8BD 0x4032      POP      {R1,R4,R5,LR}
   \       0x24   0x.... 0x....      B.W      _writeBasePri
    115            }
    116          }
