     27          // Application generated ZDO messages use sequence numbers 0-127, and the stack
     28          // uses sequence numbers 128-255.  This simplifies life by eliminating the need
     29          // for coordination between the two entities, and allows both to send ZDO
     30          // messages with non-conflicting sequence numbers.
     31          #define APPLICATION_ZDO_SEQUENCE_MASK (0x7F)
     32          

