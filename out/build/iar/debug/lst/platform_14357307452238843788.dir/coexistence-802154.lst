    263          
    264          #include "rail_types.h"
    265          // This is grody, but it beats making the PHY need to know about all
    266          // the Coex PHYs.  Borrow from unreleased phy/phy.h:
    267          enum {
    268            EMBER_RADIO_POWER_MODE_RX_ON,
    269            EMBER_RADIO_POWER_MODE_OFF
    270          };
    271          typedef uint8_t RadioPowerMode;
    272          #if SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    273          extern bool halCoexPhySelectedCoex;
    274          #define halCoexPhyChanged() (halCoexNewPhySelectedCoex != halCoexPhySelectedCoex)
    275          #define halCoexUpdateSelectedPhy() (halCoexPhySelectedCoex = halCoexNewPhySelectedCoex)
    276          #else //!SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    277          #define halCoexPhyChanged() (false)
    278          #define halCoexUpdateSelectedPhy() /*no-op*/
    279          #endif //SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    280          
    281          extern RAIL_Handle_t emPhyRailHandle;
    282          #if     PHY_DUAL
    283          // Map to native PHY only
    284          #define emPhyGetChannelPageInUse emPhy0_emPhyGetChannelPageInUse
    285          #define emRadioGetIdleMode       emPhy0_emRadioGetIdleMode
    286          #define emRadioSetIdleMode       emPhy0_emRadioSetIdleMode
    287          #endif//PHY_DUAL
    288          extern uint8_t emPhyGetChannelPageInUse(void);
    289          extern RadioPowerMode sl_mac_get_radio_idle_mode(uint8_t mac_index);
    290          extern sl_status_t sl_mac_lower_mac_set_radio_idle_mode(uint8_t mac_index, RadioPowerMode mode);
    291          extern RAIL_Status_t halPluginConfig2p4GHzRadio(RAIL_Handle_t railHandle);
    292          
    293          #if     SL_RAIL_UTIL_COEX_PHY_ENABLED
    294          static volatile bool halCoexNewPhySelectedCoex = true;
    295          #else//!SL_RAIL_UTIL_COEX_PHY_ENABLED
    296          static volatile bool halCoexNewPhySelectedCoex = false;
    297          #endif//SL_RAIL_UTIL_COEX_PHY_ENABLED
    298          static uint8_t blockPhySwitch = 0U;
    299          #define BLOCK_SWITCH_RX 0x01u
    300          #define BLOCK_SWITCH_TX 0x02u
    301          #define setBlockPhySwitch(dir, boolval)   \
    302            do {                                    \
    303              if (boolval) {                        \
    304                blockPhySwitch |= (dir);            \
    305              } else {                              \
    306                blockPhySwitch &= (uint8_t) ~(dir); \
    307              }                                     \
    308            } while (false)
    309          
    310          #if SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    311          static bool phySelectInitialized = false;
    312          static void phySelectTick(void);
    313          #endif //SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    314          
    315          static bool checkPhySwitch(void)
    316          {
    317          #if SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    318            if (phySelectInitialized) {
    319              phySelectTick();
    320            } else if (emPhyRailHandle != NULL) {
    321              halPtaSetPhySelectTimeout(SL_RAIL_UTIL_COEX_DEFAULT_PHY_SELECT_TIMEOUT);
    322              phySelectInitialized = true;
    323            }
    324          #endif //SL_RAIL_UTIL_COEX_RUNTIME_PHY_SELECT
    325            if ((halAntDivRxPhyChanged() || halCoexPhyChanged())
    326                && (blockPhySwitch == 0U)
    327                && coexInitialized
    328                && (emPhyRailHandle != NULL)) {
    329              //@TODO: Ascertain radio is OFF, RXWARM, or RXSEARCH only.
    330              halCoexUpdateSelectedPhy();
    331              if (emPhyGetChannelPageInUse() == 0) { // Using 2.4GHz band
    332                RadioPowerMode currentMode = sl_mac_get_radio_idle_mode(0U);
    333                (void) sl_mac_lower_mac_set_radio_idle_mode(0U, EMBER_RADIO_POWER_MODE_OFF);
    334                (void) halPluginConfig2p4GHzRadio(emPhyRailHandle);
    335                (void) sl_mac_lower_mac_set_radio_idle_mode(0U, currentMode);
    336              } else {
    337                // Defer proper PHY selection to when the 2.4GHz band is next used
    338              }
    339              return true;
    340            }
    341            return false;
    342          }
    343          
    344          #else//!RUNTIME_PHY_SELECT
    345          
    346          #define setBlockPhySwitch(dir, boolval) /*no-op*/
    347          #define checkPhySwitch() (false)
    348          
    349          #endif//RUNTIME_PHY_SELECT
