    310          static bool shouldExecuteIfOff(uint8_t endpoint,
    311                                         uint8_t commandId,
    312                                         uint8_t optionMask,
    313                                         uint8_t optionOverride)
    314          {
    315          #ifdef ZCL_USING_LEVEL_CONTROL_CLUSTER_OPTIONS_ATTRIBUTE
    316            // From 3.10.2.2.8.1 of ZCL7 document 14-0127-20j-zcl-ch-3-general.docx:
    317            //   "Command execution SHALL NOT continue beyond the Options processing if
    318            //    all of these criteria are true:
    319            //      - The command is one of the ‘without On/Off’ commands: Move, Move to
    320            //        Level, Stop, or Step.
    321            //      - The On/Off cluster exists on the same endpoint as this cluster.
    322            //      - The OnOff attribute of the On/Off cluster, on this endpoint, is 0x00
    323            //        (FALSE).
    324            //      - The value of the ExecuteIfOff bit is 0."
    325            if (commandId > ZCL_STOP_COMMAND_ID) {
    326              return true;
    327            }
    328          
    329            if (!emberAfContainsServer(endpoint, ZCL_ON_OFF_CLUSTER_ID)) {
    330              return true;
    331            }
    332          
    333            uint8_t options;
    334            EmberAfStatus status = emberAfReadServerAttribute(endpoint,
    335                                                              ZCL_LEVEL_CONTROL_CLUSTER_ID,
    336                                                              ZCL_OPTIONS_ATTRIBUTE_ID,
    337                                                              &options,
    338                                                              sizeof(options));
    339            if (status != EMBER_ZCL_STATUS_SUCCESS) {
    340              emberAfLevelControlClusterPrintln("Unable to read Options attribute: 0x%X",
    341                                                status);
    342              // If we can't read the attribute, then we should just assume that it has its
    343              // default value.
    344              options = 0x00;
    345            }
    346          
    347            bool on;
    348            status = emberAfReadServerAttribute(endpoint,
    349                                                ZCL_ON_OFF_CLUSTER_ID,
    350                                                ZCL_ON_OFF_ATTRIBUTE_ID,
    351                                                (uint8_t *)&on,
    352                                                sizeof(on));
    353            if (status != EMBER_ZCL_STATUS_SUCCESS) {
    354              emberAfLevelControlClusterPrintln("Unable to read OnOff attribute: 0x%X",
    355                                                status);
    356              return true;
    357            }
    358            // The device is on - hence ExecuteIfOff does not matter
    359            if (on) {
    360              return true;
    361            }
    362            // The OptionsMask & OptionsOverride fields SHALL both be present or both
    363            // omitted in the command. A temporary Options bitmap SHALL be created from
    364            // the Options attribute, using the OptionsMask & OptionsOverride fields, if
    365            // present. Each bit of the temporary Options bitmap SHALL be determined as
    366            // follows:
    367            // Each bit in the Options attribute SHALL determine the corresponding bit in
    368            // the temporary Options bitmap, unless the OptionsMask field is present and
    369            // has the corresponding bit set to 1, in which case the corresponding bit in
    370            // the OptionsOverride field SHALL determine the corresponding bit in the
    371            // temporary Options bitmap.
    372            //The resulting temporary Options bitmap SHALL then be processed as defined
    373            // in section 3.10.2.2.3.
    374          
    375            // ---------- The following order is important in decission making -------
    376            // -----------more readable ----------
    377            //
    378            if (optionMask == 0xFF && optionOverride == 0xFF) {
    379              // 0xFF are the default values passed to the command handler when
    380              // the payload is not present - in that case there is use of option
    381              // attribute to decide execution of the command
    382              return READBITS(options, EMBER_ZCL_LEVEL_CONTROL_OPTIONS_EXECUTE_IF_OFF);
    383            }
    384            // ---------- The above is to distinguish if the payload is present or not
    385          
    386            if (READBITS(optionMask, EMBER_ZCL_LEVEL_CONTROL_OPTIONS_EXECUTE_IF_OFF)) {
    387              // Mask is present and set in the command payload, this indicates
    388              // use the over ride as temporary option
    389              return READBITS(optionOverride, EMBER_ZCL_LEVEL_CONTROL_OPTIONS_EXECUTE_IF_OFF);
    390            }
    391            // if we are here - use the option bits
    392            return (READBITS(options, EMBER_ZCL_LEVEL_CONTROL_OPTIONS_EXECUTE_IF_OFF));
    393          
    394          #else
    395            // By default, we return true to continue supporting backwards compatibility.
    396            return true;
   \                     shouldExecuteIfOff: (+1)
   \        0x0   0x2001             MOVS     R0,#+1
   \        0x2   0x4770             BX       LR
    397          #endif
    398          }
