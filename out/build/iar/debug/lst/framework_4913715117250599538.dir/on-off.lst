    186          void emberAfOnOffClusterServerInitCallback(uint8_t endpoint)
    187          {
    188          #ifdef ZCL_USING_ON_OFF_CLUSTER_START_UP_ON_OFF_ATTRIBUTE
    189            // StartUp behavior relies on OnOff and StartUpOnOff attributes being tokenized.
    190            if (areStartUpOnOffServerAttributesTokenized(endpoint)) {
    191              // Read the StartUpOnOff attribute and set the OnOff attribute as per
    192              // following from zcl 7 14-0127-20i-zcl-ch-3-general.doc.
    193              // 3.8.2.2.5	StartUpOnOff Attribute
    194              // The StartUpOnOff attribute SHALL define the desired startup behavior of a
    195              // lamp device when it is supplied with power and this state SHALL be
    196              // reflected in the OnOff attribute.  The values of the StartUpOnOff
    197              // attribute are listed below.
    198              // Table 3 46. Values of the StartUpOnOff Attribute
    199              // Value      Action on power up
    200              // 0x00       Set the OnOff attribute to 0 (off).
    201              // 0x01       Set the OnOff attribute to 1 (on).
    202              // 0x02       If the previous value of the OnOff attribute is equal to 0,
    203              //            set the OnOff attribute to 1.If the previous value of the OnOff
    204              //            attribute is equal to 1, set the OnOff attribute to 0 (toggle).
    205              // 0x03-0xfe  These values are reserved.  No action.
    206              // 0xff       Set the OnOff attribute to its previous value.
    207          
    208              // Initialize startUpOnOff to No action value 0xFE
    209              uint8_t startUpOnOff = 0xFE;
    210              EmberAfStatus status = emberAfReadAttribute(endpoint,
    211                                                          ZCL_ON_OFF_CLUSTER_ID,
    212                                                          ZCL_START_UP_ON_OFF_ATTRIBUTE_ID,
    213                                                          CLUSTER_MASK_SERVER,
    214                                                          (uint8_t *)&startUpOnOff,
    215                                                          sizeof(startUpOnOff),
    216                                                          NULL);
    217              if (status == EMBER_ZCL_STATUS_SUCCESS) {
    218                // Initialise updated value to 0
    219                bool updatedOnOff = 0;
    220                status = emberAfReadAttribute(endpoint,
    221                                              ZCL_ON_OFF_CLUSTER_ID,
    222                                              ZCL_ON_OFF_ATTRIBUTE_ID,
    223                                              CLUSTER_MASK_SERVER,
    224                                              (uint8_t *)&updatedOnOff,
    225                                              sizeof(updatedOnOff),
    226                                              NULL);
    227                if (status == EMBER_ZCL_STATUS_SUCCESS) {
    228                  switch (startUpOnOff) {
    229                    case EMBER_ZCL_START_UP_ON_OFF_VALUE_SET_TO_OFF:
    230                      updatedOnOff = 0; // Off
    231                      break;
    232                    case EMBER_ZCL_START_UP_ON_OFF_VALUE_SET_TO_ON:
    233                      updatedOnOff = 1; //On
    234                      break;
    235                    case EMBER_ZCL_START_UP_ON_OFF_VALUE_SET_TO_TOGGLE:
    236                      updatedOnOff = !updatedOnOff;
    237                      break;
    238                    case EMBER_ZCL_START_UP_ON_OFF_VALUE_SET_TO_PREVIOUS:
    239                    default:
    240                      // All other values 0x03- 0xFE are reserved - no action.
    241                      // When value is 0xFF - update with last value - that is as good as
    242                      // no action.
    243                      break;
    244                  }
    245                  status = emberAfWriteAttribute(endpoint,
    246                                                 ZCL_ON_OFF_CLUSTER_ID,
    247                                                 ZCL_ON_OFF_ATTRIBUTE_ID,
    248                                                 CLUSTER_MASK_SERVER,
    249                                                 (uint8_t *)&updatedOnOff,
    250                                                 ZCL_BOOLEAN_ATTRIBUTE_TYPE);
    251                }
    252              }
    253            }
    254          #endif
    255            emberAfPluginOnOffClusterServerPostInitCallback(endpoint);
