     35          // MAC frame control
     36          // Bits:
     37          // | 0-2   |   3      |    4    |  5  |  6    |   7-9    | 10-11 |  12-13   | 14-15 |
     38          // | Frame | Security |  Frame  | Ack | Intra | Reserved | Dest. | Reserved | Src   |
     39          // | Type  | Enabled  | Pending | Req | PAN   |          | Addr. |          | Adrr. |
     40          // |       |          |         |     |       |          | Mode  |          | Mode  |
     41          
     42          // Frame Type
     43          //   000       = Beacon
     44          //   001       = Data
     45          //   010       = Acknwoledgement
     46          //   011       = MAC Command
     47          //   100 - 111 = Reserved
     48          
     49          // Addressing Mode
     50          //   00 - PAN ID and address field are not present
     51          //   01 - Reserved
     52          //   10 - Address field contains a 16-bit short address
     53          //   11 - Address field contains a 64-bit extended address
     54          
     55          #ifdef EZSP_HOST
     56          #define MAC_FRAME_TYPE_DATA           0x0001
     57          
     58          #define MAC_FRAME_SOURCE_MODE_SHORT 0x8000
     59          #define MAC_FRAME_SOURCE_MODE_LONG  0xC000
     60          
     61          #define MAC_FRAME_DESTINATION_MODE_SHORT   0x0800
     62          #define MAC_FRAME_DESTINATION_MODE_LONG    0x0C00
     63          #endif
     64          // The two possible incoming MAC frame controls.
     65          // Using short source address is not allowed.
     66          #define SHORT_DEST_FRAME_CONTROL (MAC_FRAME_TYPE_DATA                \
     67                                            | MAC_FRAME_DESTINATION_MODE_SHORT \
     68                                            | MAC_FRAME_SOURCE_MODE_LONG)
     69          #define LONG_DEST_FRAME_CONTROL  (MAC_FRAME_TYPE_DATA               \
     70                                            | MAC_FRAME_DESTINATION_MODE_LONG \
     71                                            | MAC_FRAME_SOURCE_MODE_LONG)
     72          
     73          #define MAC_ACK_REQUIRED              0x0020
     74          
     75          #if defined(EMBER_AF_PLUGIN_INTERPAN_ALLOW_APS_ENCRYPTED_MESSAGES)
     76            #define APS_ENCRYPTION_ALLOWED 1
     77          #else
     78            #define APS_ENCRYPTION_ALLOWED 0
     79          #endif
     80          
     81          #define PRIMARY_ENDPOINT   0
     82          #define ALL_ENDPOINTS      1
     83          #define SPECIFIED_ENDPOINT 2
     84          
     85          #if defined(EMBER_AF_PLUGIN_INTERPAN_DELIVER_TO)
     86            #if EMBER_AF_PLUGIN_INTERPAN_DELIVER_TO == PRIMARY_ENDPOINT
     87              #define ENDPOINT emberAfPrimaryEndpoint()
     88          
     89            #elif EMBER_AF_PLUGIN_INTERPAN_DELIVER_TO == ALL_ENDPOINTS
     90              #define ENDPOINT EMBER_BROADCAST_ENDPOINT
     91          
     92            #elif EMBER_AF_PLUGIN_INTERPAN_DELIVER_TO == SPECIFIED_ENDPOINT
     93              #define ENDPOINT EMBER_AF_PLUGIN_INTERPAN_DELIVER_TO_SPECIFIED_ENDPOINT_VALUE
     94          
     95            #else
     96              #error Unknown value for interpan plugin option: EMBER_AF_PLUGIN_INTERPAN_DELIVER_TO
     97            #endif
     98          #else
     99            #error Invalid Interpan plugin Config: EMBER_AF_PLUGIN_INTERPAN_DELIVER_TO not defined.
    100          #endif
