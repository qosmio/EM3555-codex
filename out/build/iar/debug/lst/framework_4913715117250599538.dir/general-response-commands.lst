    309          bool emberAfDiscoverAttributesResponseCallback(EmberAfClusterId clusterId,
    310                                                         bool discoveryComplete,
    311                                                         uint8_t *buffer,
    312                                                         uint16_t bufLen,
    313                                                         bool extended)
    314          {
   \                     emberAfDiscoverAttributesResponseCallback: (+1)
   \        0x0   0xB580             PUSH     {R7,LR}
    315          #if defined(EMBER_AF_PRINT_ENABLE) && defined(EMBER_AF_PRINT_DEBUG)
    316            uint16_t bufIndex = 0;
    317          
    318            emberAfDebugPrint("%p%p_RESP: ", "DISC_ATTR", (extended ? "_EXT" : ""));
    319            emberAfDebugDebugExec(emberAfDecodeAndPrintClusterWithMfgCode(clusterId, emberAfGetMfgCodeFromCurrentCommand()));
    320            emberAfDebugPrintln(" comp %pDONE", discoveryComplete ? "" : "NOT_");
    321            emberAfDebugFlush();
    322          
    323            // Each record in the response has a two-byte attribute id and a one-byte
    324            // type.
    325            while (bufIndex + 3 <= bufLen) {
    326              EmberAfAttributeId attributeId;
