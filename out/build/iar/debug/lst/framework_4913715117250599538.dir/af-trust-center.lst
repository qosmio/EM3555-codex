     51          static uint8_t reverse(uint8_t b)
     52          {
     53          #if defined(EZSP_HOST) || defined(BOARD_SIMULATION)
     54            return ((b * 0x0802UL & 0x22110UL) | (b * 0x8020UL & 0x88440UL)) * 0x10101UL >> 16;
     55          #else
     56            return (__RBIT((uint32_t)b) >> 24); // Cortex function __RBIT uses uint32_t
   \                     reverse: (+1)
   \        0x0   0xFA90 0xF0A0      RBIT     R0,R0
   \        0x4   0x0E00             LSRS     R0,R0,#+24
   \        0x6   0x4770             BX       LR
     57          #endif // EZSP_HOST
     58          }
