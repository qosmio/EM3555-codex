    339          #ifdef EMBER_AF_PLUGIN_COLOR_CONTROL_SERVER_HSV
    340          /** @brief Move To Hue And Saturation
    341           *
    342           *
    343           *
    344           * @param hue   Ver.: always
    345           * @param saturation   Ver.: always
    346           * @param transitionTime   Ver.: always
    347           */
    348          bool emberAfColorControlClusterMoveToHueAndSaturationCallback(uint8_t hue,
    349                                                                        uint8_t saturation,
    350                                                                        uint16_t transitionTime,
    351                                                                        uint8_t optionsMask,
    352                                                                        uint8_t optionsOverride)
    353          {
    354            uint8_t endpoint = emberAfCurrentEndpoint();
    355            uint8_t currentHue = readHue(endpoint);
    356            bool moveUp;
    357          
    358            if (transitionTime == 0) {
    359              transitionTime++;
    360            }
    361          
    362            // limit checking:  hue and saturation are 0..254.  Spec dictates we ignore
    363            // this and report a malformed packet.
    364            if (hue > MAX_HUE_VALUE || saturation > MAX_SATURATION_VALUE) {
    365              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_MALFORMED_COMMAND);
    366              return true;
    367            }
    368          
    369            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
    370              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    371              return true;
    372            }
    373          
    374            // compute shortest direction
    375            if (hue > currentHue) {
    376              moveUp = (hue - currentHue) < HALF_MAX_UINT8T;
    377            } else {
    378              moveUp = (currentHue - hue) > HALF_MAX_UINT8T;
    379            }
    380          
    381            // New command.  Need to stop any active transitions.
    382            stopAllColorTransitions();
    383          
    384            // Handle color mode transition, if necessary.
    385            handleModeSwitch(endpoint, COLOR_MODE_HSV);
    386          
    387            // now, kick off the state machine.
    388            initHueSat(endpoint);
    389          
    390            colorHueTransitionState.initialHue = currentHue;
    391            colorHueTransitionState.currentHue = currentHue;
    392            colorHueTransitionState.finalHue   = hue;
    393            colorHueTransitionState.stepsRemaining = transitionTime;
    394            colorHueTransitionState.stepsTotal     = transitionTime;
    395            colorHueTransitionState.endpoint = endpoint;
    396            colorHueTransitionState.up = moveUp;
    397            colorHueTransitionState.repeat = false;
    398          
    399            colorSaturationTransitionState.initialValue = readSaturation(endpoint);
    400            colorSaturationTransitionState.currentValue = readSaturation(endpoint);
    401            colorSaturationTransitionState.finalValue = saturation;
    402            colorSaturationTransitionState.stepsRemaining = transitionTime;
    403            colorSaturationTransitionState.stepsTotal     = transitionTime;
    404            colorSaturationTransitionState.endpoint       = endpoint;
    405            colorSaturationTransitionState.lowLimit  = MIN_SATURATION_VALUE;
    406            colorSaturationTransitionState.highLimit = MAX_SATURATION_VALUE;
    407          
    408            writeRemainingTime(endpoint, transitionTime);
    409          
    410            // kick off the state machine:
    411            emberEventControlSetDelayMS(COLOR_HSV_CONTROL, UPDATE_TIME_MS);
    412          
    413            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    414            return true;
    415          }
    416          
    417          bool emberAfColorControlClusterMoveHueCallback(uint8_t moveMode,
    418                                                         uint8_t rate,
    419                                                         uint8_t optionsMask,
    420                                                         uint8_t optionsOverride)
    421          {
    422            uint8_t endpoint = emberAfCurrentEndpoint();
    423          
    424            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
    425              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    426              return true;
    427            }
    428          
    429            // New command.  Need to stop any active transitions.
    430            stopAllColorTransitions();
    431          
    432            if (moveMode == EMBER_ZCL_HUE_MOVE_MODE_STOP) {
    433              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    434              return true;
    435            }
    436          
    437            // Handle color mode transition, if necessary.
    438            handleModeSwitch(endpoint, COLOR_MODE_HSV);
    439          
    440            // now, kick off the state machine.
    441            initHueSat(endpoint);
    442          
    443            colorHueTransitionState.initialHue = readHue(endpoint);
    444            colorHueTransitionState.currentHue = readHue(endpoint);
    445            if (moveMode == EMBER_ZCL_HUE_MOVE_MODE_UP) {
    446              colorHueTransitionState.finalHue = addHue(readHue(endpoint),
    447                                                        rate);
    448              colorHueTransitionState.up = true;
    449            } else if (moveMode == EMBER_ZCL_HUE_MOVE_MODE_DOWN) {
    450              colorHueTransitionState.finalHue = subtractHue(readHue(endpoint),
    451                                                             rate);
    452              colorHueTransitionState.up = false;
    453            } else {
    454              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_MALFORMED_COMMAND);
    455              return true;
    456            }
    457            colorHueTransitionState.stepsRemaining = TRANSITION_TIME_1S;
    458            colorHueTransitionState.stepsTotal     = TRANSITION_TIME_1S;
    459            colorHueTransitionState.endpoint = endpoint;
    460            colorHueTransitionState.repeat = true;
    461            // hue movement can last forever.  Indicate this with a remaining time of
    462            // maxint.
    463            writeRemainingTime(endpoint, MAX_INT16U_VALUE);
    464          
    465            colorSaturationTransitionState.stepsRemaining = 0;
    466          
    467            // kick off the state machine:
    468            emberEventControlSetDelayMS(COLOR_HSV_CONTROL, UPDATE_TIME_MS);
    469          
    470            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    471            return true;
    472          }
    473          
    474          bool emberAfColorControlClusterMoveSaturationCallback(uint8_t moveMode,
    475                                                                uint8_t rate,
    476                                                                uint8_t optionsMask,
    477                                                                uint8_t optionsOverride)
    478          {
    479            uint8_t endpoint = emberAfCurrentEndpoint();
    480          
    481            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
    482              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    483              return true;
    484            }
    485          
    486            uint16_t transitionTime;
    487          
    488            // New command.  Need to stop any active transitions.
    489            stopAllColorTransitions();
    490          
    491            if (moveMode == EMBER_ZCL_SATURATION_MOVE_MODE_STOP
    492                || rate == 0) {
    493              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    494              return true;
    495            }
    496          
    497            // Handle color mode transition, if necessary.
    498            handleModeSwitch(endpoint, COLOR_MODE_HSV);
    499          
    500            // now, kick off the state machine.
    501            initHueSat(endpoint);
    502          
    503            colorHueTransitionState.stepsRemaining = 0;
    504          
    505            colorSaturationTransitionState.initialValue = readSaturation(endpoint);
    506            colorSaturationTransitionState.currentValue = readSaturation(endpoint);
    507            if (moveMode == EMBER_ZCL_SATURATION_MOVE_MODE_UP) {
    508              colorSaturationTransitionState.finalValue = MAX_SATURATION_VALUE;
    509            } else {
    510              colorSaturationTransitionState.finalValue = MIN_SATURATION_VALUE;
    511            }
    512          
    513            transitionTime =
    514              computeTransitionTimeFromStateAndRate(&colorSaturationTransitionState,
    515                                                    rate);
    516          
    517            colorSaturationTransitionState.stepsRemaining = transitionTime;
    518            colorSaturationTransitionState.stepsTotal     = transitionTime;
    519            colorSaturationTransitionState.endpoint       = endpoint;
    520            colorSaturationTransitionState.lowLimit  = MIN_SATURATION_VALUE;
    521            colorSaturationTransitionState.highLimit = MAX_SATURATION_VALUE;
    522          
    523            writeRemainingTime(endpoint, transitionTime);
    524          
    525            // kick off the state machine:
    526            emberEventControlSetDelayMS(COLOR_HSV_CONTROL, UPDATE_TIME_MS);
    527          
    528            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    529            return true;
    530          }
    531          
    532          bool emberAfColorControlClusterMoveToHueCallback(uint8_t hue,
    533                                                           uint8_t hueMoveMode,
    534                                                           uint16_t transitionTime,
    535                                                           uint8_t optionsMask,
    536                                                           uint8_t optionsOverride)
    537          {
    538            uint8_t endpoint = emberAfCurrentEndpoint();
    539          
    540            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
    541              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    542              return true;
    543            }
    544          
    545            uint8_t currentHue = readHue(endpoint);
    546            uint8_t direction;
    547          
    548            if (transitionTime == 0) {
    549              transitionTime++;
    550            }
    551          
    552            // limit checking:  hue and saturation are 0..254.  Spec dictates we ignore
    553            // this and report a malformed packet.
    554            if (hue > MAX_HUE_VALUE) {
    555              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_MALFORMED_COMMAND);
    556              return true;
    557            }
    558          
    559            // For move to hue, the move modes are different from the other move commands.
    560            // Need to translate from the move to hue transitions to the internal
    561            // representation.
    562            switch (hueMoveMode) {
    563              case EMBER_ZCL_HUE_DIRECTION_SHORTEST_DISTANCE:
    564                if ( ((uint8_t) (currentHue - hue)) > HALF_MAX_UINT8T ) {
    565                  direction = MOVE_MODE_UP;
    566                } else {
    567                  direction = MOVE_MODE_DOWN;
    568                }
    569                break;
    570              case EMBER_ZCL_HUE_DIRECTION_LONGEST_DISTANCE:
    571                if ( ((uint8_t) (currentHue - hue)) > HALF_MAX_UINT8T ) {
    572                  direction = MOVE_MODE_DOWN;
    573                } else {
    574                  direction = MOVE_MODE_UP;
    575                }
    576                break;
    577                break;
    578              case EMBER_ZCL_HUE_DIRECTION_UP:
    579                direction = MOVE_MODE_UP;
    580                break;
    581              case EMBER_ZCL_HUE_DIRECTION_DOWN:
    582                direction = MOVE_MODE_DOWN;
    583                break;
    584              default:
    585                emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_MALFORMED_COMMAND);
    586                return true;
    587            }
    588          
    589            // New command.  Need to stop any active transitions.
    590            stopAllColorTransitions();
    591          
    592            // Handle color mode transition, if necessary.
    593            handleModeSwitch(endpoint, COLOR_MODE_HSV);
    594          
    595            // now, kick off the state machine.
    596            initHueSat(endpoint);
    597          
    598            colorHueTransitionState.initialHue = readHue(endpoint);
    599            colorHueTransitionState.currentHue = readHue(endpoint);
    600            colorHueTransitionState.finalHue   = hue;
    601            colorHueTransitionState.stepsRemaining = transitionTime;
    602            colorHueTransitionState.stepsTotal     = transitionTime;
    603            colorHueTransitionState.endpoint = endpoint;
    604            colorHueTransitionState.up = (direction == MOVE_MODE_UP);
    605            colorHueTransitionState.repeat = false;
    606          
    607            colorSaturationTransitionState.stepsRemaining = 0;
    608          
    609            writeRemainingTime(endpoint, transitionTime);
    610          
    611            // kick off the state machine:
    612            emberEventControlSetDelayMS(COLOR_HSV_CONTROL, UPDATE_TIME_MS);
    613          
    614            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    615            return true;
    616          }
    617          
