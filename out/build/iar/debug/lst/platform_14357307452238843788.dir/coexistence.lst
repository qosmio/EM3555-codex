    210          static void coexEventCallback(COEX_Events_t events)
    211          {
    212            if (coexRadioCallback != NULL) {
    213              if (COEX_HAL_GetPriority()) {
    214                events |= COEX_EVENT_PRIORITY_ASSERTED;
    215              }
    216              coexRadioCallback(events);
    217            }
    218          }
