   \                                 In section .text, align 2, keep-with-next
    598          static void getPartnerLinkKey(void)
    599          {
    600          #if defined(EMBER_AF_HAS_SECURITY_PROFILE_SE)
    601            EmberEUI64 serverEui64;
    602            uint8_t i;
    603          
    604            if (!emberAfIsCurrentSecurityProfileSmartEnergy()
    605                || serverNodeId == EMBER_TRUST_CENTER_NODE_ID) {
    606              goto partnerLinkKeyDone;
    607            }
    608          
    609            emberAfReadClientAttribute(myEndpoint,
    610                                       ZCL_OTA_BOOTLOAD_CLUSTER_ID,
    611                                       ZCL_UPGRADE_SERVER_ID_ATTRIBUTE_ID,
    612                                       serverEui64,
    613                                       EUI64_SIZE);
    614          
    615            for (i = 0; i < emberAfGetKeyTableSize(); i++) {
    616              EmberKeyStruct keyStruct;
    617              if (EMBER_SUCCESS == emberGetKeyTableEntry(i, &keyStruct)
    618                  && EMBER_APPLICATION_LINK_KEY == keyStruct.type
    619                  && 0 == MEMCOMPARE(keyStruct.partnerEUI64, serverEui64, EUI64_SIZE)) {
    620                goto partnerLinkKeyDone;
    621              }
    622            }
    623          
    624            // Spec is not clear whether the actual key establishment endpoint
    625            // needs to be used, so we just use 1.
    626            if (EMBER_SUCCESS
    627                == emberAfInitiatePartnerLinkKeyExchange(serverNodeId,
    628                                                         1,
    629                                                         otaClientPartnerLinkKeyCallback)) {
    630              return;
    631            }
    632          
    633            // If we fail to initiate partner link key, it could be because
    634            // we don't have any link key spots or the server is no longer online.
    635            // We just retry the entire operation again.
    636            restartServerDiscoveryAfterDelay();
    637            return;
    638          
    639            partnerLinkKeyDone:
    640          #endif
    641          
    642            determineNextState();
   \                     getPartnerLinkKey: (+1)
   \        0x0   0x....             B.N      determineNextState
    643            return;
    644          }
