    858          
    859          bool emberAfColorControlClusterMoveToColorCallback(uint16_t colorX,
    860                                                             uint16_t colorY,
    861                                                             uint16_t transitionTime,
    862                                                             uint8_t optionsMask,
    863                                                             uint8_t optionsOverride)
    864          {
    865            uint8_t endpoint = emberAfCurrentEndpoint();
    866          
    867            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
    868              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    869              return true;
    870            }
    871          
    872            if (transitionTime == 0) {
    873              transitionTime++;
    874            }
    875          
    876            // New command.  Need to stop any active transitions.
    877            stopAllColorTransitions();
    878          
    879            // Handle color mode transition, if necessary.
    880            handleModeSwitch(endpoint, COLOR_MODE_CIE_XY);
    881          
    882            // now, kick off the state machine.
    883            colorXTransitionState.initialValue = readColorX(endpoint);
    884            colorXTransitionState.currentValue = readColorX(endpoint);
    885            colorXTransitionState.finalValue = colorX;
    886            colorXTransitionState.stepsRemaining = transitionTime;
    887            colorXTransitionState.stepsTotal = transitionTime;
    888            colorXTransitionState.endpoint = endpoint;
    889            colorXTransitionState.lowLimit  = MIN_CIE_XY_VALUE;
    890            colorXTransitionState.highLimit = MAX_CIE_XY_VALUE;
    891          
    892            colorYTransitionState.initialValue = readColorY(endpoint);
    893            colorYTransitionState.currentValue = readColorY(endpoint);
    894            colorYTransitionState.finalValue = colorY;
    895            colorYTransitionState.stepsRemaining = transitionTime;
    896            colorYTransitionState.stepsTotal = transitionTime;
    897            colorYTransitionState.endpoint = endpoint;
    898            colorYTransitionState.lowLimit  = MIN_CIE_XY_VALUE;
    899            colorYTransitionState.highLimit = MAX_CIE_XY_VALUE;
    900          
    901            writeRemainingTime(endpoint, transitionTime);
    902          
    903            // kick off the state machine:
    904            emberEventControlSetDelayMS(COLOR_XY_CONTROL, UPDATE_TIME_MS);
    905          
    906            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    907            return true;
    908          }
    909          
    910          bool emberAfColorControlClusterMoveColorCallback(int16_t rateX,
    911                                                           int16_t rateY,
    912                                                           uint8_t optionsMask,
    913                                                           uint8_t optionsOverride)
    914          {
    915            uint8_t endpoint = emberAfCurrentEndpoint();
    916          
    917            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
    918              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    919              return true;
    920            }
    921          
    922            uint16_t transitionTimeX, transitionTimeY;
    923            uint16_t unsignedRate;
    924          
    925            // New command.  Need to stop any active transitions.
    926            stopAllColorTransitions();
    927          
    928            if (rateX == 0 && rateY == 0) {
    929              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    930              return true;
    931            }
    932          
    933            // Handle color mode transition, if necessary.
    934            handleModeSwitch(endpoint, COLOR_MODE_CIE_XY);
    935          
    936            // now, kick off the state machine.
    937            colorXTransitionState.initialValue = readColorX(endpoint);
    938            colorXTransitionState.currentValue = colorXTransitionState.initialValue;
    939            if (rateX > 0) {
    940              colorXTransitionState.finalValue = MAX_CIE_XY_VALUE;
    941              unsignedRate = (uint16_t) rateX;
    942            } else {
    943              colorXTransitionState.finalValue = MIN_CIE_XY_VALUE;
    944              unsignedRate = (uint16_t) (rateX * -1);
    945            }
    946            transitionTimeX =
    947              computeTransitionTimeFromStateAndRate(&colorXTransitionState,
    948                                                    unsignedRate);
    949            colorXTransitionState.stepsRemaining = transitionTimeX;
    950            colorXTransitionState.stepsTotal = transitionTimeX;
    951            colorXTransitionState.endpoint = endpoint;
    952            colorXTransitionState.lowLimit  = MIN_CIE_XY_VALUE;
    953            colorXTransitionState.highLimit = MAX_CIE_XY_VALUE;
    954          
    955            colorYTransitionState.initialValue = readColorY(endpoint);
    956            colorYTransitionState.currentValue = colorYTransitionState.initialValue;
    957            if (rateY > 0) {
    958              colorYTransitionState.finalValue = MAX_CIE_XY_VALUE;
    959              unsignedRate = (uint16_t) rateY;
    960            } else {
    961              colorYTransitionState.finalValue = MIN_CIE_XY_VALUE;
    962              unsignedRate = (uint16_t) (rateY * -1);
    963            }
    964            transitionTimeY =
    965              computeTransitionTimeFromStateAndRate(&colorYTransitionState,
    966                                                    unsignedRate);
    967            colorYTransitionState.stepsRemaining = transitionTimeY;
    968            colorYTransitionState.stepsTotal = transitionTimeY;
    969            colorYTransitionState.endpoint = endpoint;
    970            colorYTransitionState.lowLimit  = MIN_CIE_XY_VALUE;
    971            colorYTransitionState.highLimit = MAX_CIE_XY_VALUE;
    972          
    973            if (transitionTimeX < transitionTimeY) {
    974              writeRemainingTime(endpoint, transitionTimeX);
    975            } else {
    976              writeRemainingTime(endpoint, transitionTimeY);
    977            }
    978          
    979            // kick off the state machine:
    980            emberEventControlSetDelayMS(COLOR_XY_CONTROL, UPDATE_TIME_MS);
    981          
    982            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    983            return true;
    984          }
    985          
    986          bool emberAfColorControlClusterStepColorCallback(int16_t stepX,
    987                                                           int16_t stepY,
    988                                                           uint16_t transitionTime,
    989                                                           uint8_t optionsMask,
    990                                                           uint8_t optionsOverride)
    991          {
    992            uint8_t endpoint = emberAfCurrentEndpoint();
    993          
    994            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
    995              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    996              return true;
    997            }
    998          
    999            uint16_t colorX =
   1000              findNewColorValueFromStep(readColorX(endpoint), stepX);
   1001            uint16_t colorY =
   1002              findNewColorValueFromStep(readColorY(endpoint), stepY);
   1003          
   1004            if (transitionTime == 0) {
   1005              transitionTime++;
   1006            }
   1007          
   1008            // New command.  Need to stop any active transitions.
   1009            stopAllColorTransitions();
   1010          
   1011            // Handle color mode transition, if necessary.
   1012            handleModeSwitch(endpoint, COLOR_MODE_CIE_XY);
   1013          
   1014            // now, kick off the state machine.
   1015            colorXTransitionState.initialValue = readColorX(endpoint);
   1016            colorXTransitionState.currentValue = readColorX(endpoint);
   1017            colorXTransitionState.finalValue = colorX;
   1018            colorXTransitionState.stepsRemaining = transitionTime;
   1019            colorXTransitionState.stepsTotal = transitionTime;
   1020            colorXTransitionState.endpoint = endpoint;
   1021            colorXTransitionState.lowLimit  = MIN_CIE_XY_VALUE;
   1022            colorXTransitionState.highLimit = MAX_CIE_XY_VALUE;
   1023          
   1024            colorYTransitionState.initialValue = readColorY(endpoint);
   1025            colorYTransitionState.currentValue = readColorY(endpoint);
   1026            colorYTransitionState.finalValue = colorY;
   1027            colorYTransitionState.stepsRemaining = transitionTime;
   1028            colorYTransitionState.stepsTotal = transitionTime;
   1029            colorYTransitionState.endpoint = endpoint;
   1030            colorYTransitionState.lowLimit  = MIN_CIE_XY_VALUE;
   1031            colorYTransitionState.highLimit = MAX_CIE_XY_VALUE;
   1032          
   1033            writeRemainingTime(endpoint, transitionTime);
   1034          
   1035            // kick off the state machine:
   1036            emberEventControlSetDelayMS(COLOR_XY_CONTROL, UPDATE_TIME_MS);
   1037          
   1038            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   1039            return true;
   1040          }
   1041          
   1042          static uint16_t findNewColorValueFromStep(uint16_t oldValue, int16_t step)
   1043          {
   1044            uint16_t newValue;
   1045            int32_t  newValueSigned;
   1046          
   1047            newValueSigned = ((int32_t) oldValue) + ((int32_t) step);
   1048          
   1049            if (newValueSigned < 0) {
   1050              newValue = 0;
   1051            } else if (newValueSigned > MAX_CIE_XY_VALUE) {
   1052              newValue = MAX_CIE_XY_VALUE;
   1053            } else {
   1054              newValue = (uint16_t) newValueSigned;
   1055            }
   1056          
   1057            return newValue;
   1058          }
   1059          
   1060          static uint16_t readColorX(uint8_t endpoint)
   1061          {
   1062            uint16_t colorX;
   1063          
   1064            assert(EMBER_ZCL_STATUS_SUCCESS
   1065                   == emberAfReadServerAttribute(endpoint,
   1066                                                 ZCL_COLOR_CONTROL_CLUSTER_ID,
   1067                                                 ZCL_COLOR_CONTROL_CURRENT_X_ATTRIBUTE_ID,
   1068                                                 (uint8_t *)&colorX,
   1069                                                 sizeof(uint16_t)));
   1070          
   1071            return colorX;
   1072          }
   1073          
   1074          static uint16_t readColorY(uint8_t endpoint)
   1075          {
   1076            uint16_t colorY;
   1077          
   1078            assert(EMBER_ZCL_STATUS_SUCCESS
   1079                   == emberAfReadServerAttribute(endpoint,
   1080                                                 ZCL_COLOR_CONTROL_CLUSTER_ID,
   1081                                                 ZCL_COLOR_CONTROL_CURRENT_Y_ATTRIBUTE_ID,
   1082                                                 (uint8_t *)&colorY,
   1083                                                 sizeof(uint16_t)));
   1084          
   1085            return colorY;
   1086          }
   1087          
   1088          #endif  //#ifdef EMBER_AF_PLUGIN_COLOR_CONTROL_SERVER_XY
