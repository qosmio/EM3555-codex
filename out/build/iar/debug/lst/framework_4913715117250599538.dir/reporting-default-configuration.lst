    100          bool emberAfPluginReportingGetReportingConfigDefaults(EmberAfPluginReportingEntry *defaultConfiguration)
    101          {
   \                     emberAfPluginReportingGetReportingConfigDefaults: (+1)
   \        0x0   0xB580             PUSH     {R7,LR}
    102            // NULL error check - return false.
    103            if (NULL == defaultConfiguration) {
   \        0x2   0x2800             CMP      R0,#+0
   \        0x4   0xD101             BNE.N    ??emberAfPluginReportingGetReportingConfigDefau_0
    104              return false;
   \        0x6   0x2000             MOVS     R0,#+0
   \        0x8   0xBD02             POP      {R1,PC}
    105            }
    106            // When there is a table table available - search and read the values,
    107            // if default config value found, retrun true to the caller to use it
    108          #if ((defined EMBER_AF_GENERATED_REPORTING_CONFIG_DEFAULTS_TABLE_SIZE) \
    109            && (0 != EMBER_AF_GENERATED_REPORTING_CONFIG_DEFAULTS_TABLE_SIZE))
    110            for (int i = 0; i < EMBER_AF_GENERATED_REPORTING_CONFIG_DEFAULTS_TABLE_SIZE; i++) {
    111              // All of the serach parameters match then copy the default config.
    112              if ((defaultConfiguration->endpoint == generatedReportingConfigDefaults[i].endpoint)
    113                  && (defaultConfiguration->clusterId == generatedReportingConfigDefaults[i].clusterId)
    114                  && (defaultConfiguration->attributeId == generatedReportingConfigDefaults[i].attributeId)
    115                  && (defaultConfiguration->mask == generatedReportingConfigDefaults[i].mask)
    116                  && (defaultConfiguration->manufacturerCode == generatedReportingConfigDefaults[i].manufacturerCode)) {
    117                defaultConfiguration->direction = EMBER_ZCL_REPORTING_DIRECTION_REPORTED;
    118                defaultConfiguration->data = generatedReportingConfigDefaults[i].data;
    119                return true;
    120              }
    121            }
    122          #endif
    123            // At this point - There is no entry in the generated deafult table,
    124            // so the application need to be called to get default reporting values
    125            // The application should provide the default values because , in BDB an
    126            // implemented reportable attribute will reset its reporting configuration
    127            // when receives a special case of minInterval and maxInterval for which
    128            // function gets called.
    129            if (emberAfPluginReportingGetDefaultReportingConfigCallback(defaultConfiguration)) {
   \                     ??emberAfPluginReportingGetReportingConfigDefau_0: (+1)
   \        0xA   0x.... 0x....      BL       emberAfPluginReportingGetDefaultReportingConfigCallback
   \        0xE   0x1E40             SUBS     R0,R0,#+1
   \       0x10   0x4180             SBCS     R0,R0,R0
   \       0x12   0x43C0             MVNS     R0,R0
   \       0x14   0x0FC0             LSRS     R0,R0,#+31
   \       0x16   0xBD02             POP      {R1,PC}
    130              return true;
    131            }
    132            return false;
    133          }

