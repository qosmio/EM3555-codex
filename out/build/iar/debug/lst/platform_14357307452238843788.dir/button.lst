    113          uint8_t halButtonState(uint8_t button)
    114          {
    115            // Note: this returns the "soft" state rather than reading the port
    116            //  so it jives with the interrupts and their callbacks
    117            switch (button) {
   \                     halButtonState: (+1)
   \        0x0   0x280E             CMP      R0,#+14
   \        0x2   0xD002             BEQ.N    ??halButtonState_0
   \        0x4   0x2816             CMP      R0,#+22
   \        0x6   0xD003             BEQ.N    ??halButtonState_1
   \        0x8   0xE005             B.N      ??halButtonState_2
    118          #ifdef BUTTON0
    119              case BUTTON0:
    120                return button0State;
   \                     ??halButtonState_0: (+1)
   \        0xA   0x....             LDR.N    R0,??DataTable4_2
   \        0xC   0x7800             LDRB     R0,[R0, #+0]
   \        0xE   0x4770             BX       LR
    121          #endif
    122          #ifdef BUTTON1
    123              case BUTTON1:
    124                return button1State;
