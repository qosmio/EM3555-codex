     36          // Load the base address and attributes of all 8 MPU regions, then enable
     37          // the MPU. Even though interrupts should be disabled when this function is
     38          // called, the region loading is performed in an atomic block in case they
     39          // are not disabled. After the regions have been defined, the MPU is enabled.
     40          // To be safe, memory barrier instructions are included to make sure that
     41          // the new MPU setup is in effect before returning to the caller.
     42          //
     43          // Note that the PRIVDEFENA bit is not set in the MPU_CTRL register so the
     44          // default privileged memory map is not enabled. Disabling the default
     45          // memory map enables faults on core accesses (other than vector reads) to
     46          // the address ranges shown below.
     47          //
     48          //  Address range
     49          //  Flash (ICODE and DCODE)
     50          //    00000000 to 07FFFFFF    no access allowed (read, write or execute)
     51          //    08000000 to 0809FFFF    write not allowed
     52          //    080A0000 to 1FFFFFFF    no access allowed (read, write or execute)
     53          //  SRAM
     54          //    20000000 to 2000FFFF    execute not allowed
     55          //    20010000 to 3FFFFFFF    no access allowed (read, write or execute)
     56          //  Peripheral
     57          //    40020000 to 5FFFFFFF    no access allowed (read, write or execute)
     58          //  External Device / External RAM
     59          //    60000000 to DFFFFFFF    no access allowed (read, write or execute)
     60          

   \                                 In section .text, align 2, keep-with-next
     61          void halInternalEnableMPU(void)
     62          {
     63            halInternalLoadMPU(mpuConfig);
   \                     halInternalEnableMPU: (+1)
   \        0x0   0x....             LDR.N    R0,??DataTable3
   \        0x2                      REQUIRE halInternalLoadMPU
   \        0x2                      ; // Fall through to label halInternalLoadMPU
     64          }
     65          

   \                                 In section .text, align 2, keep-with-next
     66          void halInternalLoadMPU(mpu_t *mp)
     67          {
   \                     halInternalLoadMPU: (+1)
   \        0x0   0xB538             PUSH     {R3-R5,LR}
   \        0x2   0x4604             MOV      R4,R0
     68            uint8_t i;
     69          
     70            {
     71              DECLARE_INTERRUPT_STATE;
     72              DISABLE_INTERRUPTS();
   \        0x4   0x.... 0x....      BL       _disableBasePri
   \        0x8   0x4605             MOV      R5,R0
     73              MPU->CTRL = 0;       // enable default map while MPU is updated
   \        0xA   0x....             LDR.N    R0,??DataTable3_1
   \        0xC   0x2100             MOVS     R1,#+0
   \        0xE   0x6001             STR      R1,[R0, #+0]
     74              for (i = 0; i < NUM_MPU_REGIONS; i++) {
   \       0x10   0xE005             B.N      ??halInternalLoadMPU_0
     75                MPU->RBAR = mp->base;
   \                     ??halInternalLoadMPU_1: (+1)
   \       0x12   0x6822             LDR      R2,[R4, #+0]
   \       0x14   0x6082             STR      R2,[R0, #+8]
     76                MPU->RASR = mp->attr;
   \       0x16   0x6862             LDR      R2,[R4, #+4]
   \       0x18   0x60C2             STR      R2,[R0, #+12]
     77                mp++;
   \       0x1A   0x3408             ADDS     R4,R4,#+8
     78              }
   \       0x1C   0x1C49             ADDS     R1,R1,#+1
   \                     ??halInternalLoadMPU_0: (+1)
   \       0x1E   0x460A             MOV      R2,R1
   \       0x20   0xB2D2             UXTB     R2,R2
   \       0x22   0x2A08             CMP      R2,#+8
   \       0x24   0xDBF5             BLT.N    ??halInternalLoadMPU_1
     79              MPU->CTRL = MPU_CTRL_ENABLE_Msk;
   \       0x26   0x2101             MOVS     R1,#+1
   \       0x28   0x6001             STR      R1,[R0, #+0]
     80              _executeBarrierInstructions();
   \       0x2A   0x.... 0x....      BL       _executeBarrierInstructions
     81              RESTORE_INTERRUPTS();
   \       0x2E   0x4628             MOV      R0,R5
   \       0x30   0xE8BD 0x4032      POP      {R1,R4,R5,LR}
   \       0x34   0x.... 0x....      B.W      _writeBasePri
     82            }
     83          }
     84          

   \                                 In section .text, align 2, keep-with-next
     85          void halInternalDisableMPU(void)
     86          {
     87            MPU->CTRL = 0;
   \                     halInternalDisableMPU: (+1)
   \        0x0   0x2000             MOVS     R0,#+0
   \        0x2   0x....             LDR.N    R1,??DataTable3_1
   \        0x4   0x6008             STR      R0,[R1, #+0]
     88            _executeBarrierInstructions();
   \        0x6   0x.... 0x....      B.W      _executeBarrierInstructions
     89          }
