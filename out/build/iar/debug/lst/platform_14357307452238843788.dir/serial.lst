    344          //Documentary comments:
    345          // To conserve precious flash, there is very little validity checking
    346          //  on the given parameters.  Be sure not to use an invalid port number
    347          //  or a port that is unused.
    348          // Blocking routines will always wait for room (but not buffers - if buffers
    349          //  cannot be allocated, no part of the message will be sent)
    350          // Non-blocking routines will never wait for room, and may cause partial
    351          //  messages to be sent.  If a contiguous message needs to be sent, available
    352          //  space should be checked _before_ calling the appropriate write API.
    353          
    354          //------------------------------------------------------
    355          // Determine if blocking code needs to be enabled
    356          #if defined(EMBER_SERIAL0_BLOCKING)  \
    357            || defined(EMBER_SERIAL1_BLOCKING) \
    358            || defined(EMBER_SERIAL2_BLOCKING) \
    359            || defined(EMBER_SERIAL3_BLOCKING) \
    360            || defined(EMBER_SERIAL4_BLOCKING)
    361            #define EM_ENABLE_SERIAL_BLOCKING
    362          #endif
    363          #ifdef EMBER_SERIAL0_BLOCKING
    364            #define EM_SERIAL0_BLOCKSTATE true
    365          #else
    366            #define EM_SERIAL0_BLOCKSTATE false
    367          #endif
    368          #ifdef EMBER_SERIAL1_BLOCKING
