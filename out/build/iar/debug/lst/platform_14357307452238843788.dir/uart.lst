    461            // set baud rate
    462            // If rate is one of the BAUD_ settings from serial.h then use
    463            // its baudSetting[] value from above, otherwise interpret it
    464            // as a custom baudSetting[] encoded value.
    465            if (rate < sizeof(baudSettings) / sizeof(*baudSettings)) {
   \        0x8   0x4608             MOV      R0,R1
   \        0xA   0x2813             CMP      R0,#+19
   \        0xC   0xD202             BCS.N    ??halInternalInitPhysicalUart_0
    466              rate = baudSettings[rate];
   \        0xE   0x.... 0x....      LDR.W    R0,??DataTable17_2
   \       0x12   0x5C41             LDRB     R1,[R0, R1]
