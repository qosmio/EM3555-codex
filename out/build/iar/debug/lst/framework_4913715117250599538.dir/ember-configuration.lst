    377          #endif
    378          
    379          // Define this in order to receive unsupported ZDO request messages via
    380          // the incomingMessageHandler callback.  An unsupported ZDO request is one that
    381          // is not handled by the EmberZNet stack, other than to send a 'not supported'
    382          // ZDO response.  If this configuration option is enabled, the stack will no
    383          // longer send any ZDO response, and it is the application's responsibility
    384          // to do so.  To see if a response is required, the application must check
    385          // the APS options bitfield within the emberIncomingMessageHandler callback to see
    386          // if the EMBER_APS_OPTION_ZDO_RESPONSE_REQUIRED flag is set.
    387          #ifdef EMBER_APPLICATION_HANDLES_UNSUPPORTED_ZDO_REQUESTS
    388            | EMBER_APP_HANDLES_UNSUPPORTED_ZDO_REQUESTS
    389          #endif
    390          
