   \                                 In section .text, align 2, keep-with-next
     21          bool emberAfReadAttributesResponseCallback(EmberAfClusterId clusterId,
     22                                                     uint8_t *buffer,
     23                                                     uint16_t bufLen)
     24          {
   \                     emberAfReadAttributesResponseCallback: (+1)
   \        0x0   0xB580             PUSH     {R7,LR}
     25          #if defined(EMBER_AF_PRINT_ENABLE) && defined(EMBER_AF_PRINT_DEBUG)
     26            uint16_t bufIndex = 0;
     27            emberAfDebugPrint("%p_RESP: ", "READ_ATTR");
     28            emberAfDebugDebugExec(emberAfDecodeAndPrintClusterWithMfgCode(clusterId, emberAfGetMfgCodeFromCurrentCommand()));
     29            emberAfDebugPrintln("");
     30            emberAfDebugFlush();
     31          
     32            // Each record in the response has a two-byte attribute id and a one-byte
     33            // status.  If the status is SUCCESS, there will also be a one-byte type and
     34            // variable-length data.
     35            while (bufIndex + 3 <= bufLen) {
     36              EmberAfAttributeId attributeId;
     37              EmberAfStatus status;
     38              attributeId = (EmberAfAttributeId)emberAfGetInt16u(buffer,
     39                                                                 bufIndex,
     40                                                                 bufLen);
     41              bufIndex += 2;
     42              status = (EmberAfStatus)emberAfGetInt8u(buffer, bufIndex, bufLen);
     43              bufIndex++;
     44              emberAfDebugPrintln(" - attr:%2x, status:%x", attributeId, status);
     45              if (status == EMBER_ZCL_STATUS_SUCCESS) {
     46                uint8_t dataType;
     47                uint16_t dataSize;
     48                if (bufLen - bufIndex < 1) {
     49                  emberAfDebugPrintln("ERR: attr:%2x premature end of buffer after success status", attributeId);
     50                  break;
     51                }
     52                dataType = emberAfGetInt8u(buffer, bufIndex, bufLen);
     53                bufIndex++;
     54          
     55                dataSize = emberAfAttributeValueSize(dataType,
     56                                                     buffer + bufIndex,
     57                                                     bufLen - bufIndex);
     58          
     59                emberAfDebugPrint("   type:%x, val:", dataType);
     60                if (dataSize != 0) {
     61                  if (emberAfIsStringAttributeType(dataType)) {
     62                    emberAfDebugPrintString(buffer + bufIndex);
     63                  } else if (emberAfIsLongStringAttributeType(dataType)) {
     64                    emberAfDebugDebugExec(emberAfPrintLongString(EMBER_AF_PRINT_DEBUG, buffer + bufIndex));
     65                  } else {
     66                    emberAfDebugPrintBuffer(buffer + bufIndex, dataSize, false);
     67                  }
     68                  emberAfDebugPrintln("");
     69                  emberAfDebugFlush();
     70                  bufIndex += dataSize;
     71                } else {
     72                  // dataSize exceeds buffer length, terminate loop
     73                  emberAfDebugPrintln("ERR: attr:%2x size exceeds buffer size %d", attributeId, dataSize);
     74                  emberAfDebugFlush();
     75                  break; // while
     76                }
     77              }
     78            }
     79          #endif //EMBER_AF_PRINT_ENABLE && EMBER_AF_PRINT_DEBUG
     80            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   \        0x2   0x2000             MOVS     R0,#+0
   \        0x4   0x.... 0x....      BL       emberAfSendImmediateDefaultResponse
     81            return true;
   \        0x8   0x2001             MOVS     R0,#+1
   \        0xA   0xBD02             POP      {R1,PC}
     82          }
