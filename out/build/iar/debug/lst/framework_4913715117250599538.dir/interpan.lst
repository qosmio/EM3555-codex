    910          
    911          #if defined(EMBER_AF_PLUGIN_INTERPAN_ALLOW_FRAGMENTATION)
    912          
    913          // This function checks if packet is an inter-PAN fragment. It must do length
    914          // checks as well since ZCL default responses come in with APS payload byte 1
    915          // 0x00, which is also an inter-PAN IPMF control byte value.
    916          bool isInterpanFragment(uint8_t* payload, uint8_t payloadLen)
    917          {
    918            if (!payload || (payloadLen < EMBER_APS_INTERPAN_FRAGMENT_MIN_LEN)) {
    919              return false;
    920            }
    921          
    922            switch (payload[INTERPAN_FRAGMENTATION_APS_CONTROL_BYTE_INDEX]) {
    923              case INTERPAN_FRAGMENTATION_APS_CONTROL_BYTE_IPMF_VAL:
    924              {
    925                if ((payloadLen >= EMBER_APS_INTERPAN_FRAGMENTATION_OVERHEAD)
    926                    && (payload[INTERPAN_FRAGMENTATION_APS_LEN_IPMF_INDEX]
    927                        == (payloadLen - EMBER_APS_INTERPAN_FRAGMENTATION_OVERHEAD))) {
    928                  return true;
    929                }
    930              }
    931              break;
    932              case INTERPAN_FRAGMENTATION_APS_CONTROL_BYTE_IPMF_RESPONSE_VAL:
    933              {
    934                if (EMBER_APS_INTERPAN_FRAGMENTATION_RESPONSE_LEN == payloadLen) {
    935                  return true;
    936                }
    937              }
    938              break;
    939              default:
    940                break;
    941            }
    942          
    943            return false;
    944          }
    945          
    946          // Helper function to find a free buffer used to store a message sent via frags
    947          static txFragmentedInterpanPacket* getFreeTxPacketEntry(EmberEUI64 destEui)
    948          {
    949            uint8_t i;
    950          
    951            if (!destEui) {
    952              return NULL;
    953            }
    954          
    955            // Interpan fragmentation cannot handle sending mutliple fragmented
    956            // transmissions to the same partner due to the lack of APS ACKS with sequence
    957            // numbers. Ensure that we're not in the middle of sending to partner already
    958            for (i = 0; i < EMBER_AF_PLUGIN_INTERPAN_FRAGMENTATION_MAX_OUTGOING_PACKETS; i++) {
    959              txFragmentedInterpanPacket *txPacket = &(txPackets[i]);
    960              if (txPacket->messageType != UNUSED_TX_PACKET_ENTRY) {
    961                if (!MEMCOMPARE(txPacket->destEui, destEui, EUI64_SIZE)) {
    962                  return NULL;
    963                }
    964              }
    965            }
    966          
    967            for (i = 0; i < EMBER_AF_PLUGIN_INTERPAN_FRAGMENTATION_MAX_OUTGOING_PACKETS; i++) {
    968              txFragmentedInterpanPacket *txPacket = &(txPackets[i]);
    969              if (txPacket->messageType == UNUSED_TX_PACKET_ENTRY) {
    970                MEMCOPY(txPacket->destEui, destEui, EUI64_SIZE);
    971                return txPacket;
    972              }
    973            }
    974            return NULL;
    975          }
    976          
    977          // Helper function to free a buffer used to store a message sent via frags
    978          static void freeTxPacketEntry(txFragmentedInterpanPacket *txPacket, EInterpanFragmentationStatus reason)
    979          {
    980            if (!txPacket) {
    981              return;
    982            }
    983            txPacket->messageType = UNUSED_TX_PACKET_ENTRY;
    984          
    985            if (IPMF_SUCCESS != reason) {
    986              // User callback: something went wrong
    987              emberAfPluginInterpanFragmentTransmissionFailedCallback(reason,
    988                                                                      txPacket->fragmentNum);
    989            }
    990          }
    991          
    992          // Helper function to find an existing buffer used to store a msg sent via frags
    993          static txFragmentedInterpanPacket* txPacketLookUp(EmberEUI64 destEui)
    994          {
    995            uint8_t i;
    996            for (i = 0; i < EMBER_AF_PLUGIN_INTERPAN_FRAGMENTATION_MAX_OUTGOING_PACKETS; i++) {
    997              txFragmentedInterpanPacket *txPacket = &(txPackets[i]);
    998              if (!MEMCOMPARE(txPacket->destEui, destEui, EUI64_SIZE)) {
    999                return txPacket;
   1000              }
   1001            }
   1002            return NULL;
   1003          }
   1004          
   1005          // Helper function to find a free buffer used to store a message rcvd via frags
   1006          static rxFragmentedInterpanPacket* getFreeRxPacketEntry(EmberEUI64 sourceEui)
   1007          {
   1008            uint8_t i;
   1009            EmberEUI64 nullEui = { 0 };
   1010            for (i = 0; i < EMBER_AF_PLUGIN_INTERPAN_FRAGMENTATION_MAX_INCOMING_PACKETS; i++) {
   1011              rxFragmentedInterpanPacket *rxPacket = &(rxPackets[i]);
   1012              if (!MEMCOMPARE(rxPacket->sourceEui, nullEui, EUI64_SIZE)) {
   1013                MEMCOPY(rxPacket->sourceEui, sourceEui, EUI64_SIZE);
   1014                return rxPacket;
   1015              }
   1016            }
   1017            return NULL;
   1018          }
   1019          
   1020          // Helper function to free a buffer used to store a message received via frags
   1021          static void freeRxPacketEntry(rxFragmentedInterpanPacket *rxPacket, EInterpanFragmentationStatus reason)
   1022          {
   1023            if (!rxPacket) {
   1024              return;
   1025            }
   1026            MEMSET(rxPacket->sourceEui, 0, EUI64_SIZE);
   1027          
   1028            if (IPMF_SUCCESS != reason) {
   1029              // User callback: something went wrong
   1030              emberAfPluginInterpanFragmentTransmissionFailedCallback(reason,
   1031                                                                      rxPacket->lastFragmentNumReceived + 1);
   1032            }
   1033          }
   1034          
   1035          // Helper function to find an existing buffer used to store a msg rcvd via frags
   1036          static rxFragmentedInterpanPacket* rxPacketLookUp(EmberEUI64 sourceEui)
   1037          {
   1038            uint8_t i;
   1039            for (i = 0; i < EMBER_AF_PLUGIN_INTERPAN_FRAGMENTATION_MAX_INCOMING_PACKETS; i++) {
   1040              rxFragmentedInterpanPacket *rxPacket = &(rxPackets[i]);
   1041              if (!MEMCOMPARE(rxPacket->sourceEui, sourceEui, EUI64_SIZE)) {
   1042                return rxPacket;
   1043              }
   1044            }
   1045            return NULL;
   1046          }
   1047          
   1048          // This function sends a whole message. It takes care of the fragmenting.
   1049          EmberStatus interpanFragmentationSendUnicast(EmberAfInterpanHeader* header,
   1050                                                       uint8_t* message,
   1051                                                       uint16_t messageLen)
   1052          {
   1053            txFragmentedInterpanPacket *txPacket;
   1054            EmberStatus status;
   1055            uint8_t headerLen = INTERPAN_UNICAST_HEADER_SIZE;
   1056            uint8_t maxFragLen, numFragments;
   1057          
   1058            if (!header || !message || (0 == messageLen)) {
   1059              return EMBER_BAD_ARGUMENT;
   1060            }
   1061          
   1062            if (messageLen > EMBER_AF_PLUGIN_INTERPAN_FRAGMENTATION_BUFFER_SIZE) {
   1063              return EMBER_MESSAGE_TOO_LONG;
   1064            }
   1065          
   1066            // Claim a tx packet buffer. Only 1 tx packet per partner.
   1067            txPacket = getFreeTxPacketEntry(header->longAddress);
   1068            if (txPacket == NULL) {
   1069              return EMBER_MAX_MESSAGE_LIMIT_REACHED;
   1070            }
   1071          
   1072            // No interpan frag APS encryption allowed (payload assumed already encrypted)
   1073            header->options &= ~EMBER_AF_INTERPAN_OPTION_APS_ENCRYPT;
   1074          
   1075            // Build a big packet
   1076            status = makeInterPanMessage(header,
   1077                                         txPacket->buffer,
   1078                                         EMBER_AF_PLUGIN_INTERPAN_FRAGMENTATION_BUFFER_SIZE,
   1079                                         message,
   1080                                         &messageLen,
   1081                                         &(txPacket->bufLen));
   1082            if (EMBER_SUCCESS != status) {
   1083              return status;
   1084            }
   1085          
   1086            maxFragLen = EMBER_AF_MAXIMUM_INTERPAN_LENGTH
   1087                         - headerLen
   1088                         - EMBER_APS_INTERPAN_FRAGMENTATION_OVERHEAD;
   1089          
   1090            numFragments = messageLen / maxFragLen;
   1091            if (messageLen % maxFragLen) {
   1092              numFragments++;
   1093            }
   1094            if (numFragments > MAX_INT8U_VALUE) {
   1095              return EMBER_MESSAGE_TOO_LONG;
   1096            }
   1097          
   1098            // Fill in some info before we start the transmit process
   1099            txPacket->messageType    = header->messageType;
   1100            txPacket->fragmentMaxLen = maxFragLen;
   1101            txPacket->numFragments   = numFragments;
   1102            txPacket->fragmentNum    = 0;
   1103          
   1104            // Forward it to the frag-sending function
   1105            status = interpanFragmentationSendIpmf(txPacket);
   1106          
   1107            return status;
   1108          }
   1109          
   1110          // This function sends an individual fragment. It expects the caller to handle
   1111          // the setting up and handling of txPacket metadata.
   1112          EmberStatus interpanFragmentationSendIpmf(txFragmentedInterpanPacket *txPacket)
   1113          {
   1114            if (!txPacket || !txPacket->bufLen) {
   1115              return EMBER_BAD_ARGUMENT;
   1116            }
   1117          
   1118            EmberStatus status;
   1119            uint8_t  message[EMBER_AF_MAXIMUM_INTERPAN_LENGTH];
   1120            uint8_t* finger = message;
   1121            uint8_t  headerLen = EMBER_AF_INTER_PAN_UNICAST == txPacket->messageType
   1122                                 ? INTERPAN_UNICAST_HEADER_SIZE
   1123                                 : INTERPAN_MULTICAST_HEADER_SIZE;
   1124            uint16_t messageSentLen, messageLeftLen;
   1125            uint8_t  messageToBeSentLen, packetLen;
   1126          
   1127            // Copy header info from pre-built packet
   1128            MEMMOVE(finger, txPacket->buffer, headerLen);
   1129            finger += headerLen;
   1130          
   1131            // Write the IPMF payload with a fragment of the whole message
   1132            messageSentLen = txPacket->fragmentMaxLen * txPacket->fragmentNum;
   1133            messageLeftLen = txPacket->bufLen - headerLen - messageSentLen;
   1134            messageToBeSentLen =  messageLeftLen >= txPacket->fragmentMaxLen
   1135                                 ? txPacket->fragmentMaxLen : messageLeftLen;
   1136          
   1137            *finger++ = INTERPAN_FRAGMENTATION_APS_CONTROL_BYTE_IPMF_VAL;
   1138            *finger++ = txPacket->fragmentNum;
   1139            *finger++ = txPacket->numFragments;
   1140            *finger++ = messageToBeSentLen;
   1141            MEMMOVE(finger,
   1142                    (txPacket->buffer + headerLen + messageSentLen),
   1143                    messageToBeSentLen);
   1144            finger += messageToBeSentLen;
   1145          
   1146            packetLen = finger - message;
   1147          
   1148            emberAfAppPrintln("Sending interpan fragment %d of %d",
   1149                              txPacket->fragmentNum, txPacket->numFragments - 1);
   1150          
   1151            status = emAfPluginInterpanSendRawMessage(packetLen, message);
   1152          
   1153            // Start a timer waiting for the IPMF response
   1154            emberEventControlSetDelayMS(*(txPacket->eventControl), gMessageTimeout);
   1155          
   1156            return status;
   1157          }
   1158          
   1159          // This function reads an IPMF message and stores necessary data. The caller
   1160          // will need to send an IPMF response based on the return from this function.
   1161          EmberStatus interpanFragmentationProcessIpmf(EmberAfInterpanHeader header,
   1162                                                       uint8_t *message, uint8_t messageLen)
   1163          {
   1164            uint8_t* finger;
   1165            uint8_t fragNum, numFrags, fragLen, headerLen = INTERPAN_UNICAST_HEADER_SIZE;
   1166            rxFragmentedInterpanPacket *rxPacket;
   1167          
   1168            if (!message || !messageLen) {
   1169              return EMBER_BAD_ARGUMENT;
   1170            }
   1171          
   1172            finger = message + headerLen;
   1173            finger++;   // Skip the control byte
   1174            fragNum  = *finger++;
   1175            numFrags = *finger++;
   1176            fragLen  = *finger++;
   1177          
   1178            emberAfAppPrintln("Receiving inter-PAN fragment %d of %d", fragNum, numFrags - 1);
   1179          
   1180            // See if we already have an entry for this fragment transmission
   1181            rxPacket = rxPacketLookUp(header.longAddress);
   1182            if (!rxPacket && (0 != fragNum)) {
   1183              emberAfAppPrintln("ERR: expected first IPMF index 0, got %d", fragNum);
   1184              return EMBER_INDEX_OUT_OF_RANGE;
   1185            } else if (rxPacket && (0 == fragNum)) {
   1186              emberAfAppPrint("ERR: ");
   1187              emberAfPrintLittleEndianEui64(header.longAddress);
   1188              emberAfAppPrintln(" sending multiple IPMF index 0 fragments");
   1189              freeRxPacketEntry(rxPacket, IPMF_RX_BAD_RESPONSE);
   1190              return EMBER_INDEX_OUT_OF_RANGE;
   1191            }
   1192          
   1193            // If no entry, see if we have room to take a buffer
   1194            if (NULL == rxPacket) {
   1195              rxPacket = getFreeRxPacketEntry(header.longAddress);
   1196              if (rxPacket) {
   1197                // If we've allocated a new buffer, copy the header over and set data
   1198                MEMMOVE(rxPacket->buffer, message, headerLen);
   1199                rxPacket->bufLen                  = headerLen;
   1200                rxPacket->numFragments            = numFrags;
   1201                rxPacket->lastFragmentNumReceived = fragNum;
   1202              }
   1203            }
   1204          
   1205            if (NULL == rxPacket) {
   1206              emberAfAppPrint("ERR: RX interpan fragment from ");
   1207              emberAfPrintLittleEndianEui64(header.longAddress);
   1208              emberAfAppPrintln(" but no available buffers");
   1209              return EMBER_MAX_MESSAGE_LIMIT_REACHED;
   1210            }
   1211          
   1212            // We received an IPMF, so turn off the timer for now
   1213            emberEventControlSetInactive(*(rxPacket->eventControl));
   1214          
   1215            if (fragLen == 0) {
   1216              emberAfAppPrintln("ERR: RX interpan fragment from ");
   1217              emberAfPrintLittleEndianEui64(header.longAddress);
   1218              emberAfAppPrintln(" with IPMF length 0");
   1219              freeRxPacketEntry(rxPacket, IPMF_RX_BAD_RESPONSE);
   1220              return EMBER_INDEX_OUT_OF_RANGE;
   1221            }
   1222          
   1223            if (0 != fragNum) {
   1224              if (rxPacket->lastFragmentNumReceived != (fragNum - 1)) {
   1225                emberAfAppPrintln("ERR: RX IPMF fragment %d after %d, expecting %d",
   1226                                  fragNum, rxPacket->lastFragmentNumReceived,
   1227                                  rxPacket->lastFragmentNumReceived + 1);
   1228                freeRxPacketEntry(rxPacket, IPMF_RX_BAD_RESPONSE);
   1229                return EMBER_INDEX_OUT_OF_RANGE;
   1230              }
   1231              if (rxPacket->numFragments != numFrags) {
   1232                emberAfAppPrintln("ERR: expecting total number of IPMFs %d, but received"
   1233                                  " %d in IPMF fragment %d",
   1234                                  rxPacket->numFragments, numFrags, fragNum);
   1235                freeRxPacketEntry(rxPacket, IPMF_RX_BAD_RESPONSE);
   1236                return EMBER_INDEX_OUT_OF_RANGE;
   1237              }
   1238              // Note that we allow sequential fragments to specify different lengths.
   1239              // In theory, frags 0 to n-1 should be of the same maximum length, and the
   1240              // last fragment n should be of shorter length. For now, we'll allow that
   1241              // any of those middle packets may come in with a different length.
   1242            }
   1243          
   1244            // Strip the payload and add it to the whole message buffer
   1245            MEMMOVE(rxPacket->buffer + rxPacket->bufLen, finger, fragLen);
   1246            rxPacket->bufLen += fragLen;
   1247            rxPacket->lastFragmentNumReceived = fragNum;
   1248          
   1249            if (rxPacket->lastFragmentNumReceived == (rxPacket->numFragments - 1)) {
   1250              // Full message received
   1251              emberAfAppPrint("T%4x:Inter-PAN RX (%d B, %d fragments) [",
   1252                              emberAfGetCurrentTime(),
   1253                              rxPacket->bufLen - headerLen,
   1254                              rxPacket->numFragments);
   1255              emberAfAppPrintBuffer(rxPacket->buffer + headerLen,
   1256                                    rxPacket->bufLen - headerLen,
   1257                                    true);
   1258              emberAfAppPrintln("], 0x%x", EMBER_SUCCESS);
   1259              emberAfAppFlush();
   1260          
   1261              // User callback: all frags received, message reconstructed
   1262              emberAfPluginInterpanMessageReceivedOverFragmentsCallback(
   1263                &header,
   1264                rxPacket->bufLen - headerLen,
   1265                rxPacket->buffer + headerLen);
   1266          
   1267              freeRxPacketEntry(rxPacket, IPMF_SUCCESS);
   1268            }
   1269          
   1270            return EMBER_SUCCESS;
   1271          }
   1272          
   1273          // This function sends an IPMF response to the sender of the IPMF
   1274          void interpanFragmentationSendIpmfResponse(EmberAfInterpanHeader header,
   1275                                                     uint8_t fragNum, uint8_t response)
   1276          {
   1277            EmberStatus status;
   1278            uint8_t message[EMBER_AF_MAXIMUM_INTERPAN_LENGTH];
   1279            uint8_t* finger;
   1280            uint16_t messageLength, noPayloadLen = 0;
   1281            uint8_t noPayload = 0;
   1282          
   1283            if ((fragNum > MAX_INT8U_VALUE)
   1284                || ((INTERPAN_IPMF_RESPONSE_SUCCESS != response)
   1285                    && (INTERPAN_IPMF_RESPONSE_FAILURE != response))) {
   1286              return;
   1287            }
   1288          
   1289            // Construct a new IPMF message, but no payload
   1290            status = makeInterPanMessage(&header,
   1291                                         message,
   1292                                         EMBER_AF_MAXIMUM_INTERPAN_LENGTH,
   1293                                         &noPayload,
   1294                                         &noPayloadLen,
   1295                                         &messageLength);
   1296            if (EMBER_SUCCESS != status) {
   1297              return;
   1298            }
   1299          
   1300            // Move past the header and write the IPMF response payload
   1301            finger = message + messageLength;
   1302            *finger++ = INTERPAN_FRAGMENTATION_APS_CONTROL_BYTE_IPMF_RESPONSE_VAL;
   1303            *finger++ = fragNum;
   1304            *finger++ = response;
   1305          
   1306            messageLength += EMBER_APS_INTERPAN_FRAGMENTATION_RESPONSE_LEN;
   1307          
   1308            // Send the response
   1309            emAfPluginInterpanSendRawMessage(messageLength, message);
   1310          
   1311            // Start a timer waiting for the next IPMF
   1312            rxFragmentedInterpanPacket* rxPacket = rxPacketLookUp(header.longAddress);
   1313            if (rxPacket) {
   1314              emberEventControlSetDelayMS(*(rxPacket->eventControl), gMessageTimeout);
   1315            }
   1316          }
   1317          
   1318          // This function processes the IPMF response and either sends the next fragment
   1319          // or finishes the transmission
   1320          void interpanFragmentationProcessIpmfResponse(EmberAfInterpanHeader header,
   1321                                                        uint8_t* payload,
   1322                                                        uint8_t payloadLen)
   1323          {
   1324            if (!payload
   1325                || (EMBER_APS_INTERPAN_FRAGMENTATION_RESPONSE_LEN != payloadLen)) {
   1326              return;
   1327            }
   1328          
   1329            uint8_t fragmentNumAcked = payload[INTERPAN_FRAGMENTATION_APS_INDEX_IPMF_INDEX];
   1330            uint8_t response = payload[INTERPAN_FRAGMENTATION_APS_IPMF_RESPONSE_INDEX];
   1331          
   1332            txFragmentedInterpanPacket* txPacket = txPacketLookUp(header.longAddress);
   1333            if (!txPacket) {
   1334              return;
   1335            }
   1336          
   1337            // We received an IPMF, so turn off the timer for now
   1338            emberEventControlSetInactive(*(txPacket->eventControl));
   1339          
   1340            if (fragmentNumAcked != txPacket->fragmentNum) {
   1341              // Partner is not acking what we've sent it - error
   1342              freeTxPacketEntry(txPacket, IPMF_TX_BAD_RESPONSE);
   1343              return;
   1344            }
   1345          
   1346            if (INTERPAN_IPMF_RESPONSE_SUCCESS != response) {
   1347              // Partner acking bad response - error
   1348              freeTxPacketEntry(txPacket, IPMF_TX_BAD_RESPONSE);
   1349              return;
   1350            }
   1351          
   1352            if (txPacket->fragmentNum == (txPacket->numFragments - 1)) {
   1353              // Done!
   1354              freeTxPacketEntry(txPacket, IPMF_SUCCESS);
   1355              return;
   1356            }
   1357          
   1358            txPacket->fragmentNum++;
   1359            interpanFragmentationSendIpmf(txPacket);
   1360          }
