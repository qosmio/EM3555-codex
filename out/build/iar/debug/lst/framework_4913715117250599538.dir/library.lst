     40          void printAllLibraryStatus(void)
     41          {
   \                     printAllLibraryStatus: (+1)
   \        0x0   0xB570             PUSH     {R4-R6,LR}
     42            uint8_t i = EMBER_FIRST_LIBRARY_ID;
   \        0x2   0x2400             MOVS     R4,#+0
   \        0x4   0x....             LDR.N    R5,??DataTable0_1
   \        0x6   0xE013             B.N      ??printAllLibraryStatus_0
     43            while (i < EMBER_NUMBER_OF_LIBRARIES) {
     44              EmberLibraryStatus status = emberGetLibraryStatus(i);
     45              if (status == EMBER_LIBRARY_ERROR) {
     46                emberSerialPrintfLine(serialPort, "Error retrieving info for library ID %d",
     47                                      i);
     48              } else {
     49                emberSerialPrintfLine(serialPort,
     50                                      "%p library%p present",
     51                                      libraryNames[i],
     52                                      ((status & EMBER_LIBRARY_PRESENT_MASK)
     53                                       ? ""
     54                                       : " NOT"));
     55                if ((status & EMBER_LIBRARY_PRESENT_MASK) != 0U) {
     56                  if (i == EMBER_ZIGBEE_PRO_LIBRARY_ID
     57                      || i == EMBER_SECURITY_CORE_LIBRARY_ID) {
     58                    emberSerialPrintfLine(serialPort,
     59                                          ((status
     60                                            & EMBER_ZIGBEE_PRO_LIBRARY_HAVE_ROUTER_CAPABILITY)
     61                                           ? "  Have Router Support"
     62                                           : "  End Device Only"));
     63                  }
     64                  if (i == EMBER_PACKET_VALIDATE_LIBRARY_ID
     65                      && (status
     66                          & EMBER_LIBRARY_PRESENT_MASK)) {
     67                    emberSerialPrintfLine(serialPort,
     68                                          ((status & EMBER_PACKET_VALIDATE_LIBRARY_ENABLED)
     69                                           ? "  Enabled"
     70                                           : "  Disabled"));
