   \                     ??emDecimalStringWrite_3: (+1)
   \       0x24   0x.... 0x....      LDR.W    R5,??DataTable5_3
   \       0x28   0xF855 0x5024      LDR      R5,[R5, R4, LSL #+2]
   \       0x2C   0x42A8             CMP      R0,R5
   \       0x2E   0xD2F7             BCS.N    ??emDecimalStringWrite_2
    159                if (digit != 0 || printedLeadingNonZeroValue) {
   \       0x30   0x4635             MOV      R5,R6
   \       0x32   0xB2ED             UXTB     R5,R5
   \       0x34   0x2D00             CMP      R5,#+0
