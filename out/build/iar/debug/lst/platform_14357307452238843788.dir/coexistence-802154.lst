    922          static EmberStatus halInternalPtaSetRequest(COEX_ReqState_t * coexReqState,
    923                                                      COEX_Req_t coexReq,
    924                                                      COEX_ReqCb_t coexCb)
    925          {
    926            // if force holdoff is enabled, don't set request
    927            return (((halPtaOptions & PTA_OPT_FORCE_HOLDOFF) == 0U)
    928                    && COEX_SetRequest(coexReqState, coexReq, coexCb))
    929                   ? EMBER_SUCCESS : EMBER_ERR_FATAL;
    930          }
    931          
    932          halPtaReq_t halPtaFrameDetectReq(void)
    933          {
    934            HalPtaOptions options = halPtaGetOptions();
    935            halPtaReq_t syncDet = PTA_REQ_OFF;
    936            if (halPtaIsEnabled() && (options & PTA_OPT_REQ_FILTER_PASS) == 0) {
    937              syncDet |= PTA_REQ_ON;
    938              if ((options & PTA_OPT_RX_HIPRI) != 0U) {
    939                syncDet |= PTA_REQ_HIPRI;
    940              }
    941            }
    942            return syncDet;
    943          }
    944          
    945          halPtaReq_t halPtaFilterPassReq(void)
    946          {
    947            HalPtaOptions options = halPtaGetOptions();
    948            halPtaReq_t filterPass = PTA_REQ_OFF;
    949            if (halPtaIsEnabled()) {
    950              filterPass |= PTA_REQ_ON;
    951              if (options & (PTA_OPT_RX_HIPRI | PTA_OPT_HIPRI_FILTER_PASS)) {
    952                filterPass |= PTA_REQ_HIPRI;
    953              }
    954            }
    955            return filterPass;
    956          }
    957          
    958          EmberStatus halPtaSetTxRequest(COEX_Req_t coexReq, COEX_ReqCb_t coexCb)
    959          {
    960          #if SL_RAIL_UTIL_COEX_PRIORITY_ESCALATION_ENABLE || defined(DEBUG_PTA)
    961            if (((coexReq & COEX_REQ_ON) != 0U) && priorityEscalated) {
    962              coexReq |= COEX_REQ_HIPRI;
    963            }
    964          #endif // SL_RAIL_UTIL_COEX_PRIORITY_ESCALATION_ENABLE || defined(DEBUG_PTA)
    965            return halInternalPtaSetRequest(&txReq, coexReq, coexCb);
    966          }
    967          
    968          EmberStatus halPtaSetRxRequest(COEX_Req_t coexReq, COEX_ReqCb_t coexCb)
    969          {
    970            return halInternalPtaSetRequest(&rxReq, coexReq, coexCb);
    971          }
