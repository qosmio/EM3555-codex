     54          //------------------------------------------------------
     55          // Serial initialization
     56          
     57          EmberStatus emberSerialInit(uint8_t port,
     58                                      SerialBaudRate rate,
     59                                      SerialParity parity,
     60                                      uint8_t stopBits)
     61          {
     62            EmberStatus status = EMBER_ERR_FATAL;
     63            COM_Init_t initdata;
     64            switch (port) {
     65          #ifdef COM_VCP_ENABLE
     66              case COM_VCP:
     67              case comPortVcp:
     68                status = COM_Init((COM_Port_t) port, NULL);
     69                break;
     70          #endif
     71          #ifdef COM_USART0_ENABLE
     72              case COM_USART0:
     73              case comPortUsart0:
     74                initdata = (COM_Init_t) COM_USART0_DEFAULT;
     75                break;
     76          #endif
     77          #ifdef COM_USART1_ENABLE
     78              case COM_USART1:
     79              case comPortUsart1:
     80                initdata = (COM_Init_t) COM_USART1_DEFAULT;
     81                break;
     82          #endif
     83          #ifdef COM_USART2_ENABLE
     84              case COM_USART2:
     85              case comPortUsart2:
     86                initdata = (COM_Init_t) COM_USART2_DEFAULT;
     87                break;
     88          #endif
     89          #ifdef COM_USART3_ENABLE
     90              case comPortUsart3:
     91                initdata = (COM_Init_t) COM_USART3_DEFAULT;
     92                break;
     93          #endif
     94          #ifdef COM_LEUART0_ENABLE
     95              case COM_LEUART0:
     96              case comPortLeuart0:
     97                initdata = (COM_Init_t) COM_LEUART0_DEFAULT;
     98                break;
     99          #endif
    100          #ifdef COM_LEUART1_ENABLE
    101              case COM_LEUART1:
    102              case comPortLeuart1:
    103                initdata = (COM_Init_t) COM_LEUART1_DEFAULT;
    104                break;
    105          #endif
    106              default:
    107                return status;
    108            }
    109          #if defined(COM_USART0_ENABLE) || defined (COM_USART1_ENABLE) || defined (COM_USART2_ENABLE) || defined (COM_USART3_ENABLE)
    110            if ((port == COM_USART0) || (port == comPortUsart0)
    111                || (port == COM_USART1) || (port == comPortUsart1)
    112                || (port == COM_USART2) || (port == comPortUsart2)
    113                || (port == comPortUsart3)) {
    114              initdata.uartdrvinit.uartinit.baudRate = rate;
    115              initdata.uartdrvinit.uartinit.parity = (USART_Parity_TypeDef)parity;
    116              if (stopBits == 1) {
    117                initdata.uartdrvinit.uartinit.stopBits = usartStopbits1;
    118              } else if (stopBits == 2) {
    119                initdata.uartdrvinit.uartinit.stopBits = usartStopbits2;
    120              }
    121              status = COM_Init((COM_Port_t) port, &initdata);
    122            }
    123          #endif
    124          #if defined (COM_LEUART0_ENABLE) || defined (COM_LEUART1_ENABLE)
    125            if ((port == COM_LEUART0) || (port == comPortLeuart0)
    126                || (port == COM_LEUART1) || (port == comPortLeuart0)
    127                ) {
    128              initdata.uartdrvinit.leuartinit.baudRate = rate;
    129              initdata.uartdrvinit.leuartinit.parity = (LEUART_Parity_TypeDef)parity;
    130              if (stopBits == 1) {
    131                initdata.uartdrvinit.leuartinit.stopBits = leuartStopbits1;
    132              } else if (stopBits == 2) {
    133                initdata.uartdrvinit.leuartinit.stopBits = leuartStopbits2;
    134              }
    135              status = COM_Init((COM_Port_t) port, &initdata);
    136            }
    137          #endif
    138            return status;
    139          }
