    570          bool COEX_SetOptions(COEX_Options_t options)
    571          {
    572            COEX_Options_t changedOptions = (COEX_Options_t)(coexCfg.options ^ options);
    573          
    574            coexCfg.options = options;
    575            if ((changedOptions & COEX_OPTION_RHO_ENABLED) != 0U) {
    576              if (enableRadioHoldOffCb == NULL) {
    577                return false;
    578              }
    579              enableRadioHoldOffCb();
    580            }
    581            if ((changedOptions & COEX_OPTION_COEX_ENABLED) != 0U) {
    582              if (enableCoexistenceCb == NULL) {
    583                return false;
    584              }
    585              enableCoexistenceCb();
    586            }
    587            return true;
    588          }
