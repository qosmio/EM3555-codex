   \       0x42   0x5456             STRB     R6,[R2, R1]
   \       0x44   0x1C5B             ADDS     R3,R3,#+1
    161                  printedLeadingNonZeroValue = true;
   \       0x46   0x2101             MOVS     R1,#+1
    162                }
   \                     ??emDecimalStringWrite_5: (+1)
   \       0x48   0x1C64             ADDS     R4,R4,#+1
   \                     ??emDecimalStringWrite_1: (+1)
