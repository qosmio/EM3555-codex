    370          // Define this in order to receive supported ZDO request messages via
    371          // the incomingMessageHandler callback.  A supported ZDO request is one that
    372          // is handled by the EmberZNet stack.  The stack will continue to handle the
    373          // request and send the appropriate ZDO response even if this configuration
    374          // option is enabled.
    375          #ifdef EMBER_APPLICATION_RECEIVES_SUPPORTED_ZDO_REQUESTS
