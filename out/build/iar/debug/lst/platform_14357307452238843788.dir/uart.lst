    207          const uint8_t baudSettings[] = {
   \                     baudSettings:
   \        0x0   0x30 0x60          DC8 48, 96, 144, 192, 193, 194, 195, 148, 196, 149, 197, 92, 150, 198
   \              0x90 0xC0    
   \              0xC1 0xC2    
   \              0xC3 0x94    
   \              0xC4 0x95    
   \              0xC5 0x5C    
   \              0x96 0xC6
   \        0xE   0xAC 0x97          DC8 172, 151, 152, 153, 154
   \              0x98 0x99    
   \              0x9A
   \       0x13                      DS8 1
    208            // This table is indexed by the supported BAUD_xxx enum from serial.h.
    209            // The actual baud rate is encoded in a byte and converted algorithmically
    210            // into the needed SCx register values based on system clock frequency
    211            // Here each byte is divided into two 4-bit nibbles 0x<mul><exp> where:
    212            // baud = <mul> * 100 * 2^<exp> when <exp> is <=10
    213            //  and = <mul> * 100 * 10^(<exp>-10) when <exp> is >10
    214            // This allows all supported baud rates (and many others) to be represented.
    215            0x30,   //  0 - BAUD_300    =  3 * 100 * 2^0
    216            0x60,   //  1 - BAUD_600    =  6 * 100 * 2^0
    217            0x90,   //  2 - BAUD_900    =  9 * 100 * 2^0
    218            0xC0,   //  3 - BAUD_1200   = 12 * 100 * 2^0
    219            0xC1,   //  4 - BAUD_2400   = 12 * 100 * 2^1
    220            0xC2,   //  5 - BAUD_4800   = 12 * 100 * 2^2
    221            0xC3,   //  6 - BAUD_9600   = 12 * 100 * 2^3
    222            0x94,   //  7 - BAUD_14400  =  9 * 100 * 2^4
    223            0xC4,   //  8 - BAUD_19200  = 12 * 100 * 2^4
    224            0x95,   //  9 - BAUD_28800  =  9 * 100 * 2^5
    225            0xC5,   // 10 - BAUD_38400  = 12 * 100 * 2^5
    226            0x5C,   // 11 - BAUD_50000  =  5 * 100 * 10^2
    227            0x96,   // 12 - BAUD_57600  =  9 * 100 * 2^6
    228            0xC6,   // 13 - BAUD_76800  = 12 * 100 * 2^6
    229            0xAC,   // 14 - BAUD_100000 = 10 * 100 * 10^2
    230            0x97,   // 15 - BAUD_115200 =  9 * 100 * 2^7
    231            0x98,   // 16 - BAUD_230400 =  9 * 100 * 2^8
    232            0x99,   // 17 - BAUD_460800 =  9 * 100 * 2^9
    233             #ifdef EMBER_SERIAL_BAUD_CUSTOM
    234            EMBER_SERIAL_BAUD_CUSTOM,   //Hook for custom baud rate, see BOARD_HEADER
    235             #else
    236            0x9A,   // 18 - BAUD_921600 =  9 * 100 * 2^10
    237             #endif
    238          };
    239          
    240          #endif // defined(EM_PHYSICAL_UART)
