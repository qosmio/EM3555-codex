     38            if (led == RHO_GPIO && halGetRadioHoldOff()) { // Avoid Radio HoldOff conflict
     39              return;
     40            }
     41          #endif
     42          
     43            GPIO->P[port].GPIO_SET_LED = BIT(pin);
