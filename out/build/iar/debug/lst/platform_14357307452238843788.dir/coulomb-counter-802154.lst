     21          #ifndef SIMULATION_DEVICE
     22          #include PLATFORM_HEADER
     23          #include "stack/include/ember-types.h"
     24          #endif // SIMULATION_DEVICE
     25          
     26          #include <stdint.h>
     27          #include <stddef.h>
     28          #include "coexistence-hal.h"
     29          #include "coexistence/protocol/ieee802154/coexistence-802154.h"
     30          #include "coexistence/protocol/ieee802154/coulomb-counter-802154.h"
     31          
     32          #ifdef EMBER_AF_PLUGIN_COULOMB_COUNTER
     33          
     34          #include "coulomb-counter.h"
     35          
     36          /**
     37           * Set state for Coulomb Counter, Idle/Awake/Tx/Rx.
     38           *
     39           * @param[in] ptaStackEvent PTA stack event.
     40           *
     41           * This function maps PTA events to
     42           * corresponding Idle/Awake/Tx/Rx Coulomb Counter events .
     43           * Runs in ISR context
     44           *
     45           */
     46          void halCoulombCounterEvent(halPtaStackEvent_t ptaStackEvent)
     47          {
     48            static uint16_t ccState = 0U;
     49            static bool normalTxActive = false;
     50          
     51            switch (ptaStackEvent) {
     52              // RX listening start event(s):
     53              case PTA_STACK_EVENT_RX_LISTEN:
     54                ccState |= EMBER_AF_PLUGIN_COULOMB_COUNTER_RADIO_MODE_RX;
     55                break;
     56          
     57              // RX end event(s):
     58              case PTA_STACK_EVENT_RX_IDLED:
     59                ccState &= ~EMBER_AF_PLUGIN_COULOMB_COUNTER_RADIO_MODE_RX;
     60                break;
     61          
     62              // TX start event(s):
     63              case PTA_STACK_EVENT_TX_PENDED_PHY:
     64                normalTxActive = true;
     65              // Fall through - To enter TX state...
     66          
     67              // ACK TX start event(s):
     68              case PTA_STACK_EVENT_RX_ACKING:
     69                // RX is implicitly turned on when TX is on
     70                // since that's the state post-TX returns to;
     71                // it gets turned off only when RX_IDLED.
     72                ccState |= (EMBER_AF_PLUGIN_COULOMB_COUNTER_RADIO_MODE_TX
     73                            | EMBER_AF_PLUGIN_COULOMB_COUNTER_RADIO_MODE_RX);
     74                break;
     75          
     76              // TX end event(s):
     77              case PTA_STACK_EVENT_TX_BLOCKED:
     78              case PTA_STACK_EVENT_TX_ABORTED:
     79              case PTA_STACK_EVENT_TX_ENDED:
     80              case PTA_STACK_EVENT_TX_ACK_WAITING:
     81              case PTA_STACK_EVENT_TX_IDLED:
     82                normalTxActive = false;
     83              // Fall through - To exit TX state (back to RX)...
     84          
     85              // ACK TX start event(s):
     86              case PTA_STACK_EVENT_RX_ACK_BLOCKED:
     87              case PTA_STACK_EVENT_RX_ACK_ABORTED:
     88              case PTA_STACK_EVENT_RX_ACK_SENT:
     89                if (!normalTxActive) {
     90                  ccState &= ~EMBER_AF_PLUGIN_COULOMB_COUNTER_RADIO_MODE_TX;
     91                }
     92                break;
     93          
     94              // Events that don't matter:
     95              default:
     96                return;
     97                break;
     98            }
     99            coexCoulombCounterEventCallback(ccState);
    100          }
    101          
    102          #endif //EMBER_AF_PLUGIN_COULOMB_COUNTER
    103          
