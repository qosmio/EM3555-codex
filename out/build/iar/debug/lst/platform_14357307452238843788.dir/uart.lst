    533          // initialize USB Virtual COM Port
    534          #if EM_SERIAL3_ENABLED
    535          static EmberStatus halInternalInitUsbVcp(void)
    536          {
    537            #if defined(CORTEXM3_EM35X_USB)
    538            halResetWatchdog();
    539          
    540            tokTypeMfgEui64 tokEui64;
    541            halCommonGetMfgToken((void *)&tokEui64, TOKEN_MFG_EUI_64);
    542          
    543            uint8_t i = 0;
    544            uint8_t j = 0;
    545            for (j = 0; j < 8; j++) {
    546              USBCDC_iSerialNumber.name[i++] = nibble2Ascii((tokEui64[j] >> 4) & 0xF);
    547              USBCDC_iSerialNumber.name[i++] = nibble2Ascii((tokEui64[j] >> 0) & 0xF);
    548            }
    549          
    550            USBD_Init(&USBCDC_initStruct);
    551          
    552            // USBD_Read(EP_OUT, receiveBuffer, 50, dataReceivedCallback);
    553          
    554            //It is necessary to wait for the COM port on the host to become
    555            //active before serial port3 can be used.
    556            uint16_t startTime = halCommonGetInt16uMillisecondTick();
    557            while (USBD_GetUsbState() != USBD_STATE_CONFIGURED) {
    558                #ifdef BOOTLOADER
    559              halUsbIsr();
    560                #endif
    561              //Give ourselves a healthy 1 second for a COM port to open.
    562              if (elapsedTimeInt16u(startTime,
    563                                    halCommonGetInt16uMillisecondTick()) > 1000) {
    564                return EMBER_SERIAL_INVALID_PORT;
    565              }
    566            }
    567          
    568            return EMBER_SUCCESS;
    569            #else
    570            return EMBER_SERIAL_INVALID_PORT;
    571            #endif
    572          }
    573          
    574          #endif
    575          
