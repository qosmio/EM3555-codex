    269          static void writeRemainingTime(uint8_t endpoint, uint16_t remainingTimeMs)
    270          {
    271          #ifdef ZCL_USING_LEVEL_CONTROL_CLUSTER_LEVEL_CONTROL_REMAINING_TIME_ATTRIBUTE
    272            // Convert milliseconds to tenths of a second, rounding any fractional value
    273            // up to the nearest whole value.  This means:
    274            //
    275            //   0 ms = 0.00 ds = 0 ds
    276            //   1 ms = 0.01 ds = 1 ds
    277            //   ...
    278            //   100 ms = 1.00 ds = 1 ds
    279            //   101 ms = 1.01 ds = 2 ds
    280            //   ...
    281            //   200 ms = 2.00 ds = 2 ds
    282            //   201 ms = 2.01 ds = 3 ds
    283            //   ...
    284            //
    285            // This is done to ensure that the attribute, in tenths of a second, only
    286            // goes to zero when the remaining time in milliseconds is actually zero.
    287            uint16_t remainingTimeDs = (remainingTimeMs + 99) / 100;
    288            EmberStatus status = emberAfWriteServerAttribute(endpoint,
    289                                                             ZCL_LEVEL_CONTROL_CLUSTER_ID,
    290                                                             ZCL_LEVEL_CONTROL_REMAINING_TIME_ATTRIBUTE_ID,
    291                                                             (uint8_t *)&remainingTimeDs,
    292                                                             ZCL_INT16U_ATTRIBUTE_TYPE);
    293            if (status != EMBER_ZCL_STATUS_SUCCESS) {
    294              emberAfLevelControlClusterPrintln("ERR: writing remaining time %x", status);
    295            }
    296          #endif
    297          }
