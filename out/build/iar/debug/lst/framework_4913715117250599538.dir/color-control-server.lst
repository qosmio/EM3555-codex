    152                   == emberAfReadServerAttribute(endpoint,
    153                                                 ZCL_COLOR_CONTROL_CLUSTER_ID,
    154                                                 ZCL_COLOR_CONTROL_COLOR_MODE_ATTRIBUTE_ID,
    155                                                 (uint8_t *)&colorMode,
    156                                                 sizeof(uint8_t)));
    157          
    158            return colorMode;
    159          }
    160          #endif
