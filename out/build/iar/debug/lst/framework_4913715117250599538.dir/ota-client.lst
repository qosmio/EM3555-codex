    139          
    140          // Maximum amount of data that the client is willing to accept in one packet
    141          // The server can always give us less data (sizing the response based on its
    142          // send parameters, eg. source routing).  But it can't give us more.
    143          // Since no
    144          #define MAX_CLIENT_DATA_SIZE      63   // in bytes
    145          
    146          // We only support the Zigbbe Pro stack version.
    147          #define STACK_VERSION ZIGBEE_PRO_STACK_VERSION
