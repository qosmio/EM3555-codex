     27          /** @description Returns the bootloader type the application was
     28           *  built for.
     29           *
     30           * @return BL_TYPE_NULL, BL_TYPE_STANDALONE or BL_TYPE_APPLICATION
     31           */

   \                                 In section .text, align 2, keep-with-next
     32          BlBaseType halBootloaderGetType(void)
     33          {
     34            // Important distinction:
     35            //   this returns what bootloader the app was built for
     36            #ifdef NULL_BTL
     37            BLDEBUG_PRINT("built for NULL bootloader\r\n");
     38            return BL_TYPE_NULL;
     39            #elif defined APP_BTL
     40            // Deprecated
     41            BLDEBUG_PRINT("built for APP bootloader\r\n");
     42            return BL_TYPE_APPLICATION;
     43            #elif defined SERIAL_UART_BTL
     44            // Deprecated
     45            BLDEBUG_PRINT("built for SERIAL UART standalone bootloader\r\n");
     46            return BL_TYPE_STANDALONE;
     47            #elif defined SERIAL_USB_BTL
     48            // Deprecated
     49            BLDEBUG_PRINT("built for SERIAL USB standalone bootloader\r\n");
     50            return BL_TYPE_STANDALONE;
     51            #elif defined SERIAL_OTA_BTL
     52            // Deprecated
     53            BLDEBUG_PRINT("built for SERIAL OTA standalone bootloader\r\n");
     54            return BL_TYPE_STANDALONE;
     55            #else
     56            BLDEBUG_PRINT("built for generic bootloader\r\n");
     57            return BL_TYPE_BOOTLOADER;
   \                     halBootloaderGetType: (+1)
   \        0x0   0x2003             MOVS     R0,#+3
   \        0x2   0x4770             BX       LR
     58            #endif
     59          }
