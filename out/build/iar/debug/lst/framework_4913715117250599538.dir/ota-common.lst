     70          #if defined(EMBER_AF_PRINT_CORE)
     71          
     72          // 32-bit math may be expensive and is only needed for printing
     73          // purposes.  So this functionality should be conditionally compiled in.
     74          
     75          // The 'currentOffset' and 'endOffset' parameters are relative to the static
     76          // variable 'startingOffset'.  It is expected the 'startingOffset' is set by a
     77          // previous call that did nothing but pass in the 'offsetStart' value
     78          // (other parameters are ignored in that case).
     79          static uint8_t printPercentage(const char * prefixString,
     80                                         uint8_t updateFrequency,
     81                                         uint32_t offsetStart,
     82                                         uint32_t currentOffset,
     83                                         uint32_t endOffset)
     84          {
     85            static uint8_t percentageComplete = 0;
     86            static uint8_t oldPercentageComplete = 255; // invalid value
     87            static uint32_t startingOffset = 0;
     88            static uint32_t imageSize = 0;
     89          
     90            if (offsetStart > 0 || endOffset > 0) {
     91              oldPercentageComplete = 255;
     92              startingOffset = offsetStart;
     93              imageSize = endOffset - startingOffset;
     94              return 0;
     95            }
     96            // The rest of this code should NOT use 'offsetStart', but 'startingOffset'.
     97          
     98            currentOffset -= startingOffset;
     99          
    100            percentageComplete = emAfCalculatePercentage(currentOffset, imageSize);
    101          
    102            if (oldPercentageComplete == 255
    103                || (percentageComplete >= updateFrequency
    104                    && (percentageComplete
    105                        >= (oldPercentageComplete + updateFrequency)))) {
    106              emberAfCorePrintln("%p: %d%% complete", prefixString, percentageComplete);
    107              oldPercentageComplete = percentageComplete;
    108            }
    109            return percentageComplete;
    110          }
    111          
    112          void emAfPrintPercentageSetStartAndEnd(uint32_t startingOffset, uint32_t endOffset)
    113          {
    114            printPercentage(NULL,           // prefix string (ignored)
    115                            0,              // update frequency (ignored)
    116                            startingOffset,
    117                            0,              // current offset (ignored)
    118                            endOffset);
    119          }
    120          
    121          uint8_t emAfPrintPercentageUpdate(const char * prefixString,
    122                                            uint8_t updateFrequency,
    123                                            uint32_t currentOffset)
    124          {
    125            return printPercentage(prefixString,
    126                                   updateFrequency,
    127                                   0,               // offset start (ignored)
    128                                   currentOffset,
    129                                   0);              // offset end (ignored)
    130          }
    131          
    132          uint8_t emAfCalculatePercentage(uint32_t currentOffset, uint32_t imageSize)
    133          {
    134            uint8_t percentage = 0;
    135            if (imageSize == 0) {
    136              return 0;
    137            }
    138          
    139            if (currentOffset >= imageSize) {
    140              percentage = 100;
    141            } else {
    142              percentage = (currentOffset * 100) / imageSize;
    143            }
    144            return percentage;
    145          }
