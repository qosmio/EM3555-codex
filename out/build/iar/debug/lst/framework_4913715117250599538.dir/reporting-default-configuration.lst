     37          
     38          // scanning the table and adding default configs
     39          // 1) create a true/false record for each of the generated configs
     40          // 2) loop over the entries in the reporting table
     41          //   a) for each entry, scan through the default config references
     42          //   b) if we find any default configs that match the current table entry, mark them as do not add
     43          // 3) go through the updated record, and add the unmarked ones to the end of the table
     44          //
     45          // we use a large bitmask array, where each bit corresponds with either
     46          //  - (0) DONT_ADD, a matching entry exists in the Reporting Table
     47          //  - (1) ADD_CONFIG, this configuration needs to be added to the table
     48          // using a large bitmask over a simple array allows us to compress the information to 1-bit
     49          // per entry and greatly reduces the RAM impact on the CSTACK
     50          //
     51          // these macros are used to reference the bit-record corresponding to the given index.
     52          #define ADD_CONFIG_INDEX(n) ((n) >> 3)
     53          #define ADD_CONFIG_BIT(n) (1U << ((n) & 0x07))
     54          // EX: extracting bit-record for entry i in generatedReportingConfigDefaults
     55          //     addConfigsBitmask[ADD_CONFIG_INDEX(i)] & ADD_CONFIG_BIT(i)
     56          
     57          #define ADD_CONFIGS_LENGTH (ADD_CONFIG_INDEX(EMBER_AF_GENERATED_REPORTING_CONFIG_DEFAULTS_TABLE_SIZE) + 1)
     58          // -----------------------------
     59          

   \                                 In section .text, align 2, keep-with-next
     60          static void scanTableAddDefaultConfigs(void)
     61          {
     62            #if (EMBER_AF_GENERATED_REPORTING_CONFIG_DEFAULTS_TABLE_SIZE != 0)
     63            uint8_t addConfigsBitmask[ADD_CONFIGS_LENGTH];
     64            uint16_t i;
     65          
     66            // initialize all of the records as ADD_CONFIG
     67            MEMSET(addConfigsBitmask, 0xff, sizeof(addConfigsBitmask));
     68          
     69            // scan the table entries, marking matching generated defaults as DONT_ADD
     70            EmberAfPluginReportingEntry tableEntry;
     71            for (i = 0; i < emAfPluginReportingNumEntries(); i++) {
     72              emAfPluginReportingGetEntry(i, &tableEntry);
     73              for (uint16_t j = 0; j < EMBER_AF_GENERATED_REPORTING_CONFIG_DEFAULTS_TABLE_SIZE; j++) {
     74                if ((addConfigsBitmask[ADD_CONFIG_INDEX(j)] & ADD_CONFIG_BIT(j))
     75                    && emAfPluginReportingDoEntriesMatch(&tableEntry, &generatedReportingConfigDefaults[j])) {
     76                  addConfigsBitmask[ADD_CONFIG_INDEX(j)] &= ~ADD_CONFIG_BIT(j);
     77                }
     78              }
     79            }
     80          
     81            // now scan through the generated report configs, check the corresponding record
     82            for (i = 0; i < EMBER_AF_GENERATED_REPORTING_CONFIG_DEFAULTS_TABLE_SIZE; i++) {
     83              // if the record corresponding to the index shows ADD_CONFIG
     84              //  to the table at the next available free index
     85              if (addConfigsBitmask[ADD_CONFIG_INDEX(i)] & ADD_CONFIG_BIT(i)) {
     86                tableEntry = generatedReportingConfigDefaults[i];
     87                if (emAfPluginReportingAppendEntry(&tableEntry) == NULL_INDEX) {
     88                  // if we are out of free indices, break the loop
     89                  // we may run out of free indices if the number of configurations we receive over
     90                  // the air exceeds the number of free spaces allocated by the plugin option
     91                  break;
     92                }
     93              }
     94            }
     95            #endif // (EMBER_AF_GENERATED_REPORTING_CONFIG_DEFAULTS_TABLE_SIZE != 0)
     96          }
   \                     scanTableAddDefaultConfigs: (+1)
   \        0x0   0x4770             BX       LR
