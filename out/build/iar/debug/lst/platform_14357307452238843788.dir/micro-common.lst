     58            #define OSC24M_HZ (ENABLE_OSC24M)
     59          #elif   ((ENABLE_OSC24M >=    1000) || (ENABLE_OSC24M <=    -1000)) // KHz
     60            #define OSC24M_HZ (ENABLE_OSC24M * 1000L)
     61          #else//!((ENABLE_OSC24M >=    1000) || (ENABLE_OSC24M <=    -1000)) // MHz
