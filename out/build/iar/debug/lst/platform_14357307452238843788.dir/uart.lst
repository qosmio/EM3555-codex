   1659          #ifdef EMBER_SERIAL1_XONXOFF
   1660          // Must be called from within an ATOMIC block.
   1661          static void halInternalUart1ForceXon(void)
   1662          {
   1663            if (xonXoffTxByte == ASCII_XOFF) {   // if XOFF waiting to be sent, cancel it
   1664              xonXoffTxByte = 0;
   1665              xcmdCount = 0;
   1666            } else {                            // else, send XON and record the time
   1667              xonXoffTxByte = ASCII_XON;
   1668              halInternalStartUartTx(1);
   1669            }
   1670            xonTimer = halCommonGetInt16uQuarterSecondTick();
   1671          }
