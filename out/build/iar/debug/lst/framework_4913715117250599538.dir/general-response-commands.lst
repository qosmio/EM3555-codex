   \                                 In section .text, align 2, keep-with-next
    159          bool emberAfReadReportingConfigurationResponseCallback(EmberAfClusterId clusterId,
    160                                                                 uint8_t *buffer,
    161                                                                 uint16_t bufLen)
    162          {
   \                     emberAfReadReportingConfigurationResponseCallback: (+1)
   \        0x0   0xB580             PUSH     {R7,LR}
    163          #if defined(EMBER_AF_PRINT_ENABLE) && defined(EMBER_AF_PRINT_REPORTING)
    164            uint16_t bufIndex = 0;
    165            emberAfReportingPrint("%p_RESP: ", "READ_RPT_CFG");
    166            emberAfReportingDebugExec(emberAfDecodeAndPrintClusterWithMfgCode(clusterId, emberAfGetMfgCodeFromCurrentCommand()));
    167            emberAfReportingPrintln("");
    168            emberAfReportingFlush();
    169          
    170            // Each record in the response has a one-byte status, a one-byte direction,
    171            // and a two-byte attribute id.  If the status is SUCCESS, the record will
    172            // contain additional fields.
    173            while (bufIndex + 4 <= bufLen) {
    174              EmberAfAttributeId attributeId;
    175              EmberAfStatus status;
    176              EmberAfReportingDirection direction;
    177              status = (EmberAfStatus)emberAfGetInt8u(buffer, bufIndex, bufLen);
    178              bufIndex++;
    179              direction = (EmberAfReportingDirection)emberAfGetInt8u(buffer,
    180                                                                     bufIndex,
    181                                                                     bufLen);
    182              bufIndex++;
    183              attributeId = (EmberAfAttributeId)emberAfGetInt16u(buffer,
    184                                                                 bufIndex,
    185                                                                 bufLen);
    186              bufIndex += 2;
    187              emberAfReportingPrintln(" - status:%x, direction:%x, attr:%2x",
    188                                      status,
    189                                      direction,
    190                                      attributeId);
    191              if (status == EMBER_ZCL_STATUS_SUCCESS) {
    192                // If the direction indicates the attribute is reported, the record will
    193                // contain a one-byte type and two two-byte intervals.  If the type is
    194                // analog, the record will contain a reportable change of the same data
    195                // type.  If the direction indicates reports of the attribute are
    196                // received, the record will contain a two-byte timeout.
    197                switch (direction) {
    198                  case EMBER_ZCL_REPORTING_DIRECTION_REPORTED:
    199                  {
    200                    uint16_t minInterval, maxInterval;
    201                    uint8_t dataType;
    202                    dataType = emberAfGetInt8u(buffer, bufIndex, bufLen);
    203                    bufIndex++;
    204                    minInterval = emberAfGetInt16u(buffer, bufIndex, bufLen);
    205                    bufIndex += 2;
    206                    maxInterval = emberAfGetInt16u(buffer, bufIndex, bufLen);
    207                    bufIndex += 2;
    208                    emberAfReportingPrintln("   type:%x, min:%2x, max:%2x",
    209                                            dataType,
    210                                            minInterval,
    211                                            maxInterval);
    212                    if (emberAfGetAttributeAnalogOrDiscreteType(dataType)
    213                        == EMBER_AF_DATA_TYPE_ANALOG) {
    214                      uint8_t dataSize = emberAfGetDataSize(dataType);
    215                      emberAfReportingPrint("   change:");
    216                      emberAfReportingPrintBuffer(buffer + bufIndex, dataSize, false);
    217                      emberAfReportingPrintln("");
    218                      bufIndex += dataSize;
    219                    }
    220                    break;
    221                  }
    222                  case EMBER_ZCL_REPORTING_DIRECTION_RECEIVED:
    223                  {
    224                    uint16_t timeout = emberAfGetInt16u(buffer, bufIndex, bufLen);
    225                    bufIndex += 2;
    226                    emberAfReportingPrintln("   timeout:%2x", timeout);
    227                    break;
    228                  }
    229                  default:
    230                    emberAfReportingPrintln("ERR: unknown direction %x", direction);
    231                    emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_INVALID_FIELD);
    232                    return true;
    233                }
    234              }
    235              emberAfReportingFlush();
    236            }
    237          #endif //EMBER_AF_PRINT_ENABLE && EMBER_AF_PRINT_REPORTING
    238            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   \        0x2   0x2000             MOVS     R0,#+0
   \        0x4   0x.... 0x....      BL       emberAfSendImmediateDefaultResponse
    239            return true;
   \        0x8   0x2001             MOVS     R0,#+1
   \        0xA   0xBD02             POP      {R1,PC}
    240          }
