     17          #include PLATFORM_HEADER
     18          #include "hal/micro/endian.h"
     19          
     20          #if (!defined(EMBER_STACK_OWL_RX))
     21          #include "stack/include/ember-types.h"
     22          #endif /* EMBER_STACK_OWL_RX */
     23          
     24          // Endian conversion APIs.
     25          // Network byte order is big endian, so these APIs are only necessary on
     26          //  platforms which have a natural little endian byte order.  On big-endian
     27          //  platforms, the APIs are macro'd away to nothing
     28          
     29          #ifndef NTOHS
     30          // Network to Host Short
     31          uint16_t NTOHS(uint16_t val)
     32          {
     33            uint8_t *fldPtr;
     34          
     35            fldPtr = (uint8_t *)&val;
     36            return (HIGH_LOW_TO_INT(*fldPtr, *(fldPtr + 1)));
     37          }
     38          
     39          #endif
     40          
     41          #ifndef NTOHL
     42          // Network to Host Long
     43          uint32_t NTOHL(uint32_t val)
     44          {
     45            uint16_t *fldPtr;
     46            uint16_t field;
     47            uint16_t field2;
     48          
     49            fldPtr = (uint16_t *)&val;
     50            field = NTOHS(*fldPtr);
     51            field2 = NTOHS(*(fldPtr + 1));
     52            return ((uint32_t)field << 16) | ((uint32_t)field2);
     53          }
     54          
     55          #endif
     56          
     57          /* Swap byte order, e.g. LE to BE or BE to LE.
     58           * This function is used when working with 802.15.4 frames on 8051 MCUs. */

   \                                 In section .text, align 2, keep-with-next
     59          uint32_t SwapEndiannessInt32u(uint32_t val)
     60          {
   \                     SwapEndiannessInt32u: (+1)
   \        0x0   0xB401             PUSH     {R0}
   \        0x2   0xB081             SUB      SP,SP,#+4
     61            uint32_t ret;
     62          
     63            ((uint8_t*)&ret)[0] = ((uint8_t*)&val)[3];
   \        0x4   0xF89D 0x0007      LDRB     R0,[SP, #+7]
   \        0x8   0xF88D 0x0000      STRB     R0,[SP, #+0]
     64            ((uint8_t*)&ret)[1] = ((uint8_t*)&val)[2];
   \        0xC   0xF89D 0x0006      LDRB     R0,[SP, #+6]
   \       0x10   0xF88D 0x0001      STRB     R0,[SP, #+1]
     65            ((uint8_t*)&ret)[2] = ((uint8_t*)&val)[1];
   \       0x14   0xF89D 0x0005      LDRB     R0,[SP, #+5]
   \       0x18   0xF88D 0x0002      STRB     R0,[SP, #+2]
     66            ((uint8_t*)&ret)[3] = ((uint8_t*)&val)[0];
   \       0x1C   0xF89D 0x0004      LDRB     R0,[SP, #+4]
   \       0x20   0xF88D 0x0003      STRB     R0,[SP, #+3]
     67          
     68            return ret;
   \       0x24   0x9800             LDR      R0,[SP, #+0]
   \       0x26   0xB002             ADD      SP,SP,#+8
   \       0x28   0x4770             BX       LR
     69          }

