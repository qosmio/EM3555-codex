   \                                 In section .text, align 2, keep-with-next
   1376          void emberAfPluginColorControlServerStopTransition(void)
   1377          {
   1378            stopAllColorTransitions();
   \                     emberAfPluginColorControlServerStopTransition: (+1)
   \        0x0   0x....             B.N      stopAllColorTransitions
   1379          }
   1380          
   1381          // The specification says that if we are transitioning from one color mode
   1382          // into another, we need to compute the new mode's attribute values from the
   1383          // old mode.  However, it also says that if the old mode doesn't translate into
   1384          // the new mode, this must be avoided.
   1385          // I am putting in this function to compute the new attributes based on the old
   1386          // color mode.
   1387          #if defined(EMBER_AF_PLUGIN_COLOR_CONTROL_SERVER_HSV) \
   1388            || defined(EMBER_AF_PLUGIN_COLOR_CONTROL_SERVER_XY) \
   1389            || defined(EMBER_AF_PLUGIN_COLOR_CONTROL_SERVER_TEMP)
   1390          static void handleModeSwitch(uint8_t endpoint,
   1391                                       uint8_t newColorMode)
   1392          {
   1393            uint8_t oldColorMode = readColorMode(endpoint);
   1394            uint8_t colorModeTransition;
   1395          
   1396            if (oldColorMode == newColorMode) {
   1397              return;
   1398            } else {
   1399              writeColorMode(endpoint, newColorMode);
   1400            }
   1401          
   1402            colorModeTransition = (newColorMode << 4) + oldColorMode;
   1403          
   1404            // Note:  It may be OK to not do anything here.
   1405            switch (colorModeTransition) {
   1406              case HSV_TO_CIE_XY:
   1407                emberAfPluginColorControlServerComputePwmFromXyCallback(endpoint);
   1408                break;
   1409              case TEMPERATURE_TO_CIE_XY:
   1410                emberAfPluginColorControlServerComputePwmFromXyCallback(endpoint);
   1411                break;
   1412              case CIE_XY_TO_HSV:
   1413                emberAfPluginColorControlServerComputePwmFromHsvCallback(endpoint);
   1414                break;
   1415              case TEMPERATURE_TO_HSV:
   1416                emberAfPluginColorControlServerComputePwmFromHsvCallback(endpoint);
   1417                break;
   1418              case HSV_TO_TEMPERATURE:
   1419                emberAfPluginColorControlServerComputePwmFromTempCallback(endpoint);
   1420                break;
   1421              case CIE_XY_TO_TEMPERATURE:
   1422                emberAfPluginColorControlServerComputePwmFromTempCallback(endpoint);
   1423                break;
   1424          
   1425              // for the following cases, there is no transition.
   1426              case HSV_TO_HSV:
   1427              case CIE_XY_TO_CIE_XY:
   1428              case TEMPERATURE_TO_TEMPERATURE:
   1429              default:
   1430                return;
   1431            }
   1432          }
   1433          #endif
   1434          

