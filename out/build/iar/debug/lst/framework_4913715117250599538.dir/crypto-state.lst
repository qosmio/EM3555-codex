     24          static EmAfCryptoStatus cryptoStatus = EM_AF_NO_CRYPTO_OPERATION;
   \                     cryptoStatus:
   \        0x0                      DS8 1
     25          #if defined(EMBER_AF_PRINT_ENABLE) && defined(EMBER_AF_PRINT_SECURITY)
     26          static const char * cryptoStatusText[] = EM_AF_CRYPTO_STATUS_TEXT;
     27          #endif //defined(EMBER_AF_PRINT_ENABLE) && defined(EMBER_AF_PRINT_SECURITY)
     28          
     29          // If we are on a host micro, there is the possibility that a crypto
     30          // operation ends on the NCP and we fail to hear about it, in this case
     31          // we need a timeout to safeguard against this flag getting locked
     32          #if defined(EZSP_HOST)
     33          EmberEventControl emAfCryptoOperationTimeoutEventControl;
     34          void emAfCryptoOperationTimeoutEvent(void)
     35          {
     36            if (cryptoStatus == EM_AF_CRYPTO_OPERATION_IN_PROGRESS) {
     37              emAfSetCryptoStatus(EM_AF_NO_CRYPTO_OPERATION);
     38            }
     39          }
     40          EmberEventData emAfCryptoEvents[] = {
     41            { &emAfCryptoOperationTimeoutEventControl, emAfCryptoOperationTimeoutEvent },
     42            { NULL, NULL }
     43          };
     44          #endif //EZSP_HOST
     45          
     46          //------------------------------------------------------------------------------
     47          

   \                                 In section .text, align 2, keep-with-next
     48          EmAfCryptoStatus emAfGetCryptoStatus(void)
     49          {
     50          #if defined(EZSP_HOST)
     51            // Everytime someone asks for the crypto state, we check our
     52            // crypto timeout
     53            emberRunEvents(emAfCryptoEvents);
     54          #endif //EZSP_HOST
     55          
     56            return cryptoStatus;
