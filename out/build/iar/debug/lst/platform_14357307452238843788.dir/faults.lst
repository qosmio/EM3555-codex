   68                                   __THUMB__
   69                                   __EXPORT__ halUsageFaultIsr
   70                           halUsageFaultIsr:
   71    00000000 ........              b.w fault
   72                           #endif
   73                           
   74                                   __CODE__
   75                                   __THUMB__
   76                                   __EXPORT__ halDebugMonitorIsr
   77                           halDebugMonitorIsr:
   78    00000000 ........              b.w fault
   79                           
   80                                   __CODE__
   81                                   __THUMB__
   82                                   __EXPORT__ uninitializedIsr
   83                           uninitializedIsr:
   84    00000000 ........              b.w fault
