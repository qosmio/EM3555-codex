   86                           
   87                           //--------------------------------------------
                                ----------------------------------
   88                           // Common fault handler prolog processing
   89                           //
   90                           //   determines which of the three possible
                                 EXC_RETURN values is in lr,
   91                           //   then uses lr to save processor registers
                                 r0-r12 to the crash info area
   92                           //
   93                           //   restores lr's value, and then saves lr,
                                 msp and psp to the crash info area
   94                           //
   95                           //   checks the stack pointer to see if it is
                                 valid and won't overwrite the crash
   96                           //   info area - if needed, resets the stack
                                 pointer to the top of the stack
   97                           //   
   98                           //   calls halInternalCrashHandler() to
                                 continue saving crash data. This 
   99                           //   C function can finish crash processing
                                 without risking further faults.
  100                           //   It returns the fault reason, and this is
                                 passed to halInternalSysReset() 
  101                           //   that forces a processor reset.
  102                           //
  103                           //--------------------------------------------
                                ----------------------------------
  104                                   __CODE__
  105                                   __THUMB__
  106                                   __EXPORT__ fault
  107                           fault:
  108    00000000 72B6                  cpsid   i               // in case the
                                                                 fault priority
                                                                 is low
  109    00000002 1EF0080F              tst     lr, #8          // test
                                                      EXC_RETURN for handler vs
                                                      thread mode
  110    00000006 08D0                  beq.n   fault_handler_msp
  111    00000008 1EF0040F              tst     lr, #4          // thread mode:
                                                      test for msp versus
                                                      psp
  112    0000000C 0BD0                  beq.n   fault_thread_msp
  113                           
  114                           fault_thread_psp:
  115    0000000E DFF848E0              ldr     lr, =__BEGIN_RESETINFO__(4)
  116    00000012 AEE8FF1F              stmia.w lr!, {r0-r12}
  117    00000016 1148                  ldr     r0, =EXC_RETURN_THREAD_PSP
  118    00000018 0AE0                  b.n     fault_continue
  119                           
  120                           fault_handler_msp:
  121    0000001A DFF83CE0              ldr     lr, =__BEGIN_RESETINFO__(4)
  122    0000001E AEE8FF1F              stmia.w lr!, {r0-r12}
  123    00000022 0F48                  ldr     r0, =EXC_RETURN_HANDLER_MSP
  124    00000024 04E0                  b.n     fault_continue
  125                           
  126                           fault_thread_msp:
  127    00000026 DFF830E0              ldr     lr, =__BEGIN_RESETINFO__(4)
  128    0000002A AEE8FF1F              stmia.w lr!, {r0-r12}
  129    0000002E 0D48                  ldr     r0, =EXC_RETURN_THREAD_MSP
  130                           //        b.n     fault_continue
  131                           
  132                           fault_continue:
  133    00000030 6946                  mov     r1, sp
  134    00000032 EFF30982              mrs     r2, PSP
  135    00000036 8EE80700              stm     lr, {r0-r2}     // save lr, msp
                                                      and psp
  136    0000003A 8646                  mov     lr, r0          // restore
                                                      lr
  137                           
  138                           fault_check_sp:
  139                                   //  make sure that the current stack
                                 pointer is within the minimum region
  140                                   //  that must be occupied by the stack
                                 and that there is some headroom
  141                                   //  for the crash handler's stack.
  142    0000003C 0A48                  ldr     r0, =__BEGIN_STACK__(CRASH_STAC
                                                     K_SIZE)
  143    0000003E 0B4C                  ldr     r4, =__END_STACK__(0)
  144    00000040 8545                  cmp     sp, r0
  145    00000042 01D3                  blo.n   fault_fix_sp
  146                                   // compare to make sure SP otherwise
                                 looks valid
  147    00000044 A545                  cmp     sp, r4
  148    00000046 01D3                  blo.n   fault_sp_okay
  149                           fault_fix_sp:
  150    00000048 84F30888              msr     msp, r4
  151                           fault_sp_okay:
  152    0000004C ........              bl.w    halInternalCrashHandler //
                                                  saves rest of data, returns
                                                  reason
  153    00000050 84F30888              msr     msp, r4                 // set
                                                       sp to top of stack
                                                       segment
  154    00000054 ........              bl.w    halInternalSysReset     // call
                                                  with reset reason in R0    
                                                  
  155                           
