    287          EmberStatus emberSerialWriteBuffer(uint8_t port,
    288                                             EmberMessageBuffer buffer,
    289                                             uint8_t start,
    290                                             uint8_t length)
    291          {
    292            emberSerialWriteData(port,
    293                                 emberMessageBufferContents(buffer) + start,
    294                                 length);
