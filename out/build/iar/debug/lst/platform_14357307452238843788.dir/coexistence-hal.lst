    284          
    285          static void setGpioFlag(COEX_GpioHandle_t gpioHandle, bool enabled)
    286          {
    287            if (gpioHandle != NULL) {
    288              COEX_HAL_GpioConfig_t *gpio = (COEX_HAL_GpioConfig_t*)gpioHandle;
    289          
    290              if (enabled) {
    291                NVIC_SetPendingIRQ((IRQn_Type)gpio->intEnBit);
    292              } else {
    293                EVENT_MISS->MISS = gpio->intMissBit;
    294                EVENT_GPIO->FLAG = gpio->flagBit;
    295              }
    296            }
    297          }
    298          
    299          static void setInterruptConfig(COEX_GpioHandle_t gpioHandle)
    300          {
    301            if (gpioHandle != NULL) {
    302              COEX_HAL_GpioConfig_t *gpio = (COEX_HAL_GpioConfig_t*)gpioHandle;
    303              COEX_GpioConfig_t *coexGpio = &(gpio->config);
    304              uint32_t interruptEdges = EVENT_GPIO_CFGA_FILT_DEFAULT; /* default = no filter  */
    305              bool intAsserted = (coexGpio->options & COEX_GPIO_OPTION_INT_ASSERTED) != 0U;
    306              bool intDeasserted = (coexGpio->options & COEX_GPIO_OPTION_INT_DEASSERTED) != 0U;
    307          
    308              if (gpio->polarity ? intAsserted : intDeasserted) {
    309                interruptEdges |= EVENT_GPIO_CFGx_MOD_RISING_EDGE;
    310              }
    311              if (gpio->polarity ? intDeasserted : intAsserted) {
    312                interruptEdges |= EVENT_GPIO_CFGx_MOD_FALLING_EDGE;
    313              }
    314              gpio->interruptEdges |= interruptEdges;
    315            }
    316          }
    317          
    318          static void enableGpioInt(COEX_GpioHandle_t gpioHandle,
    319                                    bool enabled,
    320                                    bool *wasAsserted)
    321          {
    322            if (gpioHandle != NULL) {
    323              COEX_HAL_GpioConfig_t *gpio = (COEX_HAL_GpioConfig_t*)gpioHandle;
    324          
    325              // Disable triggering and clear any stale events
    326              *(gpio->intCfg) = 0;                  //disable triggering
    327              NVIC_DisableIRQ((IRQn_Type)gpio->intEnBit);      //clear top level int enable
    328              NVIC_ClearPendingIRQ((IRQn_Type)gpio->intEnBit); //clear any pended event
    329              setGpioFlag(gpio, false);
    330              if (enabled && gpio->isr != NULL) {
    331                if (wasAsserted != NULL) {
    332                  *wasAsserted = false;
    333                }
    334                *(gpio->intCfg) = gpio->interruptEdges;
    335                gpio->intSel(); //point IRQ to the desired pin
    336                NVIC_EnableIRQ((IRQn_Type)gpio->intEnBit);  //set top level interrupt enable
    337              }
    338            }
    339          }
    340          
    341          static void configGpio(COEX_GpioHandle_t gpioHandle, COEX_GpioConfig_t *coexGpio)
    342          {
    343            if (gpioHandle != NULL) {
    344              COEX_HAL_GpioConfig_t *gpio = (COEX_HAL_GpioConfig_t*)gpioHandle;
    345              bool defaultAsserted = (coexGpio->options & COEX_GPIO_OPTION_DEFAULT_ASSERTED) != 0U;
    346              gpio->config = *coexGpio;
    347          
    348              // Only configure GPIO if it was not set up prior
    349              if ((coexGpio->options & COEX_GPIO_OPTION_SHARED) != 0U) {
    350                gpio->mode = GPIO_P_CFGz_Pxy_OUT_OD;
    351              } else if ((coexGpio->options & COEX_GPIO_OPTION_OUTPUT) != 0U) {
    352                gpio->mode = GPIO_P_CFGz_Pxy_OUT;
    353              } else {
    354                gpio->mode = GPIO_P_CFGz_Pxy_IN_PUD;
    355              }
    356              halGpioSetConfig(gpio->gpio, (HalGpioCfg_t)gpio->mode);
    357              setGpio(gpio, defaultAsserted);
    358              setInterruptConfig(gpio);
    359            }
    360          }
    361          
    362          static bool isGpioInSet(COEX_GpioHandle_t gpioHandle, bool defaultValue)
    363          {
