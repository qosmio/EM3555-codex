   1367          // **************** transition state machines ***********
   1368          

   \                                 In section .text, align 2, keep-with-next
   1369          static void stopAllColorTransitions(void)
   1370          {
   1371            emberEventControlSetInactive(COLOR_TEMP_CONTROL);
