    626          
    627          __STATIC_INLINE void COEX_SetPriorityAndRequest(bool request, bool priority)
    628          {
    629            // We are purposely defining every combination of request
    630            // and priority. This reduces the delay between setting
    631            // the 3 coex GPIOs.  If all 3 coex registers are on the
    632            // same port, all GPIOs can be set simultaneously.
    633            if (request) {
    634              if (priority) {
    635          #ifdef COEX_HAL_CONFIG_DP_PRS
    636                //Setup PRS priority config before enabling request
    637                COEX_HAL_SetPriority();
    638          #endif //COEX_HAL_CONFIG_DP_PRS
    639                COEX_HAL_SetPwmRequest();
    640                COEX_HAL_SetRequest();
    641          #ifndef COEX_HAL_CONFIG_DP_PRS
    642                COEX_HAL_SetPriority();
    643          #endif //COEX_HAL_CONFIG_DP_PRS
    644              } else {
    645                COEX_HAL_SetPwmRequest();
    646                COEX_HAL_SetRequest();
    647                COEX_HAL_ClearPriority();
    648              }
    649            } else {
    650              if (priority) {
    651                COEX_HAL_SetPwmRequest();
    652                COEX_HAL_ClearRequest();
    653                COEX_HAL_SetPriority();
    654              } else {
    655                COEX_HAL_SetPwmRequest();
    656                COEX_HAL_ClearRequest();
    657                COEX_HAL_ClearPriority();
    658              }
    659            }
    660          }
    661          __STATIC_INLINE void COEX_ClearRequestAndPriority(void)
    662          {
    663            COEX_HAL_ClearPriority();
    664            COEX_HAL_ClearRequest();
    665            COEX_HAL_ClearPwmRequest();
    666          }
    667          #else //!COEX_HAL_FAST_REQUEST
    668          #define COEX_ReadRequest() isGpioInSet(reqHandle, false)
    669          __STATIC_INLINE void COEX_SetPriorityAndRequest(bool request, bool priority)
    670          {
    671            setGpio(pwmReqHandle, true);
    672            setGpio(reqHandle, request);
    673            setGpio(priHandle, priority);
    674          }
    675          __STATIC_INLINE void COEX_ClearRequestAndPriority(void)
    676          {
    677            setGpio(priHandle, false);
    678            setGpio(reqHandle, false);
    679            setGpio(pwmReqHandle, false);
    680          }
    681          #endif //!COEX_HAL_FAST_REQUEST
