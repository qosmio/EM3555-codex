   \        0x0   0x....             LDR.N    R0,??DataTable1
   \        0x2   0x7800             LDRB     R0,[R0, #+0]
   \        0x4   0x4770             BX       LR
     57          }
     58          

   \                                 In section .text, align 2, keep-with-next
     59          void emAfSetCryptoStatus(EmAfCryptoStatus newStatus)
     60          {
     61            cryptoStatus = newStatus;
   \                     emAfSetCryptoStatus: (+1)
   \        0x0   0x....             LDR.N    R1,??DataTable1
   \        0x2   0x7008             STRB     R0,[R1, #+0]
     62            emberAfSecurityPrintln("Crypto state: %p", cryptoStatusText[cryptoStatus]);
     63          
     64          #if defined(EZSP_HOST)
     65            // If crypto is starting, we set the timeout, otherwise we cancel it.
     66            if (cryptoStatus == EM_AF_CRYPTO_OPERATION_IN_PROGRESS) {
     67              emberEventControlSetDelayMS(emAfCryptoOperationTimeoutEventControl,
     68                                          CRYPTO_OPERATION_TIMEOUT_MS);
     69            } else {
