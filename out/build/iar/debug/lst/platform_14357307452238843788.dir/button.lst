   \       0x20   0xF000 0x0001      AND      R0,R0,#0x1
   \       0x24   0xF080 0x0001      EOR      R0,R0,#0x1
   \       0x28   0x4770             BX       LR
    152          #endif
    153          #ifdef BUTTON2
    154              case BUTTON2:
    155                return ((BUTTON2_IN & BIT(BUTTON2 & 7)) != 0U) ? BUTTON_RELEASED : BUTTON_PRESSED;
    156          #endif
    157          #ifdef BUTTON3
    158              case BUTTON3:
    159                return ((BUTTON3_IN & BIT(BUTTON3 & 7)) != 0U) ? BUTTON_RELEASED : BUTTON_PRESSED;
