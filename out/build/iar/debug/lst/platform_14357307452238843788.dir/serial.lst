    303          //------------------------------------------------------
    304          // Guaranteed output
    305          
    306          // The _only_ Guaranteed API:  The usage model for this api
    307          //   Does not require efficiency
    308          
    309          #if !defined(EMBER_AF_PLUGIN_STANDARD_PRINTF_SUPPORT)
    310          
    311          EmberStatus emberSerialGuaranteedPrintf(uint8_t port, PGM_P formatString, ...)
    312          {
    313            va_list ap;
    314            va_start(ap, formatString);
    315            (void) emPrintfInternal(COM_ForceWriteData, (COM_Port_t) port, formatString, ap);
    316            va_end(ap);
    317            return EMBER_SUCCESS;
    318          }
    319          
    320          #endif
