    336          #if defined(EMBER_AF_PLUGIN_INTERPAN_ALLOW_APS_ENCRYPTED_MESSAGES)
    337          
    338          static EmberStatus handleApsSecurity(bool encrypt,
    339                                               uint8_t* apsFrame,
    340                                               uint8_t apsHeaderLength,
    341                                               uint8_t* messageLength,
    342                                               uint8_t maxLengthForEncryption,
    343                                               EmberAfInterpanHeader* header)
    344          {
    345            uint8_t keyIndex;
    346            EmberStatus status;
    347          
    348            if (!(header->options & EMBER_AF_INTERPAN_OPTION_MAC_HAS_LONG_ADDRESS)) {
    349              // We won't encrypt/decrypt messages that don't have a long address.
    350              return EMBER_APS_ENCRYPTION_ERROR;
    351            }
    352            keyIndex = emberFindKeyTableEntry(header->longAddress,
    353                                              true);  // link key? (vs. master key)
    354            if (keyIndex == 0xFF) {
    355              return EMBER_APS_ENCRYPTION_ERROR;
    356            }
    357          
    358            if (encrypt
    359                && ((maxLengthForEncryption - *messageLength)
    360                    < INTERPAN_APS_ENCRYPTION_OVERHEAD)) {
    361              return EMBER_APS_ENCRYPTION_ERROR;
    362            }
    363          
    364            apsFrame[0] |= INTERPAN_APS_FRAME_SECURITY;
    365          
    366            status = emAfInterpanApsCryptMessage(encrypt,
    367                                                 apsFrame,
    368                                                 messageLength,
    369                                                 apsHeaderLength,
    370                                                 header->longAddress);
    371            return status;
    372          }
    373          #endif
