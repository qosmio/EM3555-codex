   1589          static uint16_t computeTransitionTimeFromStateAndRate(Color16uTransitionState *p,
   1590                                                                uint16_t rate)
   1591          {
   1592            uint32_t transitionTime;
   1593            uint16_t max, min;
   1594          
   1595            if (rate == 0) {
   1596              return MAX_INT16U_VALUE;
   1597            }
   1598          
   1599            if (p->currentValue > p->finalValue) {
   1600              max = p->currentValue;
   1601              min = p->finalValue;
   1602            } else {
   1603              max = p->finalValue;
   1604              min = p->currentValue;
   1605            }
   1606          
   1607            transitionTime = max - min;
   1608            transitionTime *= 10;
   1609            transitionTime /= rate;
   1610          
   1611            if (transitionTime > MAX_INT16U_VALUE) {
