    987                 #ifndef CORTEXM3_EM35X_GEN4 // HW bug fixed in GEN4
    988                  //Due to FogBugz 11909/11920, SLEEPTMR_CNT may not have updated yet so
    989                  //we must ensure that the CNT register updates before returning.  It's
    990                  //only necessary to wait for the CNT to update when we've gone to
    991                  //sleep, the SLEEPTMR is enabled, and the sleep mode used a timer.
    992                  //This code could delay for up to 1ms, but will return as soon as it
    993                  //can.  In the situation where the chip slept for a known amount of
    994                  //time, this code will not delay and instead the system timer will
    995                  //report a fake, but accurate time.
    996                  if ((!skipSleep)
    997                      && (SLEEPTMR->CFG & SLEEPTMR_CFG_ENABLE)
    998                      && (CMHV->SLEEPTMRCLKEN & CMHV_SLEEPTMRCLKEN_CLK10KEN)
    999                      && (sleepMode != SLEEPMODE_NOTIMER)) {
   1000                    uint32_t currSleepTmrCnt;
   1001          
   1002                    #ifdef BUG11909_WORKAROUND_C
   1003                    //THIS WORKAROUND IS NOT PROVEN 100% RELIABLE.  THIS SHOULD NOT BE
   1004                    //USED UNTIL IT IS PROVEN PERFECTLY RELIABLE.
   1005                    //This workaround attempts to force the SLEEPTMR_CNT to tick sooner
   1006                    //than normal.  It does so by toggling between the clock sources
   1007                    //to get the CNT to increment.  There is a chance the SLEEPTMR_CNT
   1008                    //could become random doing this!
   1009                    {
   1010                      currSleepTmrCnt = SLEEPTMR->CNTH << 16;
   1011                      currSleepTmrCnt |= SLEEPTMR->CNTL;
   1012                      if (currSleepTmrCnt == wakeupSleepTmrCnt) {
   1013                        uint32_t GPIO_PCOUT_SAVED = GPIO->P[2].OUT;
   1014                        uint32_t GPIO_PCCFGH_SAVED = GPIO->P[2].CFGH;
   1015                        uint32_t SLEEPTMR_CFG_SAVED = SLEEPTMR->CFG;
   1016                        //It is not necessary to do anything with CMHV->SLEEPTMRCLKEN.
   1017                        GPIO_PCSET = PC7;
   1018                        SET_REG_FIELD(GPIO_PCCFGH, PC7_CFG, GPIOCFG_OUT);
   1019                        do {
   1020                          //Toggling between RC/XTAL will produce a clock edge
   1021                          //into the timer and cause CNT to increment.
   1022                          SLEEPTMR->CFG ^= SLEEPTMR_CLKSEL;
   1023                          currSleepTmrCnt = SLEEPTMR->CNTH << 16;
   1024                          currSleepTmrCnt |= SLEEPTMR->CNTL;
   1025                        } while (currSleepTmrCnt == wakeupSleepTmrCnt);
   1026                        GPIO->P[2].OUT = GPIO_PCOUT_SAVED;
   1027                        GPIO->P[2].CFGH = GPIO_PCCFGH_SAVED;
   1028                        SLEEPTMR->CFG = SLEEPTMR_CFG_SAVED;
   1029                        forceSleepTmrCnt = false;
   1030                      }
   1031                    }
   1032                    #endif //BUG11909_WORKAROUND_C
   1033          
   1034                    //Knowing that halSleepTimerIsr is about to be taken (when
   1035                    //interrupts get enabled) tells us that the chip woke up due
   1036                    //to the timer and therefore sleepTmrArtificalCnt is valid
   1037                    //and needs to be forced.  This allows us to bypass delaying
   1038                    //for SLEEPTMR_CNT to tick forward.  For FogBugz 11909/11920
   1039                    //workaround.
   1040                    if ( NVIC_GET_ENABLED_IRQ(SLEEPTMR_IRQn)
   1041                         && NVIC_GET_PENDING_IRQ(SLEEPTMR_IRQn)) {
   1042                      //sleepTmrArtificalCnt was set before sleeping
   1043                      //by halSleepForQuarterSeconds
   1044                      forceSleepTmrCnt = true;
   1045                    } else {
   1046                      uint32_t ticks = MAC_TIMER_TICKS(1000); // 1 millisecond
   1047                      uint32_t beginTime;
   1048                      forceSleepTmrCnt = false;
   1049                      //It is possible to be in a situation where the SLEEPTMR is no
   1050                      //longer ticking (32k XTAL issues).  To guard against getting
   1051                      //stuck in this loop, use the MAC Timer to timeout after 1ms (since
   1052                      //that is the maximum time this loop would normally delay for).
   1053                      MAC->TIMERCTRL |= MAC_TIMERCTRL_TIMEREN;
   1054                      beginTime = MAC->TIMER;
   1055                      do {
   1056                        currSleepTmrCnt = SLEEPTMR->CNTH << 16;
   1057                        currSleepTmrCnt |= SLEEPTMR->CNTL;
   1058                      } while ((currSleepTmrCnt == wakeupSleepTmrCnt)
   1059                               && (((MAC->TIMER - beginTime) & _MAC_TIMER_MASK) < ticks));
   1060                    }
   1061                  }
   1062                 #endif//CORTEXM3_EM35X_GEN4 // HW bug fixed in GEN4
   1063                }
