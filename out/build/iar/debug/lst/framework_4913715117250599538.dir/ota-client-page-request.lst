     19          
     20          #include "app/framework/include/af.h"
     21          #include "app/framework/plugin/ota-common/ota.h"
     22          #include "ota-client-page-request.h"
     23          #include "ota-client.h"
     24          
     25          // This is by no means a super flexible implementation of page requests.
     26          // The problem we have to try to solve is how to reasonably keep track
     27          // of lots of blocks of data that could vary in size.
     28          
     29          // The client needs to know how many blocks are going to be sent by the server
     30          // so that it can keep track of ones it missed.  However the server
     31          // is the one that ultimately dictates the size.  Therefore we only support a
     32          // server that uses the same block size as we suggest to it (via the page
     33          // request).  To insure that the server doesn't change the block size
     34          // on us (due to source routing), we ask for smaller blocks than the
     35          // 50 byte maximum we know can fit in an Image Block Response packet without
     36          // a source route.
     37          
     38          // Also 32-bit divide and modulus can be expensive (e.g. on the XAP) so wherever
     39          // possible we try to use 16-bit math instead.
     40          
     41          #if defined(EMBER_AF_PLUGIN_OTA_CLIENT_USE_PAGE_REQUEST)
     42          
     43          //------------------------------------------------------------------------------
     44          // Globals
     45          
     46          #if EM_AF_PAGE_REQUEST_BLOCK_SIZE != 32
     47          // The code only works with this block size
     48            #error "EM_AF_PAGE_REQUEST_BLOCK_SIZE MUST BE 32"
     49          #endif
     50          
     51          #define BITS_PER_BITMASK 16
     52          
     53          #if defined (PAGE_REQUEST_TEST)
     54          static uint16_t PAGE_SIZE = EMBER_AF_PLUGIN_OTA_CLIENT_PAGE_REQUEST_SIZE;
     55          static uint16_t MAX_BLOCKS_IN_PAGE = 1024 / EM_AF_PAGE_REQUEST_BLOCK_SIZE;
     56          
     57          static uint16_t BITMASK_COUNT;
     58          
     59          // Set the bitmask count to the largest possible size for initialization
     60          // of the blocksReceivedBitmask array.  We will dynamically set the
     61          // BITMASK_COUNT for testing only.
     62            #define BITMASK_COUNT_CONST (4096 / 16)
     63          
     64          #else
     65          
     66          // Supported page sizes:  1024, 2048, and 4096
     67          // These are the only ones we test.
     68            #define PAGE_SIZE EMBER_AF_PLUGIN_OTA_CLIENT_PAGE_REQUEST_SIZE
     69          
     70            #define MAX_BLOCKS_IN_PAGE (PAGE_SIZE / EM_AF_PAGE_REQUEST_BLOCK_SIZE)
     71            #define BITMASK_COUNT (MAX_BLOCKS_IN_PAGE / 16                \
     72                                   + ((PAGE_SIZE % BITS_PER_BITMASK == 0) \
     73                                      ? 0                                 \
     74                                      : 1))
     75            #define BITMASK_COUNT_CONST BITMASK_COUNT
     76          #endif
     77          
     78          static uint16_t blocksReceivedBitmask[BITMASK_COUNT_CONST];
     79          static EmAfPageRequestClientStatus pageRequestStatus = EM_AF_NO_PAGE_REQUEST;
     80          static uint32_t pageRequestOffset = 0;
     81          
     82          // For the last page, the number of blocks may be less than MAX_BLOCKS_IN_PAGE
     83          static uint16_t blocksInThisPage;
     84          
     85          #define handlingPageRequest() (pageRequestStatus != EM_AF_NO_PAGE_REQUEST)
     86          
     87          // #define EXTRA_DEBUG_PRINTING
     88          #if defined (EXTRA_DEBUG_PRINTING) || defined(EMBER_SCRIPTED_TEST)
     89            #define EXTRA_DEBUG(x) do { x; } while (0)
     90          #else
     91            #define EXTRA_DEBUG(X)
     92          #endif
     93          
     94          // It doesn't seem to add a lot of benefit in exposing this formally in
     95          // AppBuilder.  However if it matters, it can be overriden.
     96          // Normally it is always set in this file.
     97          #if !defined(PAGE_REQUEST_MISSED_PACKET_DELAY_MS)
     98            #define PAGE_REQUEST_MISSED_PACKET_DELAY_MS 10L
     99          #endif
    100          
    101          #define EMBER_AF_PLUGIN_OTA_CLIENT_PAGE_REQUEST_TIMEOUT_MS \
    102            (EMBER_AF_PLUGIN_OTA_CLIENT_PAGE_REQUEST_TIMEOUT_SECONDS * MILLISECOND_TICKS_PER_SECOND)
    103          
    104          //------------------------------------------------------------------------------
    105          // Functions
    106          
    107          uint32_t emAfInitPageRequestClient(uint32_t offsetForPageRequest,
    108                                             uint32_t totalImageSize)
    109          {
    110            uint8_t i;
    111            for (i = 0; i < BITMASK_COUNT; i++) {
    112              blocksReceivedBitmask[i] = 0;
    113            }
    114            pageRequestOffset = offsetForPageRequest;
    115          
    116            if (offsetForPageRequest + PAGE_SIZE > totalImageSize) {
    117              uint16_t remainingSize = (uint16_t)(totalImageSize - offsetForPageRequest);
    118              blocksInThisPage = remainingSize / EM_AF_PAGE_REQUEST_BLOCK_SIZE;
    119              blocksInThisPage += ((remainingSize % EM_AF_PAGE_REQUEST_BLOCK_SIZE == 0)
    120                                   ? 0
    121                                   : 1);
    122            } else {
    123              blocksInThisPage = MAX_BLOCKS_IN_PAGE;
    124            }
    125            pageRequestStatus = EM_AF_WAITING_PAGE_REQUEST_REPLIES;
    126            return EMBER_AF_PLUGIN_OTA_CLIENT_PAGE_REQUEST_TIMEOUT_MS;
    127          }
    128          
    129          EmAfPageRequestClientStatus emAfGetCurrentPageRequestStatus(void)
    130          {
    131            return pageRequestStatus;
    132          }
    133          
    134          void emAfPageRequestTimerExpired(void)
    135          {
    136            if (pageRequestStatus == EM_AF_WAITING_PAGE_REQUEST_REPLIES) {
    137              otaPrintln("Page request timer expired.  Checking for missed blocks.");
    138              pageRequestStatus = EM_AF_RETRY_MISSED_PACKETS;
    139            }
    140          }
    141          
    142          uint32_t emAfGetPageSize(void)
    143          {
    144            return PAGE_SIZE;
    145          }
    146          
    147          uint32_t emAfGetPageRequestMissedPacketDelayMs(void)
    148          {
    149            return PAGE_REQUEST_MISSED_PACKET_DELAY_MS;
    150          }
    151          
    152          static void convertBitNumberToBitmask(uint16_t absoluteBitNumber,
    153                                                uint8_t* bitmaskIndex,
    154                                                uint16_t* mask)
    155          {
    156            uint16_t relativeBitPosition;
    157            *bitmaskIndex = absoluteBitNumber / BITS_PER_BITMASK;
    158            relativeBitPosition = (absoluteBitNumber - (*bitmaskIndex * BITS_PER_BITMASK));
    159            *mask = 1 << relativeBitPosition;
    160          }
    161          
    162          #if defined(__ICCARM__)
    163          // Bug: 12578:  Workaround for IAR compiler bug
    164          //   The IAR compiler 5.4 has a bug in it where high optimizations will
    165          //   mistakenly remove a NULL pointer check when inside a FOR loop.   So we
    166          //   turn off high optimizations for this function since it contains that kind
    167          //   of code.
    168          #pragma optimize=medium
    169          #endif // defined(__ICCARM__)
    170          static uint16_t numBlocksReceived(uint32_t* returnOffset)
    171          {
    172            uint16_t blockNumber;
    173            uint8_t bitmaskIndex = 0;
    174            uint16_t bitValue;
    175            uint16_t blocksReceived = 0;
    176            if (returnOffset) {
    177              *returnOffset = pageRequestOffset;
    178            }
    179            for (blockNumber = 0; blockNumber < blocksInThisPage; blockNumber++) {
    180              if ((blockNumber >= BITS_PER_BITMASK)
    181                  && (blockNumber % BITS_PER_BITMASK == 0)) {
    182                bitmaskIndex++;
    183              }
    184              bitValue = (blocksReceivedBitmask[bitmaskIndex]
    185                          >> (blockNumber % BITS_PER_BITMASK));
    186              if ((bitValue & 0x0001) == 0) {
    187                return blocksReceived;
    188              }
    189              if (returnOffset) {
    190                *returnOffset += EM_AF_PAGE_REQUEST_BLOCK_SIZE;
    191              }
    192              blocksReceived++;
    193            }
    194            return blocksReceived;
    195          }
    196          
    197          static bool allBlocksReceived(uint16_t numReceived)
    198          {
    199            return (numReceived == blocksInThisPage);
    200          }
    201          
    202          void emAfAbortPageRequest(void)
    203          {
    204            // Note:  Don't zero out the pageRequestOffset so it can be retrieved later.
    205            pageRequestStatus = EM_AF_NO_PAGE_REQUEST;
    206          }
    207          
    208          uint32_t emAfGetFinishedPageRequestOffset(void)
    209          {
    210            return pageRequestOffset + EMBER_AF_PLUGIN_OTA_CLIENT_PAGE_REQUEST_SIZE;
    211          }
    212          
    213          EmAfPageRequestClientStatus emAfNoteReceivedBlockForPageRequestClient(uint32_t offset)
    214          {
    215            uint16_t mask;
    216            uint16_t smallOffset;
    217            uint8_t bitmaskIndex;
    218            uint16_t absoluteBitNumber;
    219            if (!handlingPageRequest()) {
    220              return EM_AF_PAGE_REQUEST_ERROR;
    221            }
    222            if (offset < pageRequestOffset) {
    223              //    otaPrintln("Received offset 0x%4X is less than current page request offset 0x%4X, ignoring.",
    224              //               offset,
    225              //               pageRequestOffset);
    226              // We ignore this because we may receive blocks out of order, from other retries, etc.
    227              return EM_AF_BLOCK_ALREADY_RECEIVED;
    228            }
    229            offset -= pageRequestOffset;
    230          
    231            // To avoid 32-bit divide and modulus, since they are expensive on the XAP,
    232            // we cast into 16-bit.  Our page size is assumed to be a 16-bit number
    233            // so this is fine.
    234            smallOffset = (uint16_t)offset;
    235          
    236            if (smallOffset % EM_AF_PAGE_REQUEST_BLOCK_SIZE != 0) {
    237              otaPrintln("ERROR: Block offset for page request is not a multiple of %d",
    238                         EM_AF_PAGE_REQUEST_BLOCK_SIZE);
    239              return EM_AF_PAGE_REQUEST_ERROR;
    240            }
    241            absoluteBitNumber = smallOffset / EM_AF_PAGE_REQUEST_BLOCK_SIZE;
    242          
    243            convertBitNumberToBitmask(absoluteBitNumber, &bitmaskIndex, &mask);
    244            if ((blocksReceivedBitmask[bitmaskIndex] & mask)) {
    245              EXTRA_DEBUG(otaPrintln("Already received block %d",
    246                                     absoluteBitNumber + 1));
    247              return EM_AF_BLOCK_ALREADY_RECEIVED;
    248            }
    249            EXTRA_DEBUG(otaPrintln("Received block %d of %d in page request",
    250                                   absoluteBitNumber + 1,
    251                                   blocksInThisPage));
    252          
    253            blocksReceivedBitmask[bitmaskIndex] |= mask;
    254          
    255            if (allBlocksReceived(numBlocksReceived(NULL))) {
    256              EXTRA_DEBUG(otaPrintln("All blocks received.  Page request complete."));
    257              emAfAbortPageRequest();
    258              return EM_AF_PAGE_REQUEST_COMPLETE;
    259            }
    260          
    261            return pageRequestStatus;
    262          }
    263          
    264          EmAfPageRequestClientStatus emAfNextMissedBlockRequestOffset(uint32_t* nextOffset)
    265          {
    266            uint16_t blocksReceived;
    267            if (pageRequestStatus != EM_AF_RETRY_MISSED_PACKETS) {
    268              return EM_AF_PAGE_REQUEST_ERROR;
    269            }
    270          
    271            blocksReceived = numBlocksReceived(nextOffset);
    272            if (allBlocksReceived(blocksReceived)) {
    273              pageRequestStatus = EM_AF_PAGE_REQUEST_COMPLETE;
    274            } else if (blocksReceived == 0) {
    275              // If we didn't get ANY blocks after a page request, odds are the
    276              // OTA server is unreachable.  No point in retrying.
    277              otaPrintln("All blocks missed.  Server seems unreachable.  Giving up.");
    278              emAfAbortPageRequest();
    279              return EM_AF_PAGE_REQUEST_ERROR;
    280            }
    281            return pageRequestStatus;
    282          }
    283          
    284          bool emAfHandlingPageRequestClient(void)
    285          {
    286            return handlingPageRequest();
    287          }
