    263          void interpanPluginInit()
    264          {
    265            gInterpanEnabled = true;
   \                     interpanPluginInit: (+1)
   \        0x0   0x2001             MOVS     R0,#+1
   \        0x2   0x.... 0x....      LDR.W    R1,??DataTable4
   \        0x6   0x7008             STRB     R0,[R1, #+0]
    266          #if defined(EMBER_AF_PLUGIN_INTERPAN_ALLOW_FRAGMENTATION)
    267            gMessageTimeout = IPMF_MSG_TIMEOUT_MS;
    268          #endif
    269          
    270          #if defined(EMBER_AF_PLUGIN_INTERPAN_ALLOW_FRAGMENTATION)
    271            uint8_t i;
    272            // The following two loops need adjustment if more than one packet is desired
    273            for (i = 0; i < EMBER_AF_PLUGIN_INTERPAN_FRAGMENTATION_MAX_OUTGOING_PACKETS; i++) {
    274              txPackets[i].messageType  = UNUSED_TX_PACKET_ENTRY;
    275              txPackets[i].eventControl = &emberAfPluginInterpanFragmentTransmitEventControl;
    276            }
    277            for (i = 0; i < EMBER_AF_PLUGIN_INTERPAN_FRAGMENTATION_MAX_INCOMING_PACKETS; i++) {
    278              MEMSET(rxPackets[i].sourceEui, 0, EUI64_SIZE);
    279              rxPackets[i].eventControl = &emberAfPluginInterpanFragmentReceiveEventControl;
    280            }
    281          #endif //EMBER_AF_PLUGIN_INTERPAN_ALLOW_FRAGMENTATION
    282          }
   \        0x8   0x4770             BX       LR
    283          
    284          // This function sets the global state of inter-PAN. If state is true, inter-PAN
    285          // messages are sent and received, else, all inter-PANs are dropped.

   \                                 In section .text, align 2, keep-with-next
    286          void emAfPluginInterpanSetEnableState(bool enable)
    287          {
    288            if (gInterpanEnabled != enable) {
   \                     emAfPluginInterpanSetEnableState: (+1)
   \        0x0   0x.... 0x....      LDR.W    R1,??DataTable4
   \        0x4   0x780A             LDRB     R2,[R1, #+0]
   \        0x6   0x4603             MOV      R3,R0
   \        0x8   0x429A             CMP      R2,R3
   \        0xA   0xD002             BEQ.N    ??emAfPluginInterpanSetEnableState_0
    289              gInterpanEnabled = enable;
   \        0xC   0x7008             STRB     R0,[R1, #+0]
    290              interpanPluginSetMacMatchFilterEnable(enable);
   \        0xE   0x.... 0x....      B.W      interpanPluginSetMacMatchFilterEnable
    291            }
    292          }
   \                     ??emAfPluginInterpanSetEnableState_0: (+1)
   \       0x12   0x4770             BX       LR
    293          
    294          #if defined(EMBER_AF_PLUGIN_INTERPAN_ALLOW_FRAGMENTATION)
    295          // This is a helper function for testing purposes only. It changes the inter-PAN
    296          // fragment message timeout
    297          void interpanPluginSetFragmentMessageTimeout(uint16_t timeout)  // seconds
    298          {
    299            uint16_t timeoutMs = timeout * 1000;
    300            if (gMessageTimeout != timeoutMs) {
    301              gMessageTimeout = timeoutMs;
    302              emberAfAppPrintln("IPMF message timeout changed to %d seconds", timeout);
    303            }
    304          }
    305          #endif //EMBER_AF_PLUGIN_INTERPAN_ALLOW_FRAGMENTATION
