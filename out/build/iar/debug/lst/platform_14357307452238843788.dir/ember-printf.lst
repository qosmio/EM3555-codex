   \       0x38   0x000D             MOVS     R5,R1
   \       0x3A   0xD005             BEQ.N    ??emDecimalStringWrite_5
    160                  buffer[length++] = '0' + digit;
   \                     ??emDecimalStringWrite_4: (+1)
