    145          static void halInternalUart1ForceXon(void);   // forward declaration
    146          
    147          static int8_t xcmdCount;       // num XONs sent to host, written only by tx isr
    148                                         //-1 means an XOFF was sent last
    149                                         // 0 means ready to rx, but no XON has been sent
    150                                         // n>0 means ready to rx, and n XONs have been sent
    151          static uint8_t xonXoffTxByte;   // if non-zero, an XON or XOFF byte to send ahead
    152                                          // of tx queue - cleared when byte is sent
    153          static uint8_t xonTimer;        // time when last data rx'ed from host, or when
    154                                          // an XON was sent (in 1/4 ticks)
    155          
    156            #define ASCII_XON         0x11  // requests host to pause sending
    157            #define ASCII_XOFF        0x13  // requests host to resume sending
    158            #define XON_REFRESH_TIME  8     // delay between repeat XONs (1/4 sec units)
    159            #define XON_REFRESH_COUNT 3     // max number of repeat XONs to send after 1st
    160          
    161          // Define thresholds for XON/XOFF flow control in terms of queue used values
    162          // Take into account the 4 byte transmit FIFO
    163            #if (EMBER_SERIAL1_RX_QUEUE_SIZE == 128)
    164              #define XON_LIMIT       16    // send an XON
    165              #define XOFF_LIMIT      96    // send an XOFF
    166            #elif (EMBER_SERIAL1_RX_QUEUE_SIZE == 64)
    167              #define XON_LIMIT       8
    168              #define XOFF_LIMIT      36
    169            #elif (EMBER_SERIAL1_RX_QUEUE_SIZE == 32)
    170              #define XON_LIMIT       2
    171              #define XOFF_LIMIT      8
    172            #elif (EMBER_SERIAL1_RX_QUEUE_SIZE > 32)
    173              #define XON_LIMIT       (EMBER_SERIAL1_RX_QUEUE_SIZE / 8)
    174              #define XOFF_LIMIT      (EMBER_SERIAL1_RX_QUEUE_SIZE * 3 / 4)
    175            #else
    176              #error "Serial port 1 receive buffer too small!"
    177            #endif
    178          #endif  // EMBER_SERIAL1_XONXOFF
    179          
