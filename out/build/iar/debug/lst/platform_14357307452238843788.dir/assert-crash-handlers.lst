     33          //------------------------------------------------------------------------------
     34          // Preprocessor definitions
     35          
     36          // Reserved instruction executed after a failed assert to cause a usage fault
     37          #define ASSERT_USAGE_OPCODE 0xDE42U
     38          
     39          //------------------------------------------------------------------------------
     40          // Forward Declarations
     41          
     42          //------------------------------------------------------------------------------
     43          // Functions
     44          
     45          // Cause a usage fault by executing a special UNDEFINED instruction.
     46          // The high byte (0xDE) is reserved to be undefined - the low byte (0x42)
     47          // is arbitrary and distiguishes a failed assert from other usage faults.
     48          // the fault handler with then decode this, grab the filename and linenumber
     49          // parameters from R0 and R1 and save the information for display after
     50          // a reset
     51          #if defined (__ICCARM__)
     52          #pragma diag_suppress=Og014

   \                                 In section .text, align 4, keep-with-next
     53          static void halInternalAssertFault(PGM_P filename, int linenumber)
     54          {
     55            asm ("DC16 0DE42h");
   \                     halInternalAssertFault: (+1)
   \        0x0   0xDE42             DC16 0DE42h
     56          }
   \        0x2   0x4770             BX       LR
     57          #pragma diag_default=Og014
     58          #elif defined (__GNUC__)
     59          __attribute__((noinline))
     60          static void halInternalAssertFault(PGM_P filename, int linenumber)
     61          {
     62            asm (".short 0xDE42\n" : : "r" (filename), "r" (linenumber));
     63          }
     64          #endif
     65          

   \                                 In section .text, align 2, keep-with-next
     66          void halInternalAssertFailed(PGM_P filename, int linenumber)
     67          {
   \                     halInternalAssertFailed: (+1)
   \        0x0   0xB538             PUSH     {R3-R5,LR}
   \        0x2   0x4604             MOV      R4,R0
   \        0x4   0x460D             MOV      R5,R1
     68            halResetWatchdog();              // In case we're close to running out.
   \        0x6   0x.... 0x....      BL       halInternalResetWatchDog
     69            INTERRUPTS_OFF();
   \        0xA   0x.... 0x....      BL       _disableBasePri
     70          
     71            #if DEBUG_LEVEL >= BASIC_DEBUG
     72            emberDebugAssert(filename, linenumber);
   \        0xE   0x4629             MOV      R1,R5
   \       0x10   0x4620             MOV      R0,R4
   \       0x12   0x.... 0x....      BL       emberDebugAssert
     73            #endif
     74          
     75            #if !defined(EMBER_ASSERT_OUTPUT_DISABLED)
     76            (void) emberSerialGuaranteedPrintf(EMBER_ASSERT_SERIAL_PORT,
     77                                               "\r\n[ASSERT:%p:%d]\r\n",
     78                                               filename,
     79                                               linenumber);
   \       0x16   0x462B             MOV      R3,R5
   \       0x18   0x4622             MOV      R2,R4
   \       0x1A   0x....             LDR.N    R1,??DataTable3
   \       0x1C   0x2001             MOVS     R0,#+1
   \       0x1E   0x.... 0x....      BL       emberSerialGuaranteedPrintf
     80            #endif
     81          
     82            #if defined (__ICCARM__) || defined (__GNUC__)
     83            // We can use the special fault mechanism to preserve more assert
     84            // information for display after a crash
     85            halInternalAssertFault(filename, linenumber);
   \       0x22   0x4629             MOV      R1,R5
   \       0x24   0x4620             MOV      R0,R4
   \       0x26   0xE8BD 0x4034      POP      {R2,R4,R5,LR}
   \       0x2A   0x....             B.N      halInternalAssertFault
     86            #else
     87            // Other toolchains don't handle the inline assembly correctly, so
     88            // we just call the internal reset
     89            halResetInfo.crash.data.assertInfo.file = filename;
     90            halResetInfo.crash.data.assertInfo.line = linenumber;
     91            halInternalSysReset(RESET_CRASH_ASSERT);
     92            #endif
     93          }
