    484          static void emCoexCounter(COEX_Events_t events);
    485          static COEX_ReqState_t txReq;
    486          static COEX_ReqState_t rxReq;
    487          
    488          #if     PHY_IS_RAIL_BASED
    489          #include "rail.h"
    490          static bool cancelTransmit(void)
    491          {
    492            extern RAIL_Handle_t emPhyRailHandle;
    493            return RAIL_StopTx(emPhyRailHandle, RAIL_STOP_MODE_ACTIVE) == RAIL_STATUS_NO_ERROR;
    494          }
    495          #else//!PHY_IS_RAIL_BASED
