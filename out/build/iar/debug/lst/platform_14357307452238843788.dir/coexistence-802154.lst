    372          static void COEX_802154_Init(void)
    373          {
    374            if (coexInitialized) {
    375              return;
    376            }
    377            configRandomDelay();
    378            COEX_SetRadioCallback(&eventsCb);
    379            COEX_HAL_Init();
    380            coexInitialized = true;
    381          }
    382          
    383          #define MAP_COEX_OPTION(coexOpt, halPtaOpt) \
    384            (mapCoexOption(&coexOptions, coexOpt, options, halPtaOpt))
    385          
    386          static void mapCoexOption(COEX_Options_t * coexOptions, COEX_Options_t coexOpt,
    387                                    HalPtaOptions options, HalPtaOptions halPtaOpt)
    388          {
    389            if ((options & halPtaOpt) != 0U) {
    390              *coexOptions |= coexOpt;
    391            } else {
    392              *coexOptions &= ~coexOpt;
    393            }
    394          }
