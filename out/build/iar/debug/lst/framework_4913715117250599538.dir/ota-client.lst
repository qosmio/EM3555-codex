    258          
    259          // The Minimum Block Period attribute's unit has gone from milliseconds to
    260          // seconds and back to milliseconds. While the timelines would suggest that
    261          // SE1.2b uses seconds and everything else uses milliseconds, the workgroup has
    262          // determined that the OTA ClusterRevision determines if the client is using
    263          // milliseconds or seconds (revision 2 for seconds, 1 and 3 for milliseconds)
    264          
    265          // NOTE: clients who desire to treat the field as seconds should set the
    266          // appropriate OTA client cluster revision when configuring the application
    267          typedef enum {
    268            DISABLE_FEATURE = 0,
    269            MILLISECONDS    = 1,              // (D)
    270            SECONDS         = SECONDS_IN_MS,
    271          } MinimumBlockPeriodUnit;
