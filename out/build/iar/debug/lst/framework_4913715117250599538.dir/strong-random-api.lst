     72          EmberEntropySource emberGetStrongRandomEntropySource()
     73          {
     74          #if defined(USE_MBEDTLS_API_FOR_TRNG)
     75            if (!mbedtlsCtrDrbgInit) {
     76              uint16_t rnd;
     77              // Get a random number to initialize the CtrDrbg module as well as the entropy source.
     78              if (EMBER_INSUFFICIENT_RANDOM_DATA == emberGetStrongRandomNumber(&rnd)) {
     79                return EMBER_ENTROPY_SOURCE_ERROR;
     80              }
     81            }
     82          
     83            // Test the entropy source for any failures.
     84            // Note: mbedtls_entropy_source_self_test returns 0 on success.
     85            // TODO: commented out as this guy refers to putchar even if verbose is set to 0 for some reason...
     86            // if (mbedtls_entropy_source_self_test(0)) {
     87            //   return EMBER_ENTROPY_SOURCE_ERROR;
     88            // }
     89          
     90          #if defined(MBEDTLS_ENTROPY_HARDWARE_ALT)
     91            // Look for TRNG as a registered entropy source
     92            uint8_t i = entropyCtx.source_count;
     93            while (i--) {
