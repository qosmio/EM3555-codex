    973          EmberStatus halPtaSetEnable(bool enabled)
    974          {
    975            COEX_Options_t coexOptions = COEX_GetOptions();
    976          
    977            if (enabled) {
    978              coexOptions |= COEX_OPTION_COEX_ENABLED;
    979            } else {
    980              coexOptions &= ~COEX_OPTION_COEX_ENABLED;
    981            }
    982            return COEX_SetOptions(coexOptions)
    983                   ? EMBER_SUCCESS : EMBER_ERR_FATAL;
    984          }
