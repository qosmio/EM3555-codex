     41          // Verify the various bootloader options that may be specified.  Use of some
     42          //   options is now deprecated and will be removed in a future release.
     43          // On the 35x platform, the use of these options is only important to specify
     44          //   the size of the bootloader, rather than the bootloader type.
     45          // By default, the lack of any option will indicate an 8k bootloader size
     46          // The NULL_BTL option indicates no bootloader is used.
     47          #ifdef APP_BTL
     48            #pragma message("The APP_BTL build option is deprecated.  Removing this option will build for any 8k bootloader type.")
     49          #endif
     50          #ifdef SERIAL_UART_BTL
     51            #pragma message("The SERIAL_UART_BTL build option is deprecated.  Removing this option will build for any 8k bootloader type.")
     52          #endif
     53          #ifdef SERIAL_OTA_BTL
     54            #pragma message("The SERIAL_UART_OTA build option is deprecated.  Removing this option will build for any 8k bootloader type.")
     55          #endif
     56          #ifdef NULL_BTL
     57          // Fully supported, no error
     58          #endif
     59          #ifdef SMALL_BTL
     60            #error SMALL_BTL is not supported
     61          #endif
