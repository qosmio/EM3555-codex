    353          #ifdef DISABLE_INTERNAL_1V8_REGULATOR
    354          //Out of reset 1v8 is enabled.  The 1v8 regulator survives deep sleep.
    355          volatile int8_t halCommonVreg1v8EnableCount = 1;
    356          
    357          //Disabling the 1V8 regulator saves current when an external 1.8V
    358          //supply is used.
    359          //The 1V8_TEST bit must be set to allow control of the 1V8 regulator
    360          //with the 1V8_EN bit.  Normally (out of reset) the 1V8 regulator is enabled.
    361          void halCommonDisableVreg1v8(void)
    362          {
    363            DECLARE_INTERRUPT_STATE;
    364            DISABLE_INTERRUPTS();
    365            assert(halCommonVreg1v8EnableCount > 0);
    366            if (--halCommonVreg1v8EnableCount == 0) {
    367              CMHV->VREGCTRL = ((CMHV->VREGCTRL
    368                                 & (~(_CMHV_VREGCTRL_1V8EN_MASK
    369                                      | _CMHV_VREGCTRL_1V8TEST_MASK)))
    370                                | (0 << _CMHV_VREGCTRL_1V8EN_SHIFT)
    371                                | (1 << _CMHV_VREGCTRL_1V8TEST_SHIFT));
    372            }
    373            RESTORE_INTERRUPTS();
    374          }
    375          
    376          //The 1V8 regulator is needed for a stable ADC reading of any external signals.
    377          //This includes analog source ADC0 thru ADC5 with the general purpose ADC and
    378          //VDD_PADS/4 with the calibration ADC.
    379          //The 1V8 regulator is not needed for any internal signals.  Such internal
    380          //signals include the calibration ADC for radio calibration.
    381          //Typically the 1V8_EN signal is set in the hardware, but not visible in the
    382          //CMHV->VREGCTRL register.  The 1V8_TEST bit must be set directly control 1V8_EN.
    383          //Clearing 1V8_TEST allows the hardware to return 1V8_EN to its enabled state.
    384          //Specifically also set 1V8_EN (though it won't have affect) to be more
    385          //verbose about the 1V8_EN state.
    386          void halCommonEnableVreg1v8(void)
    387          {
    388            DECLARE_INTERRUPT_STATE;
    389            DISABLE_INTERRUPTS();
    390            assert(halCommonVreg1v8EnableCount < 2); // at most 2 concurrent ops: AUXADC and CALADC
    391            if (++halCommonVreg1v8EnableCount == 1) {
    392              CMHV->VREGCTRL = ((CMHV->VREGCTRL
    393                                 & (~(_CMHV_VREGCTRL_1V8EN_MASK
    394                                      | _CMHV_VREGCTRL_1V8TEST_MASK)))
    395                                | (1 << _CMHV_VREGCTRL_1V8EN_SHIFT)
    396                                | (0 << _CMHV_VREGCTRL_1V8TEST_SHIFT));
    397            }
    398            RESTORE_INTERRUPTS();
    399          }
    400          
    401          #else

