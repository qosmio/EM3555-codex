    468            // Convert encoded rate into baud by extracting the <mul> and <exp>
    469            // nibbles.  <mul> is always multiplied by 100.  For <exp> <= 10,
    470            // that result is multipled by 2^<exp>; for <exp> > 10 that result
    471            // is multipled by 10^(<exp>-10).
    472            tempcfg = (uint32_t)(rate >> 4U) * 100U;   // multiplier
   \                     ??halInternalInitPhysicalUart_0: (+1)
   \       0x14   0x460A             MOV      R2,R1
   \       0x16   0x0912             LSRS     R2,R2,#+4
   \       0x18   0x2064             MOVS     R0,#+100
