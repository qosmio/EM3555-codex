   1090          #ifdef EMBER_AF_PLUGIN_COLOR_CONTROL_SERVER_TEMP
   1091          
   1092          static void moveToColorTemp(uint8_t endpoint,
   1093                                      uint16_t colorTemperature,
   1094                                      uint16_t transitionTime)
   1095          {
   1096            uint16_t temperatureMin = readColorTemperatureMin(endpoint);
   1097            uint16_t temperatureMax = readColorTemperatureMax(endpoint);
   1098          
   1099            if (transitionTime == 0) {
   1100              transitionTime++;
   1101            }
   1102          
   1103            // New command.  Need to stop any active transitions.
   1104            stopAllColorTransitions();
   1105          
   1106            // Handle color mode transition, if necessary.
   1107            handleModeSwitch(endpoint, COLOR_MODE_TEMPERATURE);
   1108          
   1109            if (colorTemperature < temperatureMin) {
   1110              colorTemperature = temperatureMin;
   1111            }
   1112          
   1113            if (colorTemperature > temperatureMax) {
   1114              colorTemperature = temperatureMax;
   1115            }
   1116          
   1117            // now, kick off the state machine.
   1118            colorTempTransitionState.initialValue = readColorTemperature(endpoint);
   1119            colorTempTransitionState.currentValue = readColorTemperature(endpoint);
   1120            colorTempTransitionState.finalValue   = colorTemperature;
   1121            colorTempTransitionState.stepsRemaining = transitionTime;
   1122            colorTempTransitionState.stepsTotal     = transitionTime;
   1123            colorTempTransitionState.endpoint  = endpoint;
   1124            colorTempTransitionState.lowLimit  = temperatureMin;
   1125            colorTempTransitionState.highLimit = temperatureMax;
   1126          
   1127            // kick off the state machine:
   1128            emberEventControlSetDelayMS(COLOR_TEMP_CONTROL, UPDATE_TIME_MS);
   1129          }
   1130          
   1131          bool emberAfColorControlClusterMoveToColorTemperatureCallback(uint16_t colorTemperature,
   1132                                                                        uint16_t transitionTime,
   1133                                                                        uint8_t optionsMask,
   1134                                                                        uint8_t optionsOverride)
   1135          {
   1136            uint8_t endpoint = emberAfCurrentEndpoint();
   1137          
   1138            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
   1139              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   1140              return true;
   1141            }
   1142          
   1143            moveToColorTemp(endpoint, colorTemperature, transitionTime);
   1144          
   1145            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   1146            return true;
   1147          }
   1148          
   1149          bool emberAfColorControlClusterMoveColorTemperatureCallback(uint8_t moveMode,
   1150                                                                      uint16_t rate,
   1151                                                                      uint16_t colorTemperatureMinimum,
   1152                                                                      uint16_t colorTemperatureMaximum,
   1153                                                                      uint8_t optionsMask,
   1154                                                                      uint8_t optionsOverride)
   1155          {
   1156            uint8_t endpoint = emberAfCurrentEndpoint();
   1157          
   1158            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
   1159              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   1160              return true;
   1161            }
   1162          
   1163            uint16_t tempPhysicalMin = readColorTemperatureMin(endpoint);
   1164            uint16_t tempPhysicalMax = readColorTemperatureMax(endpoint);
   1165            uint16_t transitionTime;
   1166          
   1167            // New command.  Need to stop any active transitions.
   1168            stopAllColorTransitions();
   1169          
   1170            if (moveMode == MOVE_MODE_STOP) {
   1171              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   1172              return true;
   1173            }
   1174          
   1175            if (rate == 0) {
   1176              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_INVALID_FIELD);
   1177              return true;
   1178            }
   1179          
   1180            if (colorTemperatureMinimum < tempPhysicalMin) {
   1181              colorTemperatureMinimum = tempPhysicalMin;
   1182            }
   1183            if (colorTemperatureMaximum > tempPhysicalMax) {
   1184              colorTemperatureMaximum = tempPhysicalMax;
   1185            }
   1186          
   1187            // Handle color mode transition, if necessary.
   1188            handleModeSwitch(endpoint, COLOR_MODE_TEMPERATURE);
   1189          
   1190            // now, kick off the state machine.
   1191            colorTempTransitionState.initialValue = readColorTemperature(endpoint);
   1192            colorTempTransitionState.currentValue = readColorTemperature(endpoint);
   1193            if (moveMode == MOVE_MODE_UP) {
   1194              if (tempPhysicalMax > colorTemperatureMaximum) {
   1195                colorTempTransitionState.finalValue = colorTemperatureMaximum;
   1196              } else {
   1197                colorTempTransitionState.finalValue = tempPhysicalMax;
   1198              }
   1199            } else {
   1200              if (tempPhysicalMin < colorTemperatureMinimum) {
   1201                colorTempTransitionState.finalValue = colorTemperatureMinimum;
   1202              } else {
   1203                colorTempTransitionState.finalValue = tempPhysicalMin;
   1204              }
   1205            }
   1206            transitionTime =
   1207              computeTransitionTimeFromStateAndRate(&colorTempTransitionState,
   1208                                                    rate);
   1209            colorTempTransitionState.stepsRemaining = transitionTime;
   1210            colorTempTransitionState.stepsTotal     = transitionTime;
   1211            colorTempTransitionState.endpoint  = endpoint;
   1212            colorTempTransitionState.lowLimit  = colorTemperatureMinimum;
   1213            colorTempTransitionState.highLimit = colorTemperatureMaximum;
   1214          
   1215            writeRemainingTime(endpoint, transitionTime);
   1216          
   1217            // kick off the state machine:
   1218            emberEventControlSetDelayMS(COLOR_TEMP_CONTROL, UPDATE_TIME_MS);
   1219          
   1220            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   1221            return true;
   1222          }
   1223          
   1224          bool emberAfColorControlClusterStepColorTemperatureCallback(uint8_t stepMode,
   1225                                                                      uint16_t stepSize,
   1226                                                                      uint16_t transitionTime,
   1227                                                                      uint16_t colorTemperatureMinimum,
   1228                                                                      uint16_t colorTemperatureMaximum,
   1229                                                                      uint8_t optionsMask,
   1230                                                                      uint8_t optionsOverride)
   1231          {
   1232            uint8_t endpoint = emberAfCurrentEndpoint();
   1233          
   1234            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
   1235              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   1236              return true;
   1237            }
   1238          
   1239            uint16_t tempPhysicalMin = readColorTemperatureMin(endpoint);
   1240            uint16_t tempPhysicalMax = readColorTemperatureMax(endpoint);
   1241          
   1242            if (transitionTime == 0) {
   1243              transitionTime++;
   1244            }
   1245          
   1246            // New command.  Need to stop any active transitions.
   1247            stopAllColorTransitions();
   1248          
   1249            if (stepMode == MOVE_MODE_STOP) {
   1250              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   1251              return true;
   1252            }
   1253          
   1254            if (colorTemperatureMinimum < tempPhysicalMin) {
   1255              colorTemperatureMinimum = tempPhysicalMin;
   1256            }
   1257            if (colorTemperatureMaximum > tempPhysicalMax) {
   1258              colorTemperatureMaximum = tempPhysicalMax;
   1259            }
   1260          
   1261            // Handle color mode transition, if necessary.
   1262            handleModeSwitch(endpoint, COLOR_MODE_TEMPERATURE);
   1263          
   1264            // now, kick off the state machine.
   1265            colorTempTransitionState.initialValue = readColorTemperature(endpoint);
   1266            colorTempTransitionState.currentValue = readColorTemperature(endpoint);
   1267            if (stepMode == MOVE_MODE_UP) {
   1268              colorTempTransitionState.finalValue
   1269                = readColorTemperature(endpoint) + stepSize;
   1270            } else {
   1271              colorTempTransitionState.finalValue
   1272                = readColorTemperature(endpoint) - stepSize;
   1273            }
   1274            colorTempTransitionState.stepsRemaining = transitionTime;
   1275            colorTempTransitionState.stepsTotal     = transitionTime;
   1276            colorTempTransitionState.endpoint  = endpoint;
   1277            colorTempTransitionState.lowLimit  = colorTemperatureMinimum;
   1278            colorTempTransitionState.highLimit = colorTemperatureMaximum;
   1279          
   1280            writeRemainingTime(endpoint, transitionTime);
   1281          
   1282            // kick off the state machine:
   1283            emberEventControlSetDelayMS(COLOR_TEMP_CONTROL, UPDATE_TIME_MS);
   1284          
   1285            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
   1286            return true;
   1287          }
   1288          
   1289          void emberAfPluginLevelControlCoupledColorTempChangeCallback(uint8_t endpoint)
   1290          {
   1291            // ZCL 5.2.2.1.1 Coupling color temperature to Level Control
   1292            //
   1293            // If the Level Control for Lighting cluster identifier 0x0008 is supported
   1294            // on the same endpoint as the Color Control cluster and color temperature is
   1295            // supported, it is possible to couple changes in the current level to the
   1296            // color temperature.
   1297            //
   1298            // The CoupleColorTempToLevel bit of the Options attribute of the Level
   1299            // Control cluster indicates whether the color temperature is to be linked
   1300            // with the CurrentLevel attribute in the Level Control cluster.
   1301            //
   1302            // If the CoupleColorTempToLevel bit of the Options attribute of the Level
   1303            // Control cluster is equal to 1 and the ColorMode or EnhancedColorMode
   1304            // attribute is set to 0x02 (color temperature) then a change in the
   1305            // CurrentLevel attribute SHALL affect the ColorTemperatureMireds attribute.
   1306            // This relationship is manufacturer specific, with the qualification that
   1307            // the maximum value of the CurrentLevel attribute SHALL correspond to a
   1308            // ColorTemperatureMired attribute value equal to the
   1309            // CoupleColorTempToLevelMinMireds attribute. This relationship is one-way so
   1310            // a change to the ColorTemperatureMireds attribute SHALL NOT have any effect
   1311            // on the CurrentLevel attribute.
   1312            //
   1313            // In order to simulate the behavior of an incandescent bulb, a low value of
   1314            // the CurrentLevel attribute SHALL be associated with a high value of the
   1315            // ColorTemperatureMireds attribute (i.e., a low value of color temperature
   1316            // in kelvins).
   1317            //
   1318            // If the CoupleColorTempToLevel bit of the Options attribute of the Level
   1319            // Control cluster is equal to 0, there SHALL be no link between color
   1320            // temperature and current level.
   1321          
   1322            if (!emberAfContainsServer(endpoint, ZCL_COLOR_CONTROL_CLUSTER_ID)) {
   1323              return;
   1324            }
   1325          
   1326            if (readColorMode(endpoint) == COLOR_MODE_TEMPERATURE) {
   1327              uint16_t tempCoupleMin = readColorTemperatureCoupleToLevelMin(endpoint);
   1328              uint16_t tempPhysMax = readColorTemperatureMax(endpoint);
   1329              uint8_t currentLevel = readLevelControlCurrentLevel(endpoint);
   1330          
   1331              // Scale color temp setting between the coupling min and the physical max.
   1332              // Note that mireds varies inversely with level: low level -> high mireds.
   1333              // Peg min/MAX level to MAX/min mireds, otherwise interpolate.
   1334              uint16_t newColorTemp;
   1335              if (currentLevel <= MIN_CURRENT_LEVEL) {
   1336                newColorTemp = tempPhysMax;
   1337              } else if (currentLevel >= MAX_CURRENT_LEVEL) {
   1338                newColorTemp = tempCoupleMin;
   1339              } else {
   1340                uint32_t tempDelta = (((uint32_t)tempPhysMax - (uint32_t)tempCoupleMin)
   1341                                      * currentLevel)
   1342                                     / (uint32_t)(MAX_CURRENT_LEVEL - MIN_CURRENT_LEVEL + 1);
   1343                newColorTemp = (uint16_t)((uint32_t)tempPhysMax - tempDelta);
   1344              }
   1345          
   1346              // Apply new color temp.
   1347              moveToColorTemp(endpoint, newColorTemp, 0);
   1348            }
   1349          }
   1350          
   1351          #endif //#ifdef EMBER_AF_PLUGIN_COLOR_CONTROL_SERVER_TEMP
   1352          

   \                                 In section .text, align 2, keep-with-next
