    692          // This IRQ is triggered on the negate REQUEST edge,
    693          // needed only when REQUEST signal is shared,
    694          // and not piggybacking GNT and REQ on same IRQ.
    695          static void COEX_REQ_ISR(void)
    696          {
    697            // External REQUEST deasserted so we can assert ours
    698            //clearGpioFlag(reqHandle) // Covered within disableGpioInt(reqHandle)
    699            disableGpioInt(reqHandle); // This is a one-shot event
    700            coexReqRandomBackoff();
    701            coexUpdateReqIsr();
    702          }
    703          
    704          #if defined(__ICCARM__) /* IAR */
    705          #pragma optimize=speed
    706          #elif __clang__
    707          __attribute__((optnone))
    708          #elif defined(__GNUC__)
    709          __attribute__((optimize("-Ofast")))
    710          #else
    711          // Don't know how to optimize unsupported compiler
    712          #endif
    713          
    714          #if SL_RAIL_UTIL_COEX_DP_ENABLED
    715          __STATIC_INLINE void pulseDirectionalPriority(void)
    716          {
    717            COEX_Req_t combinedReqState = coexCfg.combinedRequestState; // Local non-volatile flavor avoids warnings
    718            bool highPriority = ((combinedReqState & COEX_REQ_HIPRI) != 0U);
    719            bool setRequest = ((combinedReqState & COEX_REQ_ON) != 0U);
    720          
    721            // DP priority possible
    722            // Not in Direction PRIORITY bypass?
    723            if ((COEX_HAL_GetDpPulseWidth() != 0)
    724                // coexUpdateReqIsr() triggered by REQUEST changing, not PWM changing?
    725                && (setRequest != getGpioOut(reqHandle, false))
    726                // PRIORITY changing requiring a new priority pulse?
    727                && (highPriority && !COEX_HAL_GetPriority())) {
    728              COEX_ClearRequestAndPriority(); // then deaasert all PTA signals
    729            }
    730          }
    731          #else
    732          #define pulseDirectionalPriority() //no-op
    733          #endif
    734          
    735          // Must be called with interrupts disabled
    736          __STATIC_INLINE void coexUpdateReqIsr(void)
    737          {
    738            COEX_Req_t combinedReqState = coexCfg.combinedRequestState; // Local non-volatile flavor avoids warnings
    739            bool myReq = ((combinedReqState & (COEX_REQ_ON | COEX_REQ_PWM)) != 0U); // I need to REQUEST
    740            bool force = ((combinedReqState & COEX_REQ_FORCE) != 0U); // (ignoring others)
    741            bool exReq; // external requestor?
    742          
    743            if (!isReqShared() || getGpioOut(reqHandle, false)) {  // in GRANT phase
    744              exReq = false;                // ignore external requestors
    745            } else {                        // in REQUEST phase
    746              clearGpioFlag(reqHandle);  // Before sampling REQUEST, avoids race
    747              exReq = COEX_ReadRequest();
    748            }
    749            if (myReq) {                    // want to assert REQUEST
    750              if (force || !exReq) {        // can assert REQUEST
    751                if (!getGpioOut(reqHandle, false)) {
    752                  // Assume request denied until request is granted
    753                  coexCfg.requestDenied = true;
    754                }
    755                clearGpioFlag(gntHandle);
    756                enableGpioInt(gntHandle, &gntWasAsserted);
    757                bool highPriority = ((combinedReqState & COEX_REQ_HIPRI) != 0U);
    758                // If COEX_REQ_ON is not set this must be a PWM request
    759                // If request is not shared map PWM requests to the standard request
    760                bool setRequest = ((combinedReqState & COEX_REQ_ON) != 0U) || !isReqShared();
    761                pulseDirectionalPriority();
    762                COEX_SetPriorityAndRequest(setRequest, highPriority);
    763          
    764                // Issue callbacks on REQUEST assertion
    765                // These are one-shot callbacks
    766                COEX_ReqState_t* reqPtr;
    767                for (reqPtr = coexCfg.reqHead; reqPtr != NULL; reqPtr = reqPtr->next) {
    768                  if ((reqPtr->cb != NULL) && ((reqPtr->coexReq & COEX_REQCB_REQUESTED) != 0U)) {
    769                    reqPtr->coexReq &= ~COEX_REQCB_REQUESTED;
    770                    (*reqPtr->cb)(COEX_REQCB_REQUESTED);
    771                  }
    772                }
    773                setGpioFlag(gntHandle); // Manually force GRANT check if missed/no edge
    774              } else {                      // must wait for REQUEST
    775                enableGpioInt(reqHandle, NULL);
    776              }
    777            } else {                        // negate REQUEST
    778              if (getGpioOut(reqHandle, false) ) {
    779                COEX_Events_t coexEvents = COEX_EVENT_REQUEST_RELEASED;
    780                if (coexCfg.requestDenied) {
    781                  coexCfg.requestDenied = false;
    782                  coexEvents |= COEX_EVENT_REQUEST_DENIED;
    783                }
    784                coexEventCallback(coexEvents);
    785              }
    786              COEX_ClearRequestAndPriority();
    787              disableGpioInt(gntHandle);
    788              if (isReqShared()) {
    789                disableGpioInt(reqHandle);
    790              }
    791            }
    792            coexNotifyRadio(); // Reassess (assert) RHO
    793          }
