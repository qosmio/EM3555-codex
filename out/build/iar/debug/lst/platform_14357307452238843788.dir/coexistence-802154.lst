    913          static void randomDelayCallback(uint16_t randomDelayMaskUs)
    914          {
    915            halCommonDelayMicroseconds(halCommonGetRandom() & randomDelayMaskUs);
    916          }
    917          static void configRandomDelay(void)
    918          {
    919            COEX_SetRandomDelayCallback(&randomDelayCallback);
