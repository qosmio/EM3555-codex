    199          static void setGpio(COEX_GpioHandle_t gpioHandle, bool enabled)
    200          {
    201            if (gpioHandle != NULL) {
    202              COEX_HAL_GpioConfig_t *gpio = (COEX_HAL_GpioConfig_t*)gpioHandle;
    203          
    204              if (enabled == gpio->polarity) {
    205                halGpioSet(gpio->gpio);
    206              } else {
    207                halGpioClear(gpio->gpio);
    208              }
    209            }
    210          }
    211          static bool isGpioOutSet(COEX_GpioHandle_t gpioHandle, bool defaultValue)
    212          {
    213            if (gpioHandle != NULL) {
    214              COEX_HAL_GpioConfig_t *gpio = (COEX_HAL_GpioConfig_t*)gpioHandle;
    215              return !!halGpioReadOutput(gpio->gpio) == !!gpio->polarity;
    216            }
    217            return defaultValue;
    218          }
