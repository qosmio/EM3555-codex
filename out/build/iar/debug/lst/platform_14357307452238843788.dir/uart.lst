    404          static void halInternalInitUartInterrupts(uint8_t halInternalInitUartPort)
    405          {
   \                     halInternalInitUartInterrupts: (+1)
   \        0x0   0x2801             CMP      R0,#+1
   \        0x2   0xD000             BEQ.N    ??halInternalInitUartInterrupts_0
   \        0x4   0x4770             BX       LR
   \                     ??halInternalInitUartInterrupts_0: (+1)
   \        0x6   0xB580             PUSH     {R7,LR}
    406            #if defined(EM_ENABLE_SERIAL_FIFO)
    407            if (EM_SER1_PORT_EN(halInternalInitUartPort) || EM_SER2_PORT_EN(halInternalInitUartPort)) {
    408              #if defined(FIFO_DMA_USED)
    409              halInternalRestartUartDma(halInternalInitUartPort);
   \        0x8   0x2001             MOVS     R0,#+1
   \        0xA   0x.... 0x....      BL       halInternalRestartUartDma
    410          
    411              // don't do this for port 1 if it's being used for EZSP
    412              #ifdef EZSP_ASH
    413              if (halInternalInitUartPort != 1U) {
    414              #endif
    415              EVENT_SCxCFG(halInternalInitUartPort) |= (EVENT_SC12_CFG_RXOVF
    416                                                        | EVENT_SC12_CFG_FRMERR
    417                                                        | EVENT_SC12_CFG_PARERR);
   \        0xE   0x.... 0x....      LDR.W    R0,??DataTable17_1
   \       0x12   0x6C01             LDR      R1,[R0, #+64]
   \       0x14   0xF441 0x41C0      ORR      R1,R1,#0x6000
   \       0x18   0xF041 0x0108      ORR      R1,R1,#0x8
   \       0x1C   0x6401             STR      R1,[R0, #+64]
    418            #ifdef EZSP_ASH
    419            }
    420            #endif
    421          
    422              // The receive side of buffer mode does not require any interrupts.
    423              // The transmit side of buffer mode requires interrupts, which
    424              // will be configured on demand in halInternalStartUartTx(), so just
    425              // enable the top level interrupt for the transmit side.
    426              EVENT_SCxFLAG(halInternalInitUartPort) = 0xFFFF;   // Clear any stale interrupts
   \       0x1E   0xF64F 0x71FF      MOVW     R1,#+65535
   \       0x22   0x6001             STR      R1,[R0, #+0]
    427              NVIC_EnableIRQ(SCx_IRQn(halInternalInitUartPort));
   \       0x24   0x2005             MOVS     R0,#+5
   \       0x26   0xE8BD 0x4002      POP      {R1,LR}
   \       0x2A   0x....             B.N      __NVIC_EnableIRQ
    428          
    429              #if defined(RTSCTS_USED)
    430              if (EM_SER1_PORT_EN(halInternalInitUartPort) || EM_SER2_PORT_EN(halInternalInitUartPort)) {
    431                // Software-based RTS/CTS needs interrupts on DMA buffer unloading.
    432                EVENT_SCxCFG(halInternalInitUartPort) |= (EVENT_SC12_CFG_RXULDA | EVENT_SC12_CFG_RXULDB
    433                                                          | EVENT_SC12_CFG_TXULDA | EVENT_SC12_FLAG_TXULDB);
    434                SCx_REG(halInternalInitUartPort, UARTCFG) |= (SC_UARTCFG_UARTFLOW | SC_UARTCFG_UARTRTS);
    435              }
    436              #endif
    437          
    438              #else // not using DMA
    439              // Make the RX Valid interrupt level sensitive (instead of edge)
    440              // EVENT_SC1->INTMODE = EVENT_SC12_INTMODE_RXVALLEVEL;
    441              // Enable just RX interrupts; TX interrupts are controlled separately
    442              EVENT_SCxCFG(halInternalInitUartPort) |= (EVENT_SC12_CFG_RXVAL
    443                                                        | EVENT_SC12_CFG_RXOVF
    444                                                        | EVENT_SC12_CFG_FRMERR
    445                                                        | EVENT_SC12_CFG_PARERR);
    446              EVENT_SCxFLAG(halInternalInitUartPort) = 0xFFFF;   // Clear any stale interrupts
    447              NVIC_EnableIRQ(SCx_IRQn(halInternalInitUartPort));
    448              #endif // DMA
    449            }
    450            #endif // FIFO mode
    451          }
