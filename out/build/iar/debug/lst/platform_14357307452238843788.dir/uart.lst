    242          #if EM_SERIAL1_ENABLED
    243            #if    SLEEPY_IP_MODEM_UART
    244          //This macro is used to manipulate TxD to avoid glitching it across sleep
    245          //which can lead to spurrious data or framing errors seen by peer
    246              #define SC1_TXD_GPIO(gpioCfg, state) do {                                        \
    247              GPIO->P[1].CFGL = ((GPIO->P[1].CFGL & ~_GPIO_P_CFGL_Px1_MASK)                    \
    248                                 | ((gpioCfg) << _GPIO_P_CFGL_Px1_SHIFT));                     \
    249              (state) ? (GPIO->P[1].SET = GPIO_P_SET_Px1) : (GPIO->P[1].CLR = GPIO_P_CLR_Px1); \
    250          } while (0)
    251            #else//!SLEEPY_IP_MODEM_UART
    252              #define SC1_TXD_GPIO(gpioCfg, state) do {} while (0)
    253            #endif//SLEEPY_IP_MODEM_UART
