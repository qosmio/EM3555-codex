   1204          /**
   1205           * This function populates command IDs into a given buffer.
   1206           *
   1207           * It returns true if commands are complete, meaning there are NO MORE
   1208           * commands that would be returned after the last command.
   1209           * It returns false, if there were more commands, but were not populated
   1210           * because of maxIdCount limitation.
   1211           */
   1212          bool emberAfExtractCommandIds(bool outgoing,
   1213                                        EmberAfClusterCommand *cmd,
   1214                                        uint16_t clusterId,
   1215                                        uint8_t *buffer,
   1216                                        uint16_t bufferLength,
   1217                                        uint16_t *bufferIndex,
   1218                                        uint8_t startId,
   1219                                        uint8_t maxIdCount)
   1220          {
   1221            uint16_t i, count = 0;
   1222            bool returnValue = true;
   1223            uint8_t cmdDirMask = 0;
   1224          
   1225            // determine the appropriate mask to match the request
   1226            // discover commands generated, client is asking server what commands do you generate?
   1227            if (outgoing && (cmd->direction == ZCL_DIRECTION_CLIENT_TO_SERVER)) {
   1228              cmdDirMask = COMMAND_MASK_OUTGOING_SERVER;
   1229              // discover commands generated server is asking client what commands do you generate?
   1230            } else if (outgoing && (cmd->direction == ZCL_DIRECTION_SERVER_TO_CLIENT)) {
   1231              cmdDirMask = COMMAND_MASK_OUTGOING_CLIENT;
   1232              // discover commands received client is asking server what commands do you receive?
   1233            } else if (!outgoing && (cmd->direction == ZCL_DIRECTION_CLIENT_TO_SERVER)) {
   1234              cmdDirMask = COMMAND_MASK_INCOMING_SERVER;
   1235              // discover commands received server is asking client what commands do you receive?
   1236            } else {
   1237              cmdDirMask = COMMAND_MASK_INCOMING_CLIENT;
   1238            }
   1239          
   1240            for ( i = 0; i < EMBER_AF_GENERATED_COMMAND_COUNT; i++ ) {
   1241              if ( generatedCommands[i].clusterId != clusterId ) {
   1242                continue;
   1243              }
   1244          
   1245              if ((generatedCommands[i].mask & cmdDirMask) == 0 ) {
   1246                continue;
   1247              }
   1248          
   1249              //Only start from the passed command id
   1250              if (generatedCommands[i].commandId < startId) {
   1251                continue;
   1252              }
   1253          
   1254              // According to spec: if cmd->mfgSpecific is set, then we ONLY return the
   1255              // mfg specific commands. If it's not, then we ONLY return non-mfg specific.
   1256              if ( generatedCommands[i].mask & COMMAND_MASK_MANUFACTURER_SPECIFIC ) {
   1257                // Command is Mfg specific
   1258                if ( !cmd->mfgSpecific ) {
   1259                  continue;                        // ignore if asking for not mfg specific
   1260                }
   1261                if ( cmd->mfgCode != emAfGetManufacturerCodeForCommand( (EmberAfCommandMetadata*) &(generatedCommands[i]))) {
   1262                  continue;                        // Ignore if mfg code doesn't match the commands
   1263                }
   1264              } else {
   1265                // Command is not mfg specific.
   1266                if ( cmd->mfgSpecific ) {
   1267                  continue;                       // Ignore if asking for mfg specific
   1268                }
   1269              }
   1270          
   1271              // The one we are about to put in, is beyond the maxIdCount,
   1272              // so instead of populating it in, we set the return flag to
   1273              // false and get out of here.
   1274              if ( maxIdCount == count || count >= bufferLength ) {
   1275                returnValue = false;
   1276                break;
   1277              }
   1278              buffer[count] = generatedCommands[i].commandId;
   1279              (*bufferIndex)++;
   1280              count++;
   1281            }
   1282            return returnValue;
   1283          }
