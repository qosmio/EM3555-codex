    512          #ifndef EMBER_APPLICATION_HAS_TRUST_CENTER_JOIN_HANDLER
    513          EmberJoinDecision emberDefaultTrustCenterDecision = EMBER_USE_PRECONFIGURED_KEY;
    514          
    515          EmberJoinDecision emberTrustCenterJoinHandler(EmberNodeId newNodeId,
    516                                                        EmberEUI64 newNodeEui64,
    517                                                        EmberDeviceUpdate status,
    518                                                        EmberNodeId parentOfNewNode)
    519          {
    520            //emzigbee-241-4
    521          #if defined(EMBER_AF_PLUGIN_CONCENTRATOR)
    522            if (emberDefaultTrustCenterDecision != EMBER_DENY_JOIN
    523                && parentOfNewNode != emberGetNodeId()) {
    524              // stodo: not sure about the condition above,
    525              // because we should get here only if the new child is not our
    526              // direct child and it is multiple hops away?
    527              bool deviceLeft = (status == EMBER_DEVICE_LEFT);
    528              emChangeSourceRouteEntry(newNodeId, parentOfNewNode, false, deviceLeft);
    529            }
    530          #endif
    531          
    532            if (status == EMBER_STANDARD_SECURITY_SECURED_REJOIN
    533                || status == EMBER_DEVICE_LEFT) {
    534              return EMBER_NO_ACTION;
    535            }
    536          
    537            return emberDefaultTrustCenterDecision;
    538          }
    539          #endif
