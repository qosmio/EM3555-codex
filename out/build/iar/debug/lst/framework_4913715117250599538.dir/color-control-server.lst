   \                                 In section .text, align 2, keep-with-next
   1748          void emberAfColorControlClusterServerInitCallback(uint8_t endpoint)
   1749          {
   1750          #ifdef EMBER_AF_PLUGIN_COLOR_CONTROL_SERVER_TEMP
   1751            // 07-5123-07 (i.e. ZCL 7) 5.2.2.2.1.22 StartUpColorTemperatureMireds Attribute
   1752            // The StartUpColorTemperatureMireds attribute SHALL define the desired startup color
   1753            // temperature values a lamp SHAL use when it is supplied with power and this value SHALL
   1754            // be reflected in the ColorTemperatureMireds attribute. In addition, the ColorMode and
   1755            // EnhancedColorMode attributes SHALL be set to 0x02 (color temperature). The values of
   1756            // the StartUpColorTemperatureMireds attribute are listed in the table below.
   1757            // Value                Action on power up
   1758            // 0x0000-0xffef        Set the ColorTemperatureMireds attribute to this value.
   1759            // 0xffff               Set the ColorTemperatureMireds attribue to its previous value.
   1760          
   1761            // Initialize startUpColorTempMireds to "maintain previous value" value 0xFFFF
   1762            uint16_t startUpColorTemp = 0xFFFF;
   1763            EmberAfStatus status = emberAfReadAttribute(endpoint,
   1764                                                        ZCL_COLOR_CONTROL_CLUSTER_ID,
   1765                                                        ZCL_START_UP_COLOR_TEMPERATURE_MIREDS_ATTRIBUTE_ID,
   1766                                                        CLUSTER_MASK_SERVER,
   1767                                                        (uint8_t *)&startUpColorTemp,
   1768                                                        sizeof(startUpColorTemp),
   1769                                                        NULL);
   1770            if (status == EMBER_ZCL_STATUS_SUCCESS) {
   1771              uint16_t updatedColorTemp = MAX_TEMPERATURE_VALUE;
   1772              status = emberAfReadAttribute(endpoint,
   1773                                            ZCL_COLOR_CONTROL_CLUSTER_ID,
   1774                                            ZCL_COLOR_CONTROL_COLOR_TEMPERATURE_ATTRIBUTE_ID,
   1775                                            CLUSTER_MASK_SERVER,
   1776                                            (uint8_t *)&updatedColorTemp,
   1777                                            sizeof(updatedColorTemp),
   1778                                            NULL);
   1779              if (status == EMBER_ZCL_STATUS_SUCCESS) {
   1780                uint16_t tempPhysicalMin = readColorTemperatureMin(endpoint);
   1781                uint16_t tempPhysicalMax = readColorTemperatureMax(endpoint);
   1782                if (tempPhysicalMin <= startUpColorTemp && startUpColorTemp <= tempPhysicalMax) {
   1783                  // Apply valid startup color temp value that is within physical limits of device.
   1784                  // Otherwise, the startup value is outside the device's supported range, and the
   1785                  // existing setting of ColorTemp attribute will be left unchanged (i.e., treated as
   1786                  // if startup color temp was set to 0xFFFF).
   1787                  updatedColorTemp = startUpColorTemp;
   1788                  status = emberAfWriteAttribute(endpoint,
   1789                                                 ZCL_COLOR_CONTROL_CLUSTER_ID,
   1790                                                 ZCL_COLOR_CONTROL_COLOR_TEMPERATURE_ATTRIBUTE_ID,
   1791                                                 CLUSTER_MASK_SERVER,
   1792                                                 (uint8_t *)&updatedColorTemp,
   1793                                                 ZCL_INT16U_ATTRIBUTE_TYPE);
   1794                  if (status == EMBER_ZCL_STATUS_SUCCESS) {
   1795                    // Set ColorMode attributes to reflect ColorTemperature.
   1796                    uint8_t updateColorMode = EMBER_ZCL_COLOR_MODE_COLOR_TEMPERATURE;
   1797                    status = emberAfWriteAttribute(endpoint,
   1798                                                   ZCL_COLOR_CONTROL_CLUSTER_ID,
   1799                                                   ZCL_COLOR_CONTROL_COLOR_MODE_ATTRIBUTE_ID,
   1800                                                   CLUSTER_MASK_SERVER,
   1801                                                   &updateColorMode,
   1802                                                   ZCL_ENUM8_ATTRIBUTE_TYPE);
   1803                    updateColorMode = EMBER_ZCL_ENHANCED_COLOR_MODE_COLOR_TEMPERATURE;
   1804                    status = emberAfWriteAttribute(endpoint,
   1805                                                   ZCL_COLOR_CONTROL_CLUSTER_ID,
   1806                                                   ZCL_COLOR_CONTROL_ENHANCED_COLOR_MODE_ATTRIBUTE_ID,
   1807                                                   CLUSTER_MASK_SERVER,
   1808                                                   &updateColorMode,
   1809                                                   ZCL_ENUM8_ATTRIBUTE_TYPE);
   1810                  }
   1811                }
   1812              }
   1813            }
   1814          #endif
   1815          }
