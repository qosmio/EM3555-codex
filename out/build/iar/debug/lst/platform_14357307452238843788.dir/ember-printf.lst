   \                                 In section .text, align 2, keep-with-next
    110          uint8_t *emWriteHexInternal(uint8_t *charBuffer, uint16_t value, uint8_t charCount)
    111          {
   \                     emWriteHexInternal: (+1)
   \        0x0   0xB470             PUSH     {R4-R6}
    112            uint8_t c = charCount;
   \        0x2   0x4613             MOV      R3,R2
    113            charBuffer += charCount;
   \        0x4   0x1880             ADDS     R0,R0,R2
   \        0x6   0xE00E             B.N      ??emWriteHexInternal_0
    114            for (; c != 0U; c--) {
    115              uint8_t n = value & 0x0F;
    116              value = value >> 4;
    117              *(--charBuffer) = n + (n < 10
    118                                     ? '0'
    119                                     : 'A' - 10);
   \                     ??emWriteHexInternal_1: (+1)
   \        0x8   0x2437             MOVS     R4,#+55
   \        0xA   0xE009             B.N      ??emWriteHexInternal_2
   \                     ??emWriteHexInternal_3: (+1)
   \        0xC   0x460E             MOV      R6,R1
   \        0xE   0xF006 0x060F      AND      R6,R6,#0xF
   \       0x12   0x0909             LSRS     R1,R1,#+4
   \       0x14   0x1E45             SUBS     R5,R0,#+1
   \       0x16   0x4628             MOV      R0,R5
   \       0x18   0x4634             MOV      R4,R6
   \       0x1A   0x2C0A             CMP      R4,#+10
   \       0x1C   0xDAF4             BGE.N    ??emWriteHexInternal_1
   \       0x1E   0x2430             MOVS     R4,#+48
   \                     ??emWriteHexInternal_2: (+1)
   \       0x20   0x19A4             ADDS     R4,R4,R6
   \       0x22   0x702C             STRB     R4,[R5, #+0]
    120            }
   \       0x24   0x1E5B             SUBS     R3,R3,#+1
   \                     ??emWriteHexInternal_0: (+1)
   \       0x26   0x461C             MOV      R4,R3
   \       0x28   0xB2E4             UXTB     R4,R4
   \       0x2A   0x2C00             CMP      R4,#+0
   \       0x2C   0xD1EE             BNE.N    ??emWriteHexInternal_3
    121            return charBuffer + charCount;
   \       0x2E   0x1880             ADDS     R0,R0,R2
   \       0x30   0xBC70             POP      {R4-R6}
