    502          
    503          static void coexEventsCb(COEX_Events_t events)
    504          {
    505            if ((events & COEX_EVENT_COEX_CHANGED) != 0U) {
    506              emRadioEnablePta((COEX_GetOptions() & COEX_OPTION_COEX_ENABLED) != 0U);
    507            }
    508            if ((events & COEX_EVENT_GRANT_RELEASED) != 0U
    509                && (COEX_GetOptions() & COEX_OPTION_TX_ABORT) != 0U
    510                && (txReq.coexReq & COEX_REQ_ON) != 0U) {
    511              if (cancelTransmit()) {
    512                events |= COEX_EVENT_TX_ABORTED;
    513              }
    514            }
    515            emCoexCounter(events);
    516          }
    517          
    518          // Certain radios may want to override this with their own
    519          WEAK(void emRadioEnablePta(bool enabled))
    520          {
    521            UNUSED_VAR(enabled);
    522          }
    523          
    524          #define coexCounterType(type) ((events & COEX_EVENT_PRIORITY_ASSERTED) != 0U \
    525                                         ? (EMBER_COUNTER_PTA_HI_PRI_ ## type)         \
    526                                         : (EMBER_COUNTER_PTA_LO_PRI_ ## type))
    527          
    528          #ifdef EMBER_STACK_IP
    529            #define coexCounter(type, data) \
    530            emberCounterHandler(coexCounterType(type), data)
    531          #elif defined(EMBER_STACK_CONNECT)
    532            #define coexCounter(type, data) //no-op
    533          #else // must be EMBER_STACK_ZIGBEE
    534          extern void emCallCounterHandler(EmberCounterType type, uint8_t data);
    535            #define coexCounter(type, data) \
    536            emCallCounterHandler(coexCounterType(type), data)
    537          #endif //EMBER_STACK_IP
    538          
    539          static void emCoexCounter(COEX_Events_t events)
    540          {
    541            if ((events & COEX_EVENT_REQUEST_RELEASED) != 0U) {
    542              coexCounter(REQUESTED, 1);
    543            }
    544            if ((events & COEX_EVENT_REQUEST_DENIED) != 0U) {
    545              coexCounter(DENIED, 1);
    546            } else if ((events & COEX_EVENT_TX_ABORTED) != 0U) {
    547              coexCounter(TX_ABORTED, 1);
    548            } else {
    549              // Request not denied
    550            }
    551          }
    552          
    553          // Certain radios may want to override this with their own
    554          WEAK(void emPhyCancelTransmit(void))
    555          {
    556          }
    557          
    558          #if SL_RAIL_UTIL_COEX_PRIORITY_ESCALATION_ENABLE || defined(DEBUG_PTA)
    559          
    560          static uint8_t ptaCcaFailEscalate = 0U;
    561          static uint8_t ptaMacFailEscalate = 0U;
    562          static bool priorityEscalated = false;
    563          
    564          static void escalatePriority(uint8_t * counter, uint8_t threshold)
    565          {
    566            if (((halPtaGetOptions() & PTA_OPT_TX_HIPRI) == 0U)
    567                && (threshold > 0U)) {
    568              ++(*counter);
    569              if (threshold <= (*counter)) {
    570                priorityEscalated = true;
    571              }
    572            }
    573          }
    574          
    575          static void deescalatePriority(void)
    576          {
    577            if (priorityEscalated) {
    578              ptaCcaFailEscalate = 0U;
    579              ptaMacFailEscalate = 0U;
    580              priorityEscalated = false;
    581            }
    582          }
    583          
    584          #else //!(SL_RAIL_UTIL_COEX_PRIORITY_ESCALATION_ENABLE || defined(DEBUG_PTA))
    585          
    586          #define escalatePriority(counter, threshold)  /* no-op */
    587          #define deescalatePriority()                  /* no-op */
    588          
    589          #endif //SL_RAIL_UTIL_COEX_PRIORITY_ESCALATION_ENABLE || defined(DEBUG_PTA)
