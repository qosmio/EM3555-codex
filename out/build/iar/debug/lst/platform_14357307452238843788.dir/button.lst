    166          //DEBOUNCE operation is based upon the theory that when multiple reads in a row
    167          //return the same value, we have passed any debounce created by the mechanical
    168          //action of a button.  The define "DEBOUNCE" says how many reads in a row
    169          //should return the same value.  The value '5', below, is the recommended value
    170          //since this should require the signal to have stabalized for approximately
    171          //100us which should be much longer than any debounce action.
    172          //Uncomment the following line to enable software debounce operation:
    173          //#define DEBOUNCE 5
    174          
    175          //Typically, software debounce is disabled by defaulting to a value of '0'
    176          //which will cause the preprocessor to strip out the debounce code and save
    177          //flash space.
    178          #ifndef DEBOUNCE
    179          #define DEBOUNCE 0
    180          #endif//DEBOUNCE
    181          
    182          #ifdef BUTTON0

   \                                 In section .text, align 2, keep-with-next
    183          void BUTTON0_ISR(void)
    184          {
   \                     halIrqBIsr: (+1)
   \        0x0   0xB510             PUSH     {R4,LR}
    185            uint8_t buttonStateNow;
    186            #if (DEBOUNCE > 0)
    187            uint8_t buttonStatePrev;
    188            uint32_t debounce;
    189            #endif //(DEBOUNCE > 0)
    190          
    191            //clear int before read to avoid potential of missing interrupt
    192            EVENT_MISS->MISS = BUTTON0_MISS_BIT; //clear missed BUTTON0 interrupt flag
   \        0x2   0x....             LDR.N    R0,??DataTable4
   \        0x4   0xF44F 0x5100      MOV      R1,#+8192
   \        0x8   0x60C1             STR      R1,[R0, #+12]
    193            EVENT_GPIO->FLAG = BUTTON0_FLAG_BIT; //clear top level BUTTON0 interrupt flag
   \        0xA   0x2102             MOVS     R1,#+2
   \        0xC   0x6001             STR      R1,[R0, #+0]
    194          
    195            buttonStateNow = halButtonPinState(BUTTON0);
   \        0xE   0x200E             MOVS     R0,#+14
   \       0x10   0x.... 0x....      BL       halButtonPinState
    196            #if (DEBOUNCE > 0)
    197            //read button until get "DEBOUNCE" number of consistent readings
    198            for ( debounce = 0;
    199                  debounce < DEBOUNCE;
    200                  debounce = (buttonStateNow == buttonStatePrev) ? debounce + 1 : 0 ) {
    201              buttonStatePrev = buttonStateNow;
    202              //clear int before read to avoid potential of missing interrupt
    203              EVENT_GPIO->FLAG = BUTTON0_FLAG_BIT;   //clear top level BUTTON0 interrupt flag
    204              buttonStateNow = halButtonPinState(BUTTON0);
    205            }
    206            #endif //(DEBOUNCE > 0)
    207            if (button0State != buttonStateNow) { //state changed, notify app
   \       0x14   0x....             LDR.N    R4,??DataTable4_2
   \       0x16   0x7821             LDRB     R1,[R4, #+0]
   \       0x18   0x460A             MOV      R2,R1
   \       0x1A   0x4603             MOV      R3,R0
   \       0x1C   0x429A             CMP      R2,R3
   \       0x1E   0xD006             BEQ.N    ??halIrqBIsr_0
    208              button0State = buttonStateNow;
   \       0x20   0x7020             STRB     R0,[R4, #+0]
    209              halButtonIsr(BUTTON0, button0State);
   \       0x22   0x4601             MOV      R1,R0
   \       0x24   0x200E             MOVS     R0,#+14
   \       0x26   0xE8BD 0x4010      POP      {R4,LR}
