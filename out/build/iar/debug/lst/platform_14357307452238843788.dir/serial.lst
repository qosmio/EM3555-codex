    389          #ifndef EMBER_SERIAL_USE_STDIO
    390          //------------------------------------------------------
    391          // Memory allocations for Queue data structures
    392          
    393          //Macros to define fifo and buffer queues, can't use a typedef becuase the size
    394          // of the fifo array in the queues can change
    395          #define DEFINE_FIFO_QUEUE(qSize, qName)          \
    396            static struct {                                \
    397              /*! Indexes of next byte to send*/           \
    398              uint16_t head;                               \
    399              /*! Index of where to enqueue next message*/ \
    400              uint16_t tail;                               \
    401              /*! Number of bytes queued*/                 \
    402              volatile uint16_t used;                      \
    403              /*! FIFO of queue data*/                     \
    404              uint8_t fifo[qSize];                         \
    405            } qName;
    406          
    407          // Allocate Appropriate TX Queue for port 0
    408          #if EMBER_SERIAL0_MODE == EMBER_SERIAL_FIFO

   \                                 In section .bss, align 4
    409          DEFINE_FIFO_QUEUE(EMBER_SERIAL0_TX_QUEUE_SIZE, emSerial0TxQueue)
   \                     emSerial0TxQueue:
   \        0x0                      DS8 136
    410            #define EM_SERIAL0_TX_QUEUE_ADDR (&emSerial0TxQueue)
    411          #elif EMBER_SERIAL0_MODE == EMBER_SERIAL_UNUSED \
    412            || EMBER_SERIAL0_MODE == EMBER_SERIAL_LOWLEVEL
    413            #define EM_SERIAL0_TX_QUEUE_ADDR (NULL)
    414            #define EMBER_SERIAL0_TX_QUEUE_SIZE 0
    415            #define EMBER_SERIAL0_RX_QUEUE_SIZE 0
    416          #endif
    417          
    418          // Allocate Appropriate TX Queue for port 1
    419          #if EMBER_SERIAL1_MODE == EMBER_SERIAL_FIFO

   \                                 In section .bss, align 4
    420          DEFINE_FIFO_QUEUE(EMBER_SERIAL1_TX_QUEUE_SIZE, emSerial1TxQueue)
   \                     emSerial1TxQueue:
   \        0x0                      DS8 136
    421            #define EM_SERIAL1_TX_QUEUE_ADDR (&emSerial1TxQueue)
    422          #elif EMBER_SERIAL1_MODE == EMBER_SERIAL_UNUSED \
    423            || EMBER_SERIAL1_MODE == EMBER_SERIAL_LOWLEVEL
    424            #define EM_SERIAL1_TX_QUEUE_ADDR (NULL)
    425            #define EMBER_SERIAL1_TX_QUEUE_SIZE 0
    426            #define EMBER_SERIAL1_RX_QUEUE_SIZE 0
    427          #endif
