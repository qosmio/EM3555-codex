    141          //------------------------------------------------------
    142          // Serial Input
    143          
    144          // returns # bytes available for reading
    145          uint16_t emberSerialReadAvailable(uint8_t port)
    146          {
    147            return COM_ReadAvailable((COM_Port_t) port);
    148          }
    149          
    150          EmberStatus emberSerialReadByte(uint8_t port, uint8_t *dataByte)
    151          {
    152            return COM_ReadByte((COM_Port_t) port, dataByte);
    153          }
    154          
    155          EmberStatus emberSerialReadData(uint8_t port,
    156                                          uint8_t *data,
    157                                          uint16_t length,
    158                                          uint16_t *bytesRead)
    159          {
    160            uint16_t bytesReadInternal = 0;
    161            EmberStatus status;
    162          
    163            while (bytesReadInternal < length) {
    164              status = emberSerialReadByte(port, data);
    165          
    166              switch (status) {
    167                case EMBER_SUCCESS:
    168                  ++data;
    169                  ++bytesReadInternal;
    170                  break;
    171          
    172                case EMBER_SERIAL_RX_EMPTY:
    173                  // empty queue is not an error for us, we just want to keep waiting
    174                  break;
    175          
    176                default:
    177                  // only store number of bytes read if the caller provided a non-NULL pointer
    178                  if (bytesRead) {
    179                    *bytesRead = bytesReadInternal;
    180                  }
    181                  return status;
    182              }
    183            }
    184          
    185            // only store number of bytes read if the caller provided a non-NULL pointer
    186            if (bytesRead) {
    187              *bytesRead = bytesReadInternal;
    188            }
    189          
    190            return EMBER_SUCCESS;
    191          }
    192          
    193          #ifndef EMBER_TEST
    194          EmberStatus emberSerialReadDataTimeout(uint8_t port,
    195                                                 uint8_t *data,
    196                                                 uint16_t length,
    197                                                 uint16_t *bytesRead,
    198                                                 uint16_t firstByteTimeout,
    199                                                 uint16_t subsequentByteTimeout)
    200          {
    201            uint16_t bytesReadInternal = 0;
    202            EmberStatus status;
    203            uint16_t timeout = firstByteTimeout;
    204            uint16_t startTime = halCommonGetInt16uMillisecondTick();
    205          
    206            // loop until we read the max number of bytes or the timeout elapses
    207            while (bytesReadInternal < length
    208                   && elapsedTimeInt16u(startTime, halCommonGetInt16uMillisecondTick()) < timeout) {
    209              status = emberSerialReadByte(port, data);
    210          
    211              switch (status) {
    212                case EMBER_SUCCESS:
    213                  ++data;
    214                  ++bytesReadInternal;
    215                  // reset timer and timeout for next character
    216                  startTime = halCommonGetInt16uMillisecondTick();
    217                  timeout = subsequentByteTimeout;
    218                  break;
    219          
    220                case EMBER_SERIAL_RX_EMPTY:
    221                  // empty queue is not an error for us, we just want to keep waiting
    222                  break;
    223          
    224                default:
    225                  // only store number of bytes read if the caller provided a non-NULL pointer
    226                  if (bytesRead) {
    227                    *bytesRead = bytesReadInternal;
    228                  }
    229                  return status;
    230              }
    231            }
    232          
    233            // only store number of bytes read if the caller provided a non-NULL pointer
    234            if (bytesRead) {
    235              *bytesRead = bytesReadInternal;
    236            }
    237          
    238            return bytesReadInternal == length ? EMBER_SUCCESS : EMBER_SERIAL_RX_EMPTY;
    239          }
    240          
    241          #endif // EMBER_TEST
    242          
    243          EmberStatus emberSerialReadPartialLine(uint8_t port, char *data, uint8_t max, uint8_t *index)
    244          {
    245            return COM_ReadPartialLine((COM_Port_t) port, data, max, index);
    246          }
    247          
    248          EmberStatus emberSerialReadLine(uint8_t port, char *data, uint8_t max)
    249          {
    250            uint8_t index = 0;
    251          
    252            while (emberSerialReadPartialLine(port, data, max, &index) != EMBER_SUCCESS) {
    253              halResetWatchdog();
    254            }
    255            return EMBER_SUCCESS;
    256          }
