    139          uint8_t halButtonPinState(uint8_t button)
    140          {
    141            // Note: this returns the current state of the button's pin.  It may not
    142            // jive with the interrupts and their callbacks, but it is useful for
    143            // checking the state of the button on startup.
    144            switch (button) {
   \                     halButtonPinState: (+1)
   \        0x0   0x280E             CMP      R0,#+14
   \        0x2   0xD002             BEQ.N    ??halButtonPinState_0
   \        0x4   0x2816             CMP      R0,#+22
   \        0x6   0xD008             BEQ.N    ??halButtonPinState_1
   \        0x8   0xE00F             B.N      ??halButtonPinState_2
    145          #ifdef BUTTON0
    146              case BUTTON0:
    147                return ((BUTTON0_IN & BIT(BUTTON0 & 7)) != 0U) ? BUTTON_RELEASED : BUTTON_PRESSED;
   \                     ??halButtonPinState_0: (+1)
   \        0xA   0x....             LDR.N    R0,??DataTable4_6
   \        0xC   0x6800             LDR      R0,[R0, #+0]
   \        0xE   0x0980             LSRS     R0,R0,#+6
   \       0x10   0xF000 0x0001      AND      R0,R0,#0x1
   \       0x14   0xF080 0x0001      EOR      R0,R0,#0x1
   \       0x18   0x4770             BX       LR
    148          #endif
    149          #ifdef BUTTON1
    150              case BUTTON1:
    151                return ((BUTTON1_IN & BIT(BUTTON1 & 7)) != 0U) ? BUTTON_RELEASED : BUTTON_PRESSED;
   \                     ??halButtonPinState_1: (+1)
   \       0x1A   0x....             LDR.N    R0,??DataTable4_7
   \       0x1C   0x6800             LDR      R0,[R0, #+0]
