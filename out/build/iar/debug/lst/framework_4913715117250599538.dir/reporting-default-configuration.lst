     31          
     32          // Load Default reporting configuration from generated table

   \                                 In section .text, align 4, keep-with-next
     33          void emberAfPluginReportingLoadReportingConfigDefaults(void)
     34          {
     35            scanTableAddDefaultConfigs();
   \                     emberAfPluginReportingLoadReportingConfigDefaults: (+1)
   \        0x0   0xBF00             Nop
