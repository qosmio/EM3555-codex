    220          #ifdef COEX_PULSE_REQ_ON_RHO_RELEASE_SUPPORT
    221          static void toggleCoexReq(void)
    222          {
    223            if ( ((coexCfg.options
    224                   & COEX_OPTION_PULSE_REQ_ON_RHO_RELEASE) != 0U) // Pulse request on RHO release selected
    225                 && getGpioOut(reqHandle, false)          // REQUESTing and
    226                 && !isGpioInSet(rhoHandle, false)          // RHO not asserted and
    227                 && !isGpioInSet(gntHandle, true)) {        // GRANT not asserted
    228              setGpio(reqHandle, false);
    229              setGpio(reqHandle, true);
    230            }
    231          }
    232          #else //!COEX_PULSE_REQ_ON_RHO_RELEASE_SUPPORT
    233          static void toggleCoexReq(void)
    234          {
    235          }
    236          #endif //COEX_PULSE_REQ_ON_RHO_RELEASE_SUPPORT
    237          
    238          void COEX_UpdateGrant(void)
    239          {
    240            if (coexCfg.updateGrantInProgress) {
    241              // Prevent this function from being called recursively
    242              return;
    243            } else {
    244              coexCfg.updateGrantInProgress = true;
    245            }
    246            if (getGpioOut(reqHandle, false)) {    // GRANT phase
    247              bool newGnt = isGpioInSet(gntHandle, false);   // Sample GPIO once, now
    248              if (newGnt != gntWasAsserted) {
    249                gntWasAsserted = newGnt;
    250                coexNotifyRadio();
    251                // Issue callbacks on GRANT assert or negate
    252                // These are not one-shot callbacks
    253                COEX_ReqState_t* reqPtr;
    254                COEX_Req_t newState = (newGnt ? COEX_REQCB_GRANTED : COEX_REQCB_NEGATED);
    255                for (reqPtr = coexCfg.reqHead; reqPtr != NULL; reqPtr = reqPtr->next) {
    256                  if ((reqPtr->cb != NULL) && ((reqPtr->coexReq & newState) != 0U)) {
    257                    (*reqPtr->cb)(newState);
    258                  }
    259                }
    260                if (!newGnt) {
    261                  coexEventCallback(COEX_EVENT_GRANT_RELEASED);
    262          
    263                  // Do we need this to meet GRANT -> REQUEST timing?
    264                  // On GNT deassertion, pulse REQUEST to keep us going.
    265                  // Don't want to revert to REQUEST phase here but stay in GRANT phase.
    266                  // This seems dangerous in that it could allow a peer to assert their
    267                  // REQUEST causing a conflict/race.
    268                  if ((coexCfg.options & COEX_OPTION_PULSE_REQ_ON_GNT_RELEASE) != 0U) {
    269                    setGpio(reqHandle, false);
    270                    setGpio(reqHandle, true);
    271                  }
    272                }
    273              }
    274            } else {                          // REQUEST phase
    275              if (coexReqAndGntIrqShared() && isReqShared()) {
    276                // External REQUEST deasserted so we can assert ours
    277                disableGpioInt(reqHandle);   // This is a one-shot event
    278                coexReqRandomBackoff();
    279                coexUpdateReqIsr();
    280              } else {
    281                // Ignore GRANT changes unless we are REQUESTing
    282              }
    283            }
    284            coexCfg.updateGrantInProgress = false;
    285          }
    286          
    287          // Triggered on both GRANT edges
    288          static void COEX_GNT_ISR(void)
    289          {
    290            clearGpioFlag(gntHandle);
    291            COEX_UpdateGrant();
    292          }
    293          
    294          // Public API
    295          bool COEX_SetRequest(COEX_ReqState_t *reqState,
    296                               COEX_Req_t coexReq,
    297                               COEX_ReqCb_t cb)
    298          {
    299            if (setCoexReqCallbackPtr == NULL || reqState == NULL) {
    300              return false;
    301            }
    302            COEX_ReqArgs_t reqArgs;
    303            reqArgs.reqState = reqState;
    304            reqArgs.coexReq = coexReq;
    305            reqArgs.cb = cb;
    306            COEX_HAL_CallAtomic((COEX_AtomicCallback_t)setCoexReqCallbackPtr,
    307                                &reqArgs);
    308            return true;
    309          }
    310          
    311          static void updateReqList(COEX_ReqState_t *reqState)
    312          {
    313            bool reqFound = false;
    314            COEX_ReqState_t** current;
    315            COEX_Req_t combinedRequestState = reqState->coexReq;
    316            for (current = &coexCfg.reqHead; *current != NULL; current = &((*current)->next)) {
    317              if (*current == reqState) {
    318                reqFound = true;
    319                if (reqState->coexReq == COEX_REQ_OFF) {
    320                  // remove disabled request from the list, it has nothing to combine
    321                  *current = (*current)->next;
    322                  reqState->next = NULL;
    323                  if (*current == NULL) {
    324                    // break out the loop if the tail was deleted
    325                    break;
    326                  }
    327                }
    328              }
    329              combinedRequestState |= (*current)->coexReq;
    330            }
    331            if (!reqFound && (reqState->coexReq != COEX_REQ_OFF)) {
    332              // Insert new non-OFF entry at head of list
    333              reqState->next = coexCfg.reqHead;
    334              coexCfg.reqHead = reqState;
    335            }
    336            coexCfg.combinedRequestState = combinedRequestState;
    337          }
    338          
    339          static void setCoexReqCallback(COEX_ReqArgs_t *reqArgs)
    340          {
    341            COEX_ReqState_t *reqState = reqArgs->reqState;
    342            COEX_Req_t coexReq = reqArgs->coexReq;
    343          
    344            if (((coexReq & COEX_REQ_ON) == 0U)
    345                && ((reqState->coexReq & COEX_REQ_ON) != 0U)
    346                && (reqState->cb != NULL)
    347                && ((reqState->coexReq & COEX_REQCB_OFF) != 0U)) {
    348              (*reqState->cb)(COEX_REQCB_OFF);
    349            }
    350            reqState->cb = reqArgs->cb;
    351            if (reqState->coexReq != coexReq) {
    352              reqState->coexReq = coexReq;
    353              updateReqList(reqState);
    354              coexUpdateReqIsr();
    355            }
    356          }
    357          
    358          static void coexRadioHoldOffPowerDown(void)
    359          {
    360            coexCfg.radioOn = false;
    361            // When sleeping radio, no need to monitor RHO anymore
    362            disableGpioInt(rhoHandle); //clear RHO top level int enable
    363          }
    364          
    365          static void coexRadioHoldOffPowerUp(void)
    366          {
    367            coexCfg.radioOn = true;
    368            if (rhoHandle != NULL) {
    369              // When waking radio, set up initial state and resume monitoring
    370              disableGpioInt(rhoHandle); //ensure RHO interrupt is off
    371              rhoCfg.cb(); // Manually call ISR to assess current state
    372              enableGpioInt(rhoHandle, NULL); //enable RHO interrupt
    373            }
    374          }
    375          
    376          void setCoexPowerState(bool powerUp)
    377          {
    378            if (setCoexPowerStateCallbackPtr != NULL) {
    379              setCoexPowerStateCallbackPtr(powerUp);
    380            }
    381          }
    382          
    383          static void setCoexPowerStateCallback(bool powerUp)
    384          {
    385            if (powerUp) {
    386              coexRadioHoldOffPowerUp();
    387            } else {
    388              coexRadioHoldOffPowerDown();
    389            }
    390          }
    391          
    392          static void COEX_RHO_ISR(void)
    393          {
    394            // Ack interrupt before reading GPIO to avoid potential of missing int
    395            clearGpioFlag(rhoHandle);
    396            // Notify Radio land of state change
    397            toggleCoexReq();
    398            coexNotifyRadio();
    399          }
    400          
    401          static bool (*enableCoexistenceCb)(void) = NULL;
    402          
    403          static bool enableCoexistence(void)
    404          {
    405            bool enabled = ((coexCfg.options & COEX_OPTION_COEX_ENABLED) != 0U);
    406            COEX_ReqState_t* reqPtr;
    407          
    408            if (enabled) {
    409              setCoexReqCallbackPtr = &setCoexReqCallback;
    410            }
    411            for (reqPtr = coexCfg.reqHead; reqPtr != NULL; reqPtr = reqPtr->next) {
    412              COEX_SetRequest(reqPtr, COEX_REQ_OFF, NULL);
    413            }
    414            if (!enabled) {
    415              setCoexReqCallbackPtr = NULL;
    416            }
    417            (*coexEventCallback)(COEX_EVENT_COEX_CHANGED);
    418            coexNotifyRadio();
    419            return true;
    420          }
    421          
    422          static bool (*enableRadioHoldOffCb)(void) = NULL;
    423          
    424          static bool enableRadioHoldOff(void)
    425          {
    426            bool enabled = ((coexCfg.options & COEX_OPTION_RHO_ENABLED) != 0U);
    427          
    428            // Configure GPIO as input and if pulling, pull it toward deasserted state
    429            if (!enabled) {
    430              disableGpioInt(rhoHandle);
    431            }
    432            if (coexCfg.radioOn || !enabled) {
    433              coexNotifyRadio(); //Notify Radio land of current state
    434            }
    435            if (coexCfg.radioOn && enabled) {
    436              enableGpioInt(rhoHandle, NULL);
    437            }
    438            return true;
    439          }
    440          
    441          static bool coexHoldOffActive(void)
    442          {
    443            return ((coexCfg.options & COEX_OPTION_COEX_ENABLED) != 0U)
    444                   && ((!getGpioOut(reqHandle, true)       // not REQUESTing or
    445                        || !isGpioInSet(gntHandle, true) ) );    // REQUEST not GRANTed
    446          }
    447          
    448          static bool radioHoldOffActive(void)
    449          {
    450            return ((coexCfg.options & COEX_OPTION_RHO_ENABLED) != 0U)
    451                   && isGpioInSet(rhoHandle, false);
    452          }
    453          
    454          static void coexNotifyRadio(void)
    455          {
    456            bool coexRho = coexHoldOffActive() || radioHoldOffActive();
    457            if (!coexRho) {
    458              coexCfg.requestDenied = false;
    459            }
    460            setCoexOption(COEX_OPTION_HOLDOFF_ACTIVE, coexRho);
    461            coexEventCallback(COEX_EVENT_HOLDOFF_CHANGED);
    462          }
    463          
    464          bool COEX_IsEnabled(void)
    465          {
    466            return (rhoHandle != NULL)
    467                   || (gntHandle != NULL)
    468                   || (reqHandle != NULL);
    469          }
