    471          #if SL_RAIL_UTIL_COEX_OVERRIDE_GPIO_INPUT
    472          static uint8_t gpioInputOverride = 0U;
    473          static COEX_GpioHandle_t overrideGpioHandles[COEX_GPIO_INDEX_COUNT];
    474          
    475          bool COEX_GetGpioInputOverride(COEX_GpioIndex_t gpioIndex)
    476          {
    477            return gpioInputOverride & (1U << gpioIndex);
    478          }
    479          
    480          bool COEX_SetGpioInputOverride(COEX_GpioIndex_t gpioIndex, bool enable)
    481          {
    482            uint8_t gpioMask = (1U << gpioIndex);
    483          
    484            bool oldValue = ((gpioInputOverride & gpioMask) != 0U);
    485            if ((gpioIndex == 0U) || (gpioIndex >= COEX_GPIO_INDEX_COUNT)) {
    486              return false;
    487            }
    488            if (oldValue != enable) {
    489              if (enable) {
    490                gpioInputOverride |= gpioMask;
    491              } else {
    492                gpioInputOverride &= ~gpioMask;
    493              }
    494              setGpioFlag(overrideGpioHandles[gpioIndex]);
    495            }
    496            return true;
    497          }
    498          #endif //SL_RAIL_UTIL_COEX_OVERRIDE_GPIO_INPUT
