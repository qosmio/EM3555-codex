    812            #if SL_RAIL_UTIL_COEX_PRI_SHARED && !SL_RAIL_UTIL_COEX_DP_ENABLED
    813            options |= COEX_OPTION_PRI_SHARED;
    814            #endif //SL_RAIL_UTIL_COEX_PRI_SHARED && !SL_RAIL_UTIL_COEX_DP_ENABLED
    815            #if SL_RAIL_UTIL_COEX_TX_ABORT
    816            options |= COEX_OPTION_TX_ABORT;
    817            #endif //SL_RAIL_UTIL_COEX_TX_ABORT
    818            #if SL_RAIL_UTIL_COEX_DP_ENABLED
    819            COEX_HAL_ConfigDp(SL_RAIL_UTIL_COEX_DP_PULSE_WIDTH_US);
