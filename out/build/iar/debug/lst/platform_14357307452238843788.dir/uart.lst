   1346          void halInternalUartRxCheckRts(uint8_t port)
   1347          {
   1348            // Verify RTS is controlled by SW (not AUTO mode), and isn't already asserted.
   1349            // (The logic to deassert RTS is in halInternalUart1RxIsr().)
   1350            if ((SCx_REG(port, UARTCFG) & (SC_UARTCFG_UARTFLOW | SC_UARTCFG_UARTAUTO | SC_UARTCFG_UARTRTS)) == SC_UARTCFG_UARTFLOW) {
   1351              // Assert RTS if the rx queue tail is in an active (or pending) DMA buffer,
   1352              // because this means the other DMA buffer is empty.
   1353              {
   1354                DECLARE_INTERRUPT_STATE;
   1355                DISABLE_INTERRUPTS();
   1356                if (((emSerialRxQueues[port]->tail < emSerialRxQueueSizes[port] / 2)
   1357                     && (SCx_REG(port, DMACTRL) & SC_DMACTRL_RXLODA))
   1358                    || ((emSerialRxQueues[port]->tail >= emSerialRxQueueSizes[port] / 2)
   1359                        && (SCx_REG(port, DMACTRL) & SC_DMACTRL_RXLODB))) {
   1360                  SCx_REG(port, UARTCFG) |= SC_UARTCFG_UARTRTS;             // assert RTS
   1361                }
   1362                RESTORE_INTERRUPTS();
   1363              }
   1364            }
   1365          }
   1366          
   1367          #endif
