    702          #ifndef EMBER_APPLICATION_HAS_GET_ENDPOINT
    703          uint8_t emberGetEndpoint(uint8_t index)
    704          {
    705            return emberEndpoints[index].endpoint;
    706          }
    707          
    708          bool emberGetEndpointDescription(uint8_t endpoint,
    709                                           EmberEndpointDescription *result)
    710          {
    711            uint8_t i;
    712            EmberEndpoint *endpoints = emberEndpoints;
    713            for (i = 0; i < emberEndpointCount; i++, endpoints++) {
    714              if (endpoints->endpoint == endpoint) {
    715                EmberEndpointDescription const * d = endpoints->description;
    716                result->profileId                   = d->profileId;
    717                result->deviceId                    = d->deviceId;
    718                result->deviceVersion               = d->deviceVersion;
    719                result->inputClusterCount           = d->inputClusterCount;
    720                result->outputClusterCount          = d->outputClusterCount;
    721                return true;
    722              }
    723            }
    724            return false;
    725          }
    726          
    727          uint16_t emberGetEndpointCluster(uint8_t endpoint,
    728                                           EmberClusterListId listId,
    729                                           uint8_t listIndex)
    730          {
    731            uint8_t i;
    732            EmberEndpoint *endpoints = emberEndpoints;
    733            for (i = 0; i < emberEndpointCount; i++, endpoints++) {
    734              if (endpoints->endpoint == endpoint) {
    735                switch (listId) {
    736                  case EMBER_INPUT_CLUSTER_LIST:
    737                    return endpoints->inputClusterList[listIndex];
    738                  case EMBER_OUTPUT_CLUSTER_LIST:
    739                    return endpoints->outputClusterList[listIndex];
    740                  default: {
    741                  }
    742                }
    743              }
    744            }
    745            return 0;
    746          }
    747          
