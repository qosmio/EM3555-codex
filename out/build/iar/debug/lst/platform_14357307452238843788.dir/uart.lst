   \       0x22   0x2A0A             CMP      R2,#+10
   \       0x24   0xD805             BHI.N    ??halInternalInitPhysicalUart_1
    475              tempcfg <<= rate;
   \       0x26   0xFA00 0xF101      LSL      R1,R0,R1
   \       0x2A   0xE008             B.N      ??halInternalInitPhysicalUart_2
    476            } else {
    477              while (rate-- > 10U) {
    478                tempcfg *= 10U;
   \                     ??halInternalInitPhysicalUart_3: (+1)
   \       0x2C   0xEB00 0x0280      ADD      R2,R0,R0, LSL #+2
