    168                   == emberAfReadServerAttribute(endpoint,
    169                                                 ZCL_COLOR_CONTROL_CLUSTER_ID,
    170                                                 ZCL_COLOR_CONTROL_COLOR_TEMPERATURE_ATTRIBUTE_ID,
    171                                                 (uint8_t *)&colorTemperature,
    172                                                 sizeof(uint16_t)));
    173          
    174            return colorTemperature;
    175          }
    176          
    177          static uint16_t readColorTemperatureMin(uint8_t endpoint)
    178          {
    179            uint16_t colorTemperatureMin;
    180            EmberStatus status;
    181          
    182            status =
    183              emberAfReadServerAttribute(endpoint,
    184                                         ZCL_COLOR_CONTROL_CLUSTER_ID,
    185                                         ZCL_COLOR_CONTROL_COLOR_TEMP_PHYSICAL_MIN_ATTRIBUTE_ID,
    186                                         (uint8_t *)&colorTemperatureMin,
    187                                         sizeof(uint16_t));
    188          
    189            if (status != EMBER_ZCL_STATUS_SUCCESS) {
    190              colorTemperatureMin = MIN_TEMPERATURE_VALUE;
    191            }
    192          
    193            return colorTemperatureMin;
    194          }
    195          
    196          static uint16_t readColorTemperatureMax(uint8_t endpoint)
    197          {
    198            uint16_t colorTemperatureMax;
    199            EmberStatus status;
    200          
    201            status =
    202              emberAfReadServerAttribute(endpoint,
    203                                         ZCL_COLOR_CONTROL_CLUSTER_ID,
    204                                         ZCL_COLOR_CONTROL_COLOR_TEMP_PHYSICAL_MAX_ATTRIBUTE_ID,
    205                                         (uint8_t *)&colorTemperatureMax,
    206                                         sizeof(uint16_t));
    207          
    208            if (status != EMBER_ZCL_STATUS_SUCCESS) {
    209              colorTemperatureMax = MAX_TEMPERATURE_VALUE;
    210            }
    211          
    212            return colorTemperatureMax;
    213          }
    214          
    215          static uint16_t readColorTemperatureCoupleToLevelMin(uint8_t endpoint)
    216          {
    217            uint16_t colorTemperatureCoupleToLevelMin;
    218            EmberStatus status;
    219          
    220            status =
    221              emberAfReadServerAttribute(endpoint,
    222                                         ZCL_COLOR_CONTROL_CLUSTER_ID,
    223                                         ZCL_COLOR_CONTROL_TEMPERATURE_LEVEL_MIN_MIREDS_ATTRIBUTE_ID,
    224                                         (uint8_t *)&colorTemperatureCoupleToLevelMin,
    225                                         sizeof(uint16_t));
    226          
    227            if (status != EMBER_ZCL_STATUS_SUCCESS) {
    228              // Not less than the physical min.
    229              colorTemperatureCoupleToLevelMin = readColorTemperatureMin(endpoint);
    230            }
    231          
    232            return colorTemperatureCoupleToLevelMin;
    233          }
    234          
    235          static uint8_t readLevelControlCurrentLevel(uint8_t endpoint)
    236          {
    237            uint8_t currentLevel;
    238            EmberStatus status;
    239          
    240            status =
    241              emberAfReadServerAttribute(endpoint,
    242                                         ZCL_LEVEL_CONTROL_CLUSTER_ID,
    243                                         ZCL_CURRENT_LEVEL_ATTRIBUTE_ID,
    244                                         (uint8_t *)&currentLevel,
    245                                         sizeof(uint8_t));
    246          
    247            if (status != EMBER_ZCL_STATUS_SUCCESS) {
    248              currentLevel = 0x7F; // midpoint of range 0x01-0xFE
    249            }
    250          
    251            return currentLevel;
    252          }
