     85          #if     (OSC24M_HZ == -1000000) // Sentinal for runtime determination
     86          int32_t halSystemXtalHz = OSC24M_HZ;
     87          #else//!(OSC24M_HZ == -1000000)
     88          const int32_t halSystemXtalHz = OSC24M_HZ;
     89          #endif//(OSC24M_HZ == -1000000)
     90          
     91          uint32_t halSystemClockHz(void)
     92          {
     93            if ((CMLV->OSC24MCTRL & CMLV_OSC24MCTRL_SEL) == 0) {
     94              // Running off internal fast RC
     95              #if     (defined(DISABLE_RC_CALIBRATION) || (ENABLE_OSC24M == 0))
     96              // RC is uncalibrated -- estimate using OSCHF_TUNE,
     97              // assuming typical centered at 9 MHz and 0.5 MHz +/- tuning increments
     98              // (per Lipari-S-002-Lipari_analogue_specification.doc Table 25.5)
     99              // Use bitfield to make unsigned field within word into signed word
    100              struct { int16_t bitfield : OSCHF_TUNE_FIELD_BITS; } offsetbf;
    101          
    102              offsetbf.bitfield = OSCHF_TUNE;
    103              int32_t offset = offsetbf.bitfield;
    104              return (9 * 1000000) - (offset * 500000);
    105              #elif  (ENABLE_OSC24M < 0)
    106              // Assume calibrated to 1/2 of halSystemXtalHz
    107              return -(halSystemXtalHz / 2);
    108              #else//(ENABLE_OSC24M > 0)
    109              // Assume calibrated to 1/2 of OSC24M
    110              return (OSC24M_HZ / 2);
    111              #endif//(defined(DISABLE_RC_CALIBRATION) || (ENABLE_OSC24M == 0))
    112            } else {
    113              // Running off external Xtal or signal -- or want what that would be
    114              #if     (ENABLE_OSC24M == 0)
    115              // RC is uncalibrated -- estimate using OSCHF_TUNE_VALUE (or actual
    116              // if no tuning will be done),
    117              // assuming typical centered at 9 MHz and 0.5 MHz +/- tuning increments
    118              // (per Lipari-S-002-Lipari_analogue_specification.doc Table 25.5)
    119                #if     (defined(DISABLE_RC_CALIBRATION) || !defined(OSCHF_TUNE_VALUE))
    120              // Use bitfield to make unsigned field within word into signed word
    121              struct { int16_t bitfield : OSCHF_TUNE_FIELD_BITS; } offsetbf;
    122          
    123              offsetbf.bitfield = OSCHF_TUNE;
    124              int32_t offset = offsetbf.bitfield;
    125                #else//!(defined(DISABLE_RC_CALIBRATION) || !defined(OSCHF_TUNE_VALUE))
    126              int32_t offset = OSCHF_TUNE_VALUE;
    127                #endif//(defined(DISABLE_RC_CALIBRATION) || !defined(OSCHF_TUNE_VALUE))
    128              return (9 * 1000000) - (offset * 500000);
    129              #elif   (ENABLE_OSC24M < 0)
    130              return -halSystemXtalHz;
    131              #else//!(ENABLE_OSC24M < 0)
    132              return (OSC24M_HZ / (HALF_SPEED_SYSCLK ? 2 : 1));
    133              #endif//(ENABLE_OSC24M < 0)
    134            }
    135          }
    136          
    137          uint32_t halMcuClockHz(void)
    138          {
    139            uint32_t clkHz = halSystemClockHz();
    140            if (!CMLV->CPUCLKSEL && !HALF_SPEED_SYSCLK) {
    141              // MCU (FCLK) is running off PCLK = SYSCLK/2
    142              clkHz /= 2;
    143            } else {
    144              // MCU (FCLK) is (or will be) running off SYSCLK directly
    145              // With HALF_SPEED_SYSCLK, PCLK == SYSCLK and CMLV->CPUCLKSEL doesn't matter
    146            }
    147            return clkHz;
    148          }
    149          
    150          uint32_t halPeripheralClockHz()
    151          {
    152            uint32_t clkHz = halSystemClockHz();
    153            if (HALF_SPEED_SYSCLK) {
    154              // PCLK == SYSCLK
    155            } else {
    156              clkHz /= 2; // PCLK == SYSLCK/2
    157            }
    158            return clkHz;
    159          }
    160          
