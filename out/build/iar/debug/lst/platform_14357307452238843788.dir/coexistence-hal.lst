     20          #ifndef COEX_HAL_DISABLED
     21          #if COEX_HAL_SMALL_RHO
     22          #ifdef  WAKE_ON_DFL_RHO_VAR // Only define this if needed per board header
     23          uint8_t WAKE_ON_DFL_RHO_VAR = WAKE_ON_DFL_RHO;
     24          #endif//WAKE_ON_DFL_RHO_VAR
     25          
     26          extern void emRadioHoldOffIsr(boolean active);
     27          
     28          #define RHO_ENABLED_MASK  0x01u // RHO is enabled
     29          #define RHO_RADIO_ON_MASK 0x02u // Radio is on (not sleeping)
     30          static uint8_t rhoState;
     31          
     32          void COEX_HAL_Init(void)
     33          {
     34            //stub
     35          }
     36          
     37          boolean halGetRadioHoldOff(void)
     38          {
     39            return (!!(rhoState & RHO_ENABLED_MASK));
     40          }
     41          
     42          // Return active state of Radio HoldOff GPIO pin
     43          static boolean halInternalRhoPinIsActive(void)
     44          {
     45            return (!!(RHO_IN & BIT(RHO_GPIO & 7)) == !!RHO_ASSERTED);
     46          }
     47          
     48          void RHO_ISR(void)
     49          {
     50            if (rhoState & RHO_ENABLED_MASK) {
     51              // Ack interrupt before reading GPIO to avoid potential of missing int
     52              INT_MISS = RHO_MISS_BIT;
     53              INT_GPIOFLAG = RHO_FLAG_BIT; // acknowledge the interrupt
     54              // Notify Radio land of state change
     55              emRadioHoldOffIsr(halInternalRhoPinIsActive());
     56            } else {
     57             #ifdef  RHO_ISR_FOR_DFL
     58              // Defer to default GPIO config's ISR
     59              extern void RHO_ISR_FOR_DFL(void);
     60              RHO_ISR_FOR_DFL(); // This ISR is expected to acknowledge the interrupt
     61             #else//!RHO_ISR_FOR_DFL
     62              INT_GPIOFLAG = RHO_FLAG_BIT; // acknowledge the interrupt
     63             #endif//RHO_ISR_FOR_DFL
     64            }
     65          }
     66          
     67          EmberStatus halSetRadioHoldOff(boolean enabled)
     68          {
     69            // If enabling afresh or disabling after having been enabled
     70            // restart from a fresh state just in case.
     71            // Otherwise don't touch a setup that might already have been
     72            // put into place by the default 'DFL' use (e.g. a button).
     73            // When disabling after having been enabled, it is up to the
     74            // board header caller to reinit the default 'DFL' use if needed.
     75            if (enabled || (rhoState & RHO_ENABLED_MASK)) {
     76              RHO_INTCFG = 0;              //disable RHO triggering
     77              INT_CFGCLR = RHO_INT_EN_BIT; //clear RHO top level int enable
     78              INT_GPIOFLAG = RHO_FLAG_BIT; //clear stale RHO interrupt
     79              INT_MISS = RHO_MISS_BIT;     //clear stale missed RHO interrupt
     80            }
     81          
     82            rhoState = (rhoState & (uint8_t) ~RHO_ENABLED_MASK) | (enabled ? RHO_ENABLED_MASK : 0);
     83          
     84            // Reconfigure GPIOs for desired state
     85            ADJUST_GPIO_CONFIG_DFL_RHO(enabled);
     86          
     87            if (enabled) {
     88              // Only update radio if it's on, otherwise defer to when it gets turned on
     89              if (rhoState & RHO_RADIO_ON_MASK) {
     90                emRadioHoldOffIsr(halInternalRhoPinIsActive()); //Notify Radio land of current state
     91                INT_CFGSET = RHO_INT_EN_BIT; //set top level interrupt enable
     92                // Interrupt on now, ISR will maintain proper state
     93              }
     94            } else {
     95              emRadioHoldOffIsr(FALSE); //Notify Radio land of configured state
     96              // Leave interrupt state untouched (probably turned off above)
     97            }
     98          
     99            return EMBER_SUCCESS;
    100          }
    101          
    102          void halStackRadioHoldOffPowerDown(void)
    103          {
    104            rhoState &= ~RHO_RADIO_ON_MASK;
    105            if (rhoState & RHO_ENABLED_MASK) {
    106              // When sleeping radio, no need to monitor RHO anymore
    107              INT_CFGCLR = RHO_INT_EN_BIT; //clear RHO top level int enable
    108            }
    109          }
    110          
    111          void halStackRadioHoldOffPowerUp(void)
    112          {
    113            rhoState |= RHO_RADIO_ON_MASK;
    114            if (rhoState & RHO_ENABLED_MASK) {
    115              // When waking radio, set up initial state and resume monitoring
    116              INT_CFGCLR = RHO_INT_EN_BIT; //ensure RHO interrupt is off
    117              RHO_ISR(); // Manually call ISR to assess current state
    118              INT_CFGSET = RHO_INT_EN_BIT; //enable RHO interrupt
    119            }
    120          }
    121          
    122          void COEX_HAL_CallAtomic(COEX_AtomicCallback_t cb, void *arg)
    123          {
    124            ATOMIC((*cb)(arg); )
    125          }
