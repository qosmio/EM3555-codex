    669          
    670          bool emberAfColorControlClusterStepHueCallback(uint8_t stepMode,
    671                                                         uint8_t stepSize,
    672                                                         uint8_t transitionTime,
    673                                                         uint8_t optionsMask,
    674                                                         uint8_t optionsOverride)
    675          {
    676            uint8_t endpoint = emberAfCurrentEndpoint();
    677          
    678            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
    679              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    680              return true;
    681            }
    682          
    683            uint8_t currentHue = readHue(endpoint);
    684          
    685            if (transitionTime == 0) {
    686              transitionTime++;
    687            }
    688          
    689            // New command.  Need to stop any active transitions.
    690            stopAllColorTransitions();
    691          
    692            if (stepMode == MOVE_MODE_STOP) {
    693              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    694              return true;
    695            }
    696          
    697            // Handle color mode transition, if necessary.
    698            handleModeSwitch(endpoint, COLOR_MODE_HSV);
    699          
    700            // now, kick off the state machine.
    701            initHueSat(endpoint);
    702          
    703            colorHueTransitionState.initialHue = currentHue;
    704            colorHueTransitionState.currentHue = currentHue;
    705          
    706            if (stepMode == MOVE_MODE_UP) {
    707              colorHueTransitionState.finalHue = addHue(currentHue, stepSize);
    708              colorHueTransitionState.up = true;
    709            } else {
    710              colorHueTransitionState.finalHue = subtractHue(currentHue, stepSize);
    711              colorHueTransitionState.up = false;
    712            }
    713            colorHueTransitionState.stepsRemaining = transitionTime;
    714            colorHueTransitionState.stepsTotal     = transitionTime;
    715            colorHueTransitionState.endpoint = endpoint;
    716            colorHueTransitionState.repeat = false;
    717          
    718            colorSaturationTransitionState.stepsRemaining = 0;
    719          
    720            writeRemainingTime(endpoint, transitionTime);
    721          
    722            // kick off the state machine:
    723            emberEventControlSetDelayMS(COLOR_HSV_CONTROL, UPDATE_TIME_MS);
    724          
    725            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    726            return true;
    727          }
    728          
    729          bool emberAfColorControlClusterStepSaturationCallback(uint8_t stepMode,
    730                                                                uint8_t stepSize,
    731                                                                uint8_t transitionTime,
    732                                                                uint8_t optionsMask,
    733                                                                uint8_t optionsOverride)
    734          {
    735            uint8_t endpoint = emberAfCurrentEndpoint();
    736          
    737            if (!shouldExecuteIfOff(endpoint, optionsMask, optionsOverride)) {
    738              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    739              return true;
    740            }
    741          
    742            uint8_t currentSaturation = readSaturation(endpoint);
    743          
    744            if (transitionTime == 0) {
    745              transitionTime++;
    746            }
    747          
    748            // New command.  Need to stop any active transitions.
    749            stopAllColorTransitions();
    750          
    751            if (stepMode == MOVE_MODE_STOP) {
    752              emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    753              return true;
    754            }
    755          
    756            // Handle color mode transition, if necessary.
    757            handleModeSwitch(endpoint, COLOR_MODE_HSV);
    758          
    759            // now, kick off the state machine.
    760            initHueSat(endpoint);
    761          
    762            colorHueTransitionState.stepsRemaining = 0;
    763          
    764            colorSaturationTransitionState.initialValue = currentSaturation;
    765            colorSaturationTransitionState.currentValue = currentSaturation;
    766          
    767            if (stepMode == MOVE_MODE_UP) {
    768              colorSaturationTransitionState.finalValue = addSaturation(currentSaturation,
    769                                                                        stepSize);
    770            } else {
    771              colorSaturationTransitionState.finalValue =
    772                subtractSaturation(currentSaturation,
    773                                   stepSize);
    774            }
    775            colorSaturationTransitionState.stepsRemaining = transitionTime;
    776            colorSaturationTransitionState.stepsTotal     = transitionTime;
    777            colorSaturationTransitionState.endpoint       = endpoint;
    778            colorSaturationTransitionState.lowLimit  = MIN_SATURATION_VALUE;
    779            colorSaturationTransitionState.highLimit = MAX_SATURATION_VALUE;
    780          
    781            writeRemainingTime(endpoint, transitionTime);
    782          
    783            // kick off the state machine:
    784            emberEventControlSetDelayMS(COLOR_HSV_CONTROL, UPDATE_TIME_MS);
    785          
    786            emberAfSendImmediateDefaultResponse(EMBER_ZCL_STATUS_SUCCESS);
    787            return true;
    788          }
    789          
    790          static uint8_t addSaturation(uint8_t saturation1, uint8_t saturation2)
    791          {
    792            uint16_t saturation16;
    793          
    794            saturation16 =  ((uint16_t) saturation1);
    795            saturation16 += ((uint16_t) saturation2);
    796          
    797            if (saturation16 > MAX_SATURATION_VALUE) {
    798              saturation16 = MAX_SATURATION_VALUE;
    799            }
    800          
    801            return ((uint8_t) saturation16);
    802          }
    803          
    804          static uint8_t subtractSaturation(uint8_t saturation1, uint8_t saturation2)
    805          {
    806            if (saturation2 > saturation1) {
    807              return 0;
    808            }
    809          
    810            return saturation1 - saturation2;
    811          }
    812          
    813          // any time we call a hue or saturation transition, we need to assume certain
    814          // things about the hue and saturation data structures.  This function will
    815          // properly initialize them.
    816          static void initHueSat(uint8_t endpoint)
    817          {
    818            colorHueTransitionState.stepsRemaining = 0;
    819            colorHueTransitionState.currentHue = readHue(endpoint);
    820            colorHueTransitionState.endpoint   = endpoint;
    821          
    822            colorSaturationTransitionState.stepsRemaining = 0;
    823            colorSaturationTransitionState.currentValue = readSaturation(endpoint);
    824            colorSaturationTransitionState.endpoint     = endpoint;
    825          }
    826          
    827          static uint8_t readHue(uint8_t endpoint)
    828          {
    829            uint8_t hue;
