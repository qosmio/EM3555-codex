    214          // halInternalClassifyReset() records the cause of the last reset and any
    215          // assert information here. If the last reset was not due to an assert,
    216          // the saved assert filename and line number will be NULL and 0 respectively.

   \                                 In section .bss, align 2
    217          static uint16_t savedResetCause;
   \                     savedResetCause:
   \        0x0                      DS8 2

   \                                 In section .bss, align 4
    218          static HalAssertInfoType savedAssertInfo;
   \                     savedAssertInfo:
   \        0x0                      DS8 8
    219          

   \                                 In section .text, align 2, keep-with-next
    220          void halInternalClassifyReset(void)
    221          {
   \                     halInternalClassifyReset: (+1)
   \        0x0   0xB410             PUSH     {R4}
    222            // Table used to convert from CMHV->RESETEVENT register bits to reset types
    223            static const uint16_t resetEventTable[] = {
    224              RESET_POWERON_HV,            // bit 0: RESET_PWRHV_BIT
    225              RESET_POWERON_LV,            // bit 1: RESET_PWRLV_BIT
    226              RESET_EXTERNAL_PIN,          // bit 2: RESET_NRESET_BIT
    227              RESET_WATCHDOG_EXPIRED,      // bit 3: RESET_WDOG_BIT
    228              RESET_SOFTWARE,              // bit 4: RESET_SW_BIT
    229              RESET_BOOTLOADER_DEEPSLEEP,  // bit 5: RESET_DSLEEP_BIT
    230              RESET_FATAL_OPTIONBYTE,      // bit 6: RESET_OPTBYTEFAIL_BIT
    231              RESET_FATAL_LOCKUP,          // bit 7: RESET_CPULOCKUP_BIT
    232            };
    233          
    234            // It is possible for RSTB and POWER_HV to be set at the same time, which
    235            // happens when RSTB releases between HV power good and LV power good. (All
    236            // other reset events are mutually exclusive.) When both RSTB and POWER_HV
    237            // are set, POWER_HV should be returned as the cause. The bit test order --
    238            // from LSB to MSB -- ensures that it will.
    239            uint16_t resetEvent = CMHV->RESETEVENT
    240                                  & (CMHV_RESETEVENT_CPULOCKUP
    241                                     | CMHV_RESETEVENT_OPTBYTEFAIL
    242                                     | CMHV_RESETEVENT_DSLEEP
    243                                     | CMHV_RESETEVENT_SW
    244                                     | CMHV_RESETEVENT_WDOG
    245                                     | CMHV_RESETEVENT_NRESET
    246                                     | CMHV_RESETEVENT_PWRLV
    247                                     | CMHV_RESETEVENT_PWRHV);
   \        0x2   0x....             LDR.N    R0,??DataTable3
   \        0x4   0x6801             LDR      R1,[R0, #+0]
   \        0x6   0xF001 0x01FF      AND      R1,R1,#0xFF
    248          
    249            uint16_t cause = RESET_UNKNOWN;
   \        0xA   0x2000             MOVS     R0,#+0
    250            uint16_t i;
    251          
    252            for (i = 0; i < sizeof(resetEventTable) / sizeof(resetEventTable[0]); i++) {
   \        0xC   0x4602             MOV      R2,R0
   \        0xE   0xE000             B.N      ??halInternalClassifyReset_0
   \                     ??halInternalClassifyReset_1: (+1)
