    810            }
    811          
    812            emberAfAppPrintln("%pprofile 0x%2x, cluster 0x%2x, command 0x%x not permitted",
    813                              "ERR: Inter-PAN ",
    814                              headerData->profileId,
    815                              headerData->clusterId,
    816                              commandId);
    817            return false;
   \                     ??isMessageAllowed_0: (+1)
   \       0x7C   0x2000             MOVS     R0,#+0
   \                     ??isMessageAllowed_9: (+1)
   \       0x7E   0xBC70             POP      {R4-R6}
   \       0x80   0x4770             BX       LR
    818          }
    819          
    820          #if defined(EMBER_AF_PRINT_ENABLE) && defined(EMBER_AF_PRINT_APP)
    821          
    822          static void printMessage(EmberAfInterpanHeader *headerData)
    823          {
    824            emberAfAppPrint("RX inter-PAN message (");
    825            if (headerData->messageType == EMBER_AF_INTER_PAN_UNICAST) {
    826              emberAfAppPrint("uni");
    827            } else if (headerData->messageType == EMBER_AF_INTER_PAN_BROADCAST) {
    828              emberAfAppPrint("broad");
    829            } else if (headerData->messageType == EMBER_AF_INTER_PAN_MULTICAST) {
    830              emberAfAppPrint("multi");
    831            }
    832            emberAfAppPrintln("cast):");
    833            emberAfAppFlush();
    834            emberAfAppPrintln("  src pan id: 0x%2x", headerData->panId);
    835            if (headerData->options & EMBER_AF_INTERPAN_OPTION_MAC_HAS_LONG_ADDRESS) {
    836              emberAfAppPrint("  src long id: ");
    837              emberAfPrintBigEndianEui64(headerData->longAddress);
    838              emberAfAppPrintln("");
    839            } else {
    840              emberAfAppPrintln("  src short id: 0x%2x", headerData->shortAddress);
    841            }
    842            emberAfAppFlush();
    843            emberAfAppPrintln("  profile id: 0x%2x", headerData->profileId);
    844            emberAfAppPrint("  cluster id: 0x%2x ", headerData->clusterId);
    845            emberAfAppDebugExec(emberAfDecodeAndPrintClusterWithMfgCode(headerData->clusterId, emberAfGetMfgCodeFromCurrentCommand()));
    846            emberAfAppPrintln("");
    847            if (headerData->messageType == EMBER_AF_INTER_PAN_MULTICAST) {
    848              emberAfAppPrintln("  group id: 0x%2x", headerData->groupId);
    849            }
    850            emberAfAppFlush();
    851          }
    852          
    853          #endif //defined(EMBER_AF_PRINT_ENABLE) && defined(EMBER_AF_PRINT_APP)
    854          

