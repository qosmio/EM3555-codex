   \                                 In section .text, align 2, keep-with-next
    454          static EmberStatus halInternalInitPhysicalUart(uint8_t halInternalInitPhysicalPort,
    455                                                         SerialBaudRate rate,
    456                                                         SerialParity parity,
    457                                                         uint8_t stopBits)
    458          {
   \                     halInternalInitPhysicalUart: (+1)
   \        0x0   0xB570             PUSH     {R4-R6,LR}
