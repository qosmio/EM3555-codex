    307          #if defined(ENCRYPT_DEBUG)
    308          
    309          static void printData(const char * name, uint8_t* message, uint8_t length)
    310          {
    311            uint8_t i;
    312            emberAfAppPrint("\n%p: ", name);
    313            for (i = 0; i < length; i++) {
    314              emberAfAppPrint("%X ", message[i]);
    315              emberAfAppFlush();
    316            }
    317            emberAfAppPrintln("");
    318            emberAfAppFlush();
    319          }
    320          
    321          #endif
