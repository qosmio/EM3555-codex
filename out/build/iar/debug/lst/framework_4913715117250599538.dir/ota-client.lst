    154          typedef enum {
    155            DELAY_BEFORE_SEND_QUERY = 0,
    156            SEND_QUERY_NOW = 1,
    157          } SendNextQueryState;
    158          
    159          // This defines how long to wait for a message response before considering it
    160          // an error.  It also defines how long a sleepy stays awake waiting for
    161          // a message.
    162          #if EMBER_AF_DISCOVERY_TIMEOUT_QS >= 3 * 4
    163          #define MESSAGE_TIMEOUT_MS ((EMBER_AF_DISCOVERY_TIMEOUT_QS * (MILLISECOND_TICKS_PER_SECOND / 4)) + 100)
    164          #else
    165          #define MESSAGE_TIMEOUT_MS 3000L
    166          #endif
