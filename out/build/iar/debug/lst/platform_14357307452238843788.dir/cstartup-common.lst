     63          //=============================================================================
     64          // Define the size of the call stack and define a block of memory for it.
     65          //
     66          // Place the cstack area in a segment named CSTACK.  This segment is
     67          // defined soley for the purpose of placing the stack.  Refer to reset handler
     68          // for the initialization code and iar-cfg-common.icf for segment placement
     69          // in memory.
     70          //
     71          // **Note well: This sets a default value that should work for simple
     72          // applications. Larger and more complex applications may very well need to
     73          // increase the size based on compiler usage analysis or runtime testing.
     74          //=============================================================================
     75          #ifndef CSTACK_SIZE
     76            #ifdef RTOS
     77          // The RTOS will handle the actual CSTACK sizing per-task, but we must
     78          // still allocate some space for startup and exceptions.
     79              #define CSTACK_SIZE (128)  // *4 = 512 bytes
     80            #else
     81              #if (defined(EMBER_NO_STACK)    /* nodetest and friends */ \
     82            || (!defined(EMBER_STACK_IP) && !defined(EMBER_STACK_CONNECT)))
     83          // Zigbee Pro Stack
     84                #if defined(STACK_PROTECTION)
     85          // IAR's stack protection feature causes increased stack usage, so bump
     86          // up the default in that case
     87                  #define CSTACK_SIZE  (800)  // *4 = 3200 bytes
     88                #else
     89                  #define CSTACK_SIZE  (600)  // *4 = 2400 bytes
     90                #endif
     91              #else
     92          // IP Stack
     93                #define CSTACK_SIZE  (950)  // *4 = 3800 bytes
     94              #endif //defined(EMBER_NO_STACK) ...
     95            #endif
     96          #endif

   \                                 In section CSTACK, align 4, root
     97          VAR_AT_SEGMENT(NO_STRIPPING uint32_t cstackMemory[CSTACK_SIZE], __CSTACK__);
   \                     cstackMemory:
   \        0x0                      DS8 2'400
     98          
     99          #ifndef HTOL_EM3XX
    100          // Create an array to hold space for the guard region. Do not actually use this
    101          // array in code as we will move the guard region around programatically. This
    102          // is only here so that the linker takes into account the size of the guard
    103          // region when configuring the RAM.
    104          ALIGNMENT(HEAP_GUARD_REGION_SIZE_BYTES)

   \                                 In section GUARD_REGION, align 32, root
    105          VAR_AT_SEGMENT(NO_STRIPPING uint8_t guardRegionPlaceHolder[HEAP_GUARD_REGION_SIZE_BYTES], __GUARD_REGION__);
   \                     guardRegionPlaceHolder:
   \        0x0                      DS8 32
    106          #endif
    107          
    108          // Reset cause and crash info live in a special RAM segment that is
    109          // not modified during startup.

   \                                 In section RESETINFO, align 4, root
    110          VAR_AT_SEGMENT(NO_STRIPPING HalResetInfoType halResetInfo, __RESETINFO__);
   \                     halResetInfo:
   \        0x0                      DS8 152
    111          
    112          // If space is needed in the flash for data storage like for the local storage
    113          // bootloader then create an array here to hold a place for this data.
    114          #if INTERNAL_STORAGE_SIZE_B > 0
    115          // Define the storage region as an uninitialized array in the
    116          // __INTERNAL_STORAGE__ region which the linker knows how to place.
    117          VAR_AT_SEGMENT(NO_STRIPPING uint8_t internalStorage[INTERNAL_STORAGE_SIZE_B], __INTERNAL_STORAGE__);
    118          #endif
    119          
