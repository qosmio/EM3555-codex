    396          // Public API
    397          
    398          EmberStatus halPtaSetBool(HalPtaOptions option, bool value)
    399          {
    400            HalPtaOptions ptaOptions = halPtaGetOptions();
    401            ptaOptions = value ? (ptaOptions | option) : (ptaOptions & (~option));
    402            return halPtaSetOptions(ptaOptions);
    403          }
    404          
    405          HalPtaOptions halPtaGetOptions(void)
    406          {
    407            return halPtaOptions;
    408          }
    409          
    410          EmberStatus halPtaSetOptions(HalPtaOptions options)
    411          {
    412            EmberStatus status = EMBER_ERR_FATAL;
    413            COEX_802154_Init();
    414            COEX_Options_t coexOptions = COEX_GetOptions();
    415          
    416          #ifndef DEBUG_PTA
    417            if ((options & CONST_PTA_OPTIONS) != (DEFAULT_PTA_OPTIONS & CONST_PTA_OPTIONS)) {
    418              //Return error if any options argument is unsupported or constant
    419              return EMBER_BAD_ARGUMENT;
    420            }
    421          #endif //!DEBUG_PTA
    422          
    423            if (((~halPtaOptions) & options & PTA_OPT_FORCE_HOLDOFF) != 0U) {
    424              //Cancel all requests if force holdoff is enabled
    425              //All future requests will be blocked until force holdoff is disabled
    426              (void) halPtaSetTxRequest(PTA_REQ_OFF, NULL);
    427              (void) halPtaSetRxRequest(PTA_REQ_OFF, NULL);
    428            }
    429            MAP_COEX_OPTION(COEX_OPTION_TX_ABORT, PTA_OPT_ABORT_TX);
    430            MAP_COEX_OPTION(COEX_OPTION_RHO_ENABLED, PTA_OPT_RHO_ENABLED);
    431          
    432            if (COEX_SetOptions(coexOptions)) {
    433              halPtaOptions = options;
    434              status = EMBER_SUCCESS;
    435            }
    436            return status;
    437          }
    438          #else //!COEX_STACK_EVENT_SUPPORT
    439          

   \                                 In section .text, align 2, keep-with-next
    440          EmberStatus halPtaSetBool(HalPtaOptions option, bool value)
    441          {
    442            UNUSED_VAR(option);
    443            UNUSED_VAR(value);
    444            return EMBER_ERR_FATAL;
   \                     halPtaSetBool: (+1)
   \        0x0   0x2001             MOVS     R0,#+1
   \        0x2   0x4770             BX       LR
    445          }
    446          

   \                                 In section .text, align 2, keep-with-next
    447          HalPtaOptions halPtaGetOptions(void)
    448          {
    449            return PTA_OPT_DISABLED;
   \                     halPtaGetOptions: (+1)
   \        0x0   0x2000             MOVS     R0,#+0
   \        0x2   0x4770             BX       LR
    450          }
    451          

   \                                 In section .text, align 2, keep-with-next
    452          EmberStatus halPtaSetOptions(HalPtaOptions options)
    453          {
    454            UNUSED_VAR(options);
    455            return EMBER_ERR_FATAL;
   \                     halPtaSetOptions: (+1)
   \        0x0   0x2001             MOVS     R0,#+1
   \        0x2   0x4770             BX       LR
    456          }
