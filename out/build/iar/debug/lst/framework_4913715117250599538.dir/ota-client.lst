    168          #define IMAGE_BLOCK_ABORT_LENGTH                   (EMBER_AF_ZCL_OVERHEAD + 1)
    169          #define IMAGE_BLOCK_RESPONSE_SUCCESS_MIN_LENGTH    (EMBER_AF_ZCL_OVERHEAD + 14)
    170          
    171          // This is the length WITHOUT the Minimum Block Request Period
    172          #define IMAGE_BLOCK_RESPONSE_WAIT_FOR_DATA_LENGTH_MIN  (EMBER_AF_ZCL_OVERHEAD + 8)
    173          
    174          #define IMAGE_BLOCK_RESPONSE_WAIT_FOR_DATA_MIN_BLOCK_RESPONSE_LENGTH \
    175            (IMAGE_BLOCK_RESPONSE_WAIT_FOR_DATA_LENGTH_MIN + 2)
    176          
    177          // Maximum wait time that the client would wait to retrive data or to be
    178          // upgraded. If the server is not ready for the operation, it should tell the
    179          // client to wait (again).  But the client would only wait up to the value
    180          // defined below.  Regarding upgrading, current OTA spec recommends that the
    181          // client should query the server every 60 mins even though it is told to wait
    182          // longer.
    183          #define TIMEOUT_MAX_WAIT_TIME_MS   (60 * MINUTES_IN_MS)
    184          
    185          // If the server sent us an invalid delay time for the an image block
    186          // download, this is how long we will delay before getting the
    187          // next block.
    188          #define CALCULATE_TIME_ERROR_IMAGE_BLOCK_DELAY_MS (5 * MINUTES_IN_MS)
    189          
    190          // If the server sent us an invalid delay time for the upgrade end response,
    191          // we use this value for the next request.
    192          #define CALCULATE_TIME_ERROR_UPGRADE_END_RESPONSE_DELAY_MS (1 * HOURS_IN_MS)
    193          
    194          // When the server asks us to wait indefinitely to apply an upgrade,
    195          // we will ask them again in this much time.
    196          #define WAIT_FOR_UPGRADE_DELAY_MS (1 * HOURS_IN_MS)
    197          
    198          // When the Bootloading cluster's activation policy is set to activate via out-
    199          // of-band means only, this is the amount of time we wait for the out-of-band
    200          // action to happen before we complain
    201          #define WAIT_FOR_OUT_OF_BAND_ACTIVATION_MS  (1 * MINUTES_IN_MS)
    202          
    203          // How often a print is done indicating client download progress.
    204          // e.g. "Download 5% complete"
    205          #define DOWNLOAD_PERCENTAGE_UPDATE_RATE 5
    206          
    207          #define MESSAGE_TIMEOUT_BACKOFF_MS (2 * SECONDS_IN_MS)
    208          
    209          // Even when we are told to upgrade immediately, we want to insure there
    210          // is a chance for the APS retries and ZCL response to get back to their
    211          // senders.
    212          #define IMMEDIATE_UPGRADE_DELAY_MS (3 * SECONDS_IN_MS)
